@model IEnumerable<BioUTN.Modelos.BloqueDisponibilidad>

@{
    ViewData["Title"] = "Horarios Disponibles";
}

<style>
    .figma-container { font-family: 'Inter', -apple-system, sans-serif; background-color: #f9fafb; padding: 20px; border-radius: 12px; }
    .figma-card { background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 0.75rem; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); padding: 1.25rem; transition: all 0.2s; }
    .figma-btn-primary { background-color: #10b981; color: white; border: none; padding: 0.625rem 1.25rem; border-radius: 0.5rem; font-size: 14px; font-weight: 500; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; transition: all 0.2s; }
    .figma-btn-primary:hover { background-color: #059669; color: white; }
    .btn-edit { color: #3b82f6; background-color: #eff6ff; padding: 0.375rem 0.75rem; border-radius: 0.5rem; font-size: 12px; font-weight: 600; text-decoration: none; border: 1px solid #bfdbfe; transition: all 0.2s; }
    .btn-edit:hover { background-color: #dbeafe; color: #2563eb; }
    .btn-delete { color: #ef4444; background-color: #fef2f2; border: 1px solid #fecaca; padding: 0.375rem 0.75rem; border-radius: 0.5rem; font-size: 12px; font-weight: 600; transition: all 0.2s; }
    .btn-delete:hover { background-color: #fee2e2; color: #dc2626; }
    .badge-soft { font-size: 11px; font-weight: 600; padding: 0.25rem 0.5rem; border-radius: 4px; border: 1px solid #e5e7eb; background: #f9fafb; color: #4b5563; }
</style>

<div class="figma-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1" style="font-weight: 700; color: #111827;">Horarios de Equipos</h1>
            <p class="text-muted mb-0" style="font-size: 14px;">Configuración de días y horas disponibles para reserva</p>
        </div>
        <a asp-action="Create" class="figma-btn-primary">
            <i class="bi bi-plus-lg"></i>
            <span>Nuevo Horario</span>
        </a>
    </div>

    <div class="figma-card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted" style="font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px;">
                    <tr>
                        <th class="py-3 px-4 border-0 rounded-start">Equipo</th>
                        <th class="py-3 px-4 border-0">Día</th>
                        <th class="py-3 px-4 border-0">Hora Inicio</th>
                        <th class="py-3 px-4 border-0">Hora Fin</th>
                        <th class="py-3 px-4 border-0">Tipo</th>
                        <th class="py-3 px-4 border-0 rounded-end text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody style="font-size: 14px; color: #374151;">
                    @foreach (var item in Model) {
                        <tr>
                            <td class="py-3 px-4">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="bg-blue-50 text-blue-600 rounded p-2" style="background-color: #eff6ff; color: #2563eb;">
                                        <i class="bi bi-pc-display-horizontal"></i>
                                    </div>
                                    <span class="fw-bold" style="color: #111827;">@(item.Equipo?.Nombre ?? "N/A")</span>
                                </div>
                            </td>
                            <td class="py-3 px-4 fw-bold">@item.DiaSemana</td>
                            <td class="py-3 px-4">@item.HoraInicio.ToString(@"hh\:mm")</td>
                            <td class="py-3 px-4">@item.HoraFin.ToString(@"hh\:mm")</td>
                            <td class="py-3 px-4">
                                <span class="badge-soft">@item.TipoReserva</span>
                            </td>
                            <td class="py-3 px-4 text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn-edit"><i class="bi bi-pencil-fill"></i></a>
                                    <form asp-action="Delete" asp-route-id="@item.Id" onsubmit="return confirm('¿Eliminar horario?');" class="d-inline">
                                        <button type="submit" class="btn-delete"><i class="bi bi-trash-fill"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    @if(!Model.Any()) {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-muted">
                                <i class="bi bi-calendar-x fs-1 mb-2 d-block"></i>
                                No hay horarios configurados. <br>
                                Haz clic en "Nuevo Horario" para empezar.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
