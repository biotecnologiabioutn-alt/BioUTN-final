@model BioUTN.Modelos.EntradaDiario

@{
    ViewData["Title"] = "Nueva Ficha de Seguimiento";
}

@section Styles {
<style>
    .figma-container { font-family: 'Inter', -apple-system, sans-serif; background-color: #f9fafb; padding: 20px; border-radius: 12px; }
    .figma-card { background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 0.75rem; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); padding: 1.5rem; }
    .figma-label { font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 0.5rem; display: block; }
    .figma-input { width: 100%; padding: 0.625rem 0.75rem; border-radius: 0.5rem; border: 1px solid #e5e7eb; font-size: 14px; color: #111827; outline: none; transition: all 0.2s; background-color: #ffffff; }
    .figma-input:focus { border-color: rgba(16, 185, 129, 0.6); box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.2); }
    .figma-btn-primary { background-color: #10b981; color: white; border: none; padding: 0.625rem 1.25rem; border-radius: 0.5rem; font-size: 14px; font-weight: 500; transition: all 0.2s; }
    .figma-btn-primary:hover { background-color: #059669; color: white; }
    .figma-btn-secondary { background-color: white; color: #374151; border: 1px solid #e5e7eb; padding: 0.625rem 1.25rem; border-radius: 0.5rem; font-size: 14px; font-weight: 500; transition: all 0.2s; text-decoration: none; display: inline-flex; align-items: center; }
    .figma-btn-secondary:hover { background-color: #f9fafb; color: #111827; }
    .section-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: #6b7280; font-weight: 600; margin-bottom: 1rem; margin-top: 1.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid #f3f4f6; }
</style>
}

<div class="figma-container">
    <div class="mb-4">
        <h3 style="font-weight: 700; color: #111827; font-size: 18px;">Nueva Ficha de Seguimiento</h3>
        <p class="text-muted" style="font-size: 13px;">Registrar una observación o nota en el cuaderno digital del lote.</p>
    </div>

    <div class="row">
        <div class="col-md-10 col-lg-8">
            <div class="figma-card">
                <form asp-action="Create" class="space-y-4">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 13px;"></div>

                    <div class="section-label mt-0">Asignación</div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="IdProyecto" class="figma-label">ID Proyecto *</label>
                            <input asp-for="IdProyecto" type="number" class="figma-input" required placeholder="Ej: 1" />
                            <span asp-validation-for="IdProyecto" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="IdUsuario" class="figma-label">ID Usuario *</label>
                            <input asp-for="IdUsuario" type="number" class="figma-input" required placeholder="Ej: 1" />
                            <span asp-validation-for="IdUsuario" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="IdLoteCultivo" class="figma-label">ID Lote (Opcional)</label>
                        <input asp-for="IdLoteCultivo" type="number" class="figma-input" placeholder="ID del lote en caso de aplicar a uno" />
                        <span asp-validation-for="IdLoteCultivo" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="section-label">Detalles de Observación</div>
                    <div class="mb-3">
                        <label asp-for="Titulo" class="figma-label">Título *</label>
                        <input asp-for="Titulo" class="figma-input" required placeholder="Breve título descriptivo" />
                        <span asp-validation-for="Titulo" class="text-danger small mt-1 d-block"></span>
                    </div>
                    
                    <div class="mb-3">
                        <label asp-for="Contenido" class="figma-label">Contenido / Observaciones *</label>
                        <textarea asp-for="Contenido" class="figma-input" rows="5" required placeholder="Describe los hallazgos y detalles observados..."></textarea>
                        <span asp-validation-for="Contenido" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4 pt-3" style="border-top: 1px solid #e5e7eb;">
                        <a asp-action="Index" class="figma-btn-secondary">Volver</a>
                        <button type="submit" class="figma-btn-primary">Guardar Ficha</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
