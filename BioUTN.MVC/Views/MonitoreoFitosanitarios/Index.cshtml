@model IEnumerable<BioUTN.Modelos.MonitoreoFitosanitario>

@{
    ViewData["Title"] = "Control de Contaminación";
}

<style>
    /* Custom Figma-like styles */
    .figma-container {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background-color: #f9fafb;
        padding: 20px;
        border-radius: 12px;
    }
    .figma-card {
        background-color: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 0.75rem;
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        padding: 1.25rem;
        transition: all 0.2s;
    }
    .monitor-filters {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }
    .filter-btn {
        padding: 0.375rem 1rem;
        border-radius: 20px;
        border: 1px solid #e5e7eb;
        background: #ffffff;
        color: #4b5563;
        cursor: pointer;
        font-size: 0.78rem;
        font-weight: 500;
        transition: all 0.2s;
    }
    .filter-btn.active {
        background: #ecfdf5;
        border-color: #10b981;
        color: #047857;
    }
    .filter-btn:hover {
        background: #f3f4f6;
    }

    .lote-monitor-row {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 1rem 1.25rem;
        margin-bottom: 0.6rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        transition: all 0.2s;
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    }
    .lote-monitor-row:hover {
        background: #f9fafb;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
    }
    .lote-monitor-row.danger-row {
        border-color: #fca5a5;
        background: #fef2f2;
    }
    .lote-monitor-row.warn-row {
        border-color: #fde047;
        background: #fefce8;
    }

    .lote-code-badge {
        font-family: 'Inter', sans-serif;
        font-size: 0.82rem;
        font-weight: 700;
        color: #0d9488;
        background: #f0fdfa;
        border: 1px solid #ccfbf1;
        border-radius: 6px;
        padding: 2px 8px;
        white-space: nowrap;
    }

    .status-dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        flex-shrink: 0;
    }
    .dot-ok { background: #10b981; box-shadow: 0 0 6px rgba(16,185,129,0.3); }
    .dot-warn { background: #eab308; box-shadow: 0 0 6px rgba(234,179,8,0.3); }
    .dot-danger { background: #ef4444; box-shadow: 0 0 6px rgba(239,68,68,0.3); }

    .quick-action-btn {
        padding: 0.35rem 0.75rem;
        border-radius: 6px;
        font-size: 0.75rem;
        border: 1px solid #e5e7eb;
        cursor: pointer;
        font-weight: 500;
        transition: all 0.2s;
        background-color: #ffffff;
        color: #374151;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
    }
    .quick-action-btn:hover {
        background-color: #f3f4f6;
        color: #111827;
    }

    .contaminacion-modal {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        z-index: 2000;
        align-items: center;
        justify-content: center;
    }
    .contaminacion-modal.show { display: flex; }
    .cont-modal-box {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        padding: 1.5rem;
        width: 100%;
        max-width: 460px;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
        animation: slideUp 0.3s ease;
    }
    @@keyframes slideUp {
        from { transform: translateY(30px); opacity: 0; }
        to { transform: translateY(0); opacity: 1; }
    }
    .btn-custom-primary {
        background-color: #10b981;
        color: white;
        border-radius: 0.5rem;
        padding: 0.5rem 1rem;
        font-weight: 500;
        font-size: 0.875rem;
        transition: all 0.2s;
        border: none;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }
    .btn-custom-primary:hover {
        background-color: #059669;
        color: white;
    }
    .btn-custom-secondary {
        background-color: #f3f4f6;
        color: #374151;
        border-radius: 0.5rem;
        padding: 0.5rem 1rem;
        font-weight: 500;
        font-size: 0.875rem;
        transition: all 0.2s;
        border: 1px solid #e5e7eb;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }
    .btn-custom-secondary:hover {
        background-color: #e5e7eb;
        color: #111827;
    }
</style>

<div class="container-fluid py-4 figma-container">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h1 class="h3 mb-1" style="font-weight: 700; color: #111827;">Control de Contaminación</h1>
            <p class="text-muted mb-0" style="font-size: 14px;">Monitoreo diario de frascos. Registra cualquier contaminación o fenolización observada.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Cultivos" asp-action="Index" class="btn-custom-secondary">
                <i class="bi bi-arrow-left"></i> Volver a Cultivos
            </a>
            @if (User.IsInRole("Tecnico") || User.IsInRole("Coordinador"))
            {
                <button class="btn-custom-secondary border-danger text-danger" onclick="openContModal()">
                    <i class="bi bi-exclamation-circle"></i> Registrar Evento
                </button>
                <a asp-action="Create" class="btn-custom-primary">
                    <i class="bi bi-plus-circle"></i> Nuevo Monitoreo
                </a>
            }
        </div>
    </div>

    <!-- Filtros -->
    <div class="monitor-filters mb-4">
        <button class="filter-btn active" onclick="filterRows(this, 'all')">Todos</button>
        <button class="filter-btn" onclick="filterRows(this, 'ok')"><i class="bi bi-check-circle me-1"></i>Sanos</button>
        <button class="filter-btn" onclick="filterRows(this, 'danger')"><i class="bi bi-x-circle me-1"></i>Contaminados</button>
        <button class="filter-btn" onclick="filterRows(this, 'warn')"><i class="bi bi-exclamation-circle me-1"></i>Fenolización</button>
    </div>

    <!-- Lista de monitoreo por lote -->
    <div class="figma-card mb-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h6 class="text-dark fw-bold mb-0">Registros de Monitoreo</h6>
            <span class="text-muted small">Últimos eventos registrados en la base de datos</span>
        </div>

        <div id="monitoreoList">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <div class="lote-monitor-row @(item.NivelContaminacion != "Nula" ? "danger-row" : (item.NivelFenolizacion != "Nula" ? "warn-row" : ""))" data-status="@(item.NivelContaminacion != "Nula" ? "danger" : (item.NivelFenolizacion != "Nula" ? "warn" : "ok"))">
                        <div class="status-dot @(item.NivelContaminacion != "Nula" ? "dot-danger" : (item.NivelFenolizacion != "Nula" ? "dot-warn" : "dot-ok"))"></div>
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-2 mb-1">
                                <span class="lote-code-badge">Lote ID: @item.IdUnidadFrasco</span>
                                @if(item.NivelContaminacion != "Nula") {
                                    <span class="badge bg-danger bg-opacity-10 text-danger" style="font-size:0.65rem;">@item.NivelContaminacion</span>
                                } else if(item.NivelFenolizacion != "Nula") {
                                    <span class="badge bg-warning bg-opacity-10 text-warning" style="font-size:0.65rem; color:#854d0e !important;">Fenolización @item.NivelFenolizacion</span>
                                } else {
                                    <span class="badge bg-success bg-opacity-10 text-success" style="font-size:0.65rem;">Sano</span>
                                }
                            </div>
                            <div class="text-muted small">Observaciones: @item.Observaciones</div>
                        </div>
                        <div>
                            @if (User.IsInRole("Tecnico") || User.IsInRole("Coordinador"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="quick-action-btn">
                                    <i class="bi bi-pencil"></i> Editar
                                </a>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="text-center py-5 text-muted small">
                    <i class="bi bi-shield-check fs-1 d-block mb-3 text-success"></i>
                    <h5 class="fw-bold text-dark mb-1">Todo bajo control</h5>
                    <p class="mb-0">No hay monitoreos ni contaminaciones registradas en la base de datos.</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal de registro rápido de contaminación -->
<div class="contaminacion-modal" id="contModal">
    <div class="cont-modal-box">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="text-danger fw-bold mb-0"><i class="bi bi-virus me-2"></i>Registrar Evento</h5>
            <button onclick="closeContModal()" style="background:none;border:none;color:rgba(0,0,0,0.5);font-size:1.2rem;cursor:pointer;"><i class="bi bi-x-lg"></i></button>
        </div>
        <hr class="mb-3" style="border-color: #e5e7eb;">

        <form asp-action="Create" method="post">
            <div class="mb-3">
                <label class="form-label text-muted small fw-bold text-uppercase mb-1">Código del Lote</label>
                <input type="text" name="CodigoLote" id="modalLoteCode" class="form-control" placeholder="C-NUB-PM1-F20-R7-MS1" readonly style="font-family: 'Courier New'; color: #0d9488; background-color: #f9fafb;" />
                <input type="hidden" name="IdUnidadFrasco" value="1" />
            </div>
            <div class="row g-2 mb-3">
                <div class="col-6">
                    <label class="form-label text-muted small fw-bold text-uppercase mb-1">Tipo Contaminación</label>
                    <select name="NivelContaminacion" class="form-select" id="tipoContaminacion">
                        <option value="Nula">Sin contaminación</option>
                        <option value="Bacteria">Bacteria (24-48h)</option>
                        <option value="Hongo">Hongo (7 días)</option>
                        <option value="Mixta">Bacteria + Hongo</option>
                    </select>
                </div>
                <div class="col-6">
                    <label class="form-label text-muted small fw-bold text-uppercase mb-1">Fenolización</label>
                    <select name="NivelFenolizacion" class="form-select">
                        <option value="Nula">Sin fenolización</option>
                        <option value="Leve">Leve (medio amarillento)</option>
                        <option value="Moderada">Moderada (medio marrón)</option>
                        <option value="Severa">Severa (tejido muerto)</option>
                    </select>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label text-muted small fw-bold text-uppercase mb-1">Observaciones</label>
                <textarea name="Observaciones" class="form-control" rows="2" placeholder="Describir lo observado..."></textarea>
            </div>
            <input type="hidden" name="FechaEvaluacion" value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm:ss")" />
            <input type="hidden" name="IdUsuario" value="1" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger flex-grow-1 shadow-sm font-semibold">
                    <i class="bi bi-save me-1"></i> Guardar Evento
                </button>
                <button type="button" onclick="closeContModal()" class="btn btn-secondary shadow-sm">Cancelar</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
    function filterRows(btn, status) {
        document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        document.querySelectorAll('.lote-monitor-row').forEach(row => {
            if (status === 'all' || row.dataset.status === status) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }

    function openContModal(code, tipo) {
        const codeEl = document.getElementById('modalLoteCode');
        if (code) codeEl.value = code;
        if (tipo === 'fenol') {
            document.getElementById('tipoContaminacion').value = 'Nula';
        }
        document.getElementById('contModal').classList.add('show');
    }

    function closeContModal() {
        document.getElementById('contModal').classList.remove('show');
    }

    document.getElementById('contModal').addEventListener('click', function(e) {
        if (e.target === this) closeContModal();
    });
</script>
}
