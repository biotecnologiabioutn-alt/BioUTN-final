@model BioUTN.Modelos.MonitoreoFitosanitario

@{
    ViewData["Title"] = "Editar MonitoreoFitosanitario";
}

@section Styles {
<style>
    .figma-container { font-family: 'Inter', -apple-system, sans-serif; background-color: #f9fafb; padding: 20px; border-radius: 12px; }
    .figma-card { background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 0.75rem; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); padding: 1.5rem; }
    .figma-label { font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 0.5rem; display: block; }
    .figma-input { width: 100%; padding: 0.625rem 0.75rem; border-radius: 0.5rem; border: 1px solid #e5e7eb; font-size: 14px; color: #111827; outline: none; transition: all 0.2s; background-color: #ffffff; }
    .figma-input:focus { border-color: rgba(16, 185, 129, 0.6); box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.2); }
    .figma-btn-primary { background-color: #10b981; color: white; border: none; padding: 0.625rem 1.25rem; border-radius: 0.5rem; font-size: 14px; font-weight: 500; transition: all 0.2s; }
    .figma-btn-primary:hover { background-color: #059669; color: white; }
    .figma-btn-secondary { background-color: white; color: #374151; border: 1px solid #e5e7eb; padding: 0.625rem 1.25rem; border-radius: 0.5rem; font-size: 14px; font-weight: 500; transition: all 0.2s; text-decoration: none; display: inline-flex; align-items: center; }
    .figma-btn-secondary:hover { background-color: #f9fafb; color: #111827; }
</style>
}

<div class="figma-container">
    <div class="mb-4">
        <h3 style="font-weight: 700; color: #111827; font-size: 18px;">Editar Monitoreo Fitosanitario</h3>
        <p class="text-muted" style="font-size: 13px;">Actualizar evaluación de unidad de frasco</p>
    </div>

    <div class="row">
        <div class="col-md-8 col-lg-6">
            <div class="figma-card">
                <form asp-action="Edit" class="space-y-4">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 13px;"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="IdUnidadFrasco" class="figma-label">Unidad de Frasco (Código) *</label>
                        <select asp-for="IdUnidadFrasco" class="figma-input form-select" asp-items="ViewBag.UnidadesFrasco" required>
                            <option value="">-- Seleccionar Frasco --</option>
                        </select>
                        <span asp-validation-for="IdUnidadFrasco" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FechaEvaluacion" class="figma-label">Fecha de Evaluación *</label>
                        <input asp-for="FechaEvaluacion" type="date" class="figma-input" required />
                        <span asp-validation-for="FechaEvaluacion" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label asp-for="NivelFenolizacion" class="figma-label">Nivel de Fenolización *</label>
                            <select asp-for="NivelFenolizacion" class="figma-input" required>
                                <option value="Nulo">Nulo</option>
                                <option value="Bajo">Bajo</option>
                                <option value="Medio">Medio</option>
                                <option value="Alto">Alto</option>
                            </select>
                            <span asp-validation-for="NivelFenolizacion" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-6 mb-3">
                            <label asp-for="NivelContaminacion" class="figma-label">Nivel de Contaminación *</label>
                            <select asp-for="NivelContaminacion" class="figma-input" required>
                                <option value="Nulo">Nulo</option>
                                <option value="Bacteriana">Bacteriana</option>
                                <option value="Fúngica">Fúngica</option>
                            </select>
                            <span asp-validation-for="NivelContaminacion" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="figma-label">Presencia de Patógenos</label>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" asp-for="Bacterias">
                                <label class="form-check-label" asp-for="Bacterias">Bacterias</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" asp-for="Hongos">
                                <label class="form-check-label" asp-for="Hongos">Hongos</label>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="figma-label">Estado de la Planta</label>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" asp-for="Muerte">
                                <label class="form-check-label" asp-for="Muerte">Muerte del tejido</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" asp-for="RequiereResiembra">
                                <label class="form-check-label" asp-for="RequiereResiembra">Requiere Resiembra Urgente</label>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Respuesta" class="figma-label">Respuesta de la Planta *</label>
                        <input asp-for="Respuesta" class="figma-input" placeholder="Ej. Brotación de yemas, enraizamiento..." required />
                        <span asp-validation-for="Respuesta" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="IdUsuario" class="figma-label">Usuario Evaluador *</label>
                        <select asp-for="IdUsuario" class="figma-input form-select" asp-items="ViewBag.Usuarios" required>
                            <option value="">-- Seleccionar Evaluador --</option>
                        </select>
                        <span asp-validation-for="IdUsuario" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Observaciones" class="figma-label">Observaciones</label>
                        <textarea asp-for="Observaciones" class="figma-input" rows="3" placeholder="Detalles de la evaluación..."></textarea>
                        <span asp-validation-for="Observaciones" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4 pt-3" style="border-top: 1px solid #e5e7eb;">
                        <a asp-action="Index" class="figma-btn-secondary">Cancelar</a>
                        <button type="submit" class="figma-btn-primary">Actualizar Evaluación</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
