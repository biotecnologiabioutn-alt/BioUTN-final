@model BioUTN.Modelos.Equipo

@{
    ViewData["Title"] = "Editar Equipo";
}

@section Styles {
<style>
    .figma-container { font-family: 'Inter', -apple-system, sans-serif; background-color: #f9fafb; padding: 20px; border-radius: 12px; }
    .figma-card { background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 0.75rem; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); padding: 1.5rem; }
    .figma-label { font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 0.5rem; display: block; }
    .figma-input { width: 100%; padding: 0.625rem 0.75rem; border-radius: 0.5rem; border: 1px solid #e5e7eb; font-size: 14px; color: #111827; outline: none; transition: all 0.2s; background-color: #ffffff; }
    .figma-input:focus { border-color: rgba(59, 130, 246, 0.6); box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2); }
    .figma-btn-primary { background-color: #3b82f6; color: white; border: none; padding: 0.625rem 1.25rem; border-radius: 0.5rem; font-size: 14px; font-weight: 500; transition: all 0.2s; }
    .figma-btn-primary:hover { background-color: #2563eb; color: white; }
    .figma-btn-secondary { background-color: white; color: #374151; border: 1px solid #e5e7eb; padding: 0.625rem 1.25rem; border-radius: 0.5rem; font-size: 14px; font-weight: 500; transition: all 0.2s; text-decoration: none; display: inline-flex; align-items: center; }
    .figma-btn-secondary:hover { background-color: #f9fafb; color: #111827; }
</style>
}

<div class="figma-container">
    <div class="mb-4">
        <h3 style="font-weight: 700; color: #111827; font-size: 18px;">Editar Equipo</h3>
        <p class="text-muted" style="font-size: 13px;">Actualiza la información técnica y estado del equipo.</p>
    </div>

    <div class="row">
        <div class="col-md-10 col-lg-8">
            <div class="figma-card">
                <form asp-action="Edit" class="space-y-4">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 13px;"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="CodigoInventario" class="figma-label">Código de Inventario *</label>
                            <input asp-for="CodigoInventario" class="figma-input" placeholder="Ej: HU-001" required />
                            <span asp-validation-for="CodigoInventario" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-8 mb-3">
                            <label asp-for="Nombre" class="figma-label">Nombre del Equipo *</label>
                            <input asp-for="Nombre" class="figma-input" placeholder="Ej: Cabina de Flujo Laminar" required />
                            <span asp-validation-for="Nombre" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Marca" class="figma-label">Marca *</label>
                            <input asp-for="Marca" class="figma-input" placeholder="Ej: Thermo Fisher" required />
                            <span asp-validation-for="Marca" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Modelo" class="figma-label">Modelo *</label>
                            <input asp-for="Modelo" class="figma-input" placeholder="Ej: 1300 Series A2" required />
                            <span asp-validation-for="Modelo" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Estado" class="figma-label">Estado Actual *</label>
                            <select asp-for="Estado" class="figma-input form-select" required>
                                <option value="Disponible">Disponible</option>
                                <option value="En Mantenimiento">En Mantenimiento</option>
                                <option value="Desactivado">Desactivado</option>
                            </select>
                            <span asp-validation-for="Estado" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="FechaProximoMantenimiento" class="figma-label">Fecha de Próx. Mantenimiento</label>
                            <input asp-for="FechaProximoMantenimiento" type="date" class="figma-input" />
                            <span asp-validation-for="FechaProximoMantenimiento" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4 pt-3" style="border-top: 1px solid #e5e7eb;">
                        <a asp-action="Index" class="figma-btn-secondary">Volver</a>
                        <button type="button" id="btnGuardar" class="figma-btn-primary">Guardar Cambios</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    document.getElementById('btnGuardar').addEventListener('click', function (e) {
        e.preventDefault();
        
        var form = this.closest('form');
        if (!form.checkValidity()) {
            form.reportValidity();
            return;
        }

        Swal.fire({
            title: '¿Actualizar Equipo?',
            text: "Se guardarán los cambios realizados al catálogo.",
            icon: 'info',
            showCancelButton: true,
            confirmButtonColor: '#3b82f6',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Sí, Actualizar',
            cancelButtonText: 'Revisar'
        }).then((result) => {
            if (result.isConfirmed) {
                form.submit();
            }
        })
    });
</script>
}
