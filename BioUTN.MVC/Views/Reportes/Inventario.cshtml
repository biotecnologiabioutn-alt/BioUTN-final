@{
    ViewData["Title"] = "Reportes de Inventario";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="bioutn-title mb-0"><i class="bi bi-box-seam text-info me-2"></i> Reportes de Inventario</h2>
        <p class="bioutn-subtitle mt-1">Consumos, reactivos críticos y vida útil de equipos.</p>
    </div>
    <a asp-controller="Inventarios" asp-action="Index" class="btn bioutn-btn bioutn-btn-secondary shadow-sm">
        <i class="bi bi-arrow-left me-1"></i> Volver a Gestión
    </a>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="bioutn-card p-4 text-center">
            <i class="bi bi-exclamation-triangle text-warning" style="font-size: 3rem;"></i>
            <h4 class="mt-3 text-dark">Stock Crítico</h4>
            <p class="text-muted">Próximamente: Alertas de reactivos por caducar o agotarse.</p>
        </div>
    </div>
    <div class="col-md-6">
        <div class="bioutn-card p-4 text-center">
            <i class="bi bi-tools text-info" style="font-size: 3rem;"></i>
            <h4 class="mt-3 text-dark">Mantenimiento de Equipos</h4>
            <p class="text-muted">Próximamente: Historial de uso y mantenimiento.</p>
        </div>
    </div>
</div>
