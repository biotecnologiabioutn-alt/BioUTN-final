@model IEnumerable<BioUTN.Modelos.UbicacionFisica>

@{
    ViewData["Title"] = "Mapa del Cuarto de Colecciones";
}

@section Styles {
<style>
    body { background-color: #f9fafb; font-family: 'Inter', -apple-system, sans-serif; }
    .figma-container { padding: 40px 20px; max-width: 1200px; margin: 0 auto; }
    .figma-header { margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: flex-end; }
    .figma-title { font-size: 24px; font-weight: 700; color: #111827; margin-bottom: 0.25rem; }
    .figma-subtitle { font-size: 14px; color: #6b7280; }
    
    .figma-btn-secondary { background-color: white; color: #374151; border: 1px solid #e5e7eb; padding: 0.5rem 1rem; border-radius: 8px; font-size: 14px; font-weight: 500; transition: all 0.2s; display: inline-flex; align-items: center; gap: 0.5rem; text-decoration: none; }
    .figma-btn-secondary:hover { background-color: #f9fafb; color: #111827; }

    .anaquel-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
    }

    .anaquel-card {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        transition: transform 0.2s;
    }
    
    .anaquel-card:hover {
        transform: translateY(-2px);
    }

    .anaquel-header {
        background: #f8fafc;
        border-bottom: 2px solid #e2e8f0;
        padding: 1rem;
        text-align: center;
    }

    .anaquel-title {
        font-size: 1.25rem;
        font-weight: 800;
        color: #1e293b;
        letter-spacing: 1px;
    }

    .anaquel-body {
        padding: 1rem;
        display: flex;
        flex-direction: column-reverse; /* To make Piso 4 at the top, Piso 1 at the bottom like a real shelf */
        gap: 0.5rem;
    }

    .piso-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.75rem;
        border-radius: 6px;
        border: 1px solid #e2e8f0;
        background: #f1f5f9;
        font-size: 0.875rem;
        font-weight: 600;
        color: #475569;
    }

    .piso-status-disponible {
        background-color: #dcfce7;
        color: #166534;
        padding: 2px 8px;
        border-radius: 12px;
        font-size: 0.75rem;
    }

    .piso-status-lleno {
        background-color: #fee2e2;
        color: #991b1b;
        padding: 2px 8px;
        border-radius: 12px;
        font-size: 0.75rem;
    }
    
    .piso-status-mantenimiento {
        background-color: #fef9c3;
        color: #854d0e;
        padding: 2px 8px;
        border-radius: 12px;
        font-size: 0.75rem;
    }
</style>
}

<div class="figma-container">
    <div class="figma-header">
        <div>
            <h1 class="figma-title"><i class="bi bi-grid-3x3-gap-fill text-primary me-2"></i> Mapa Físico del Laboratorio</h1>
            <p class="figma-subtitle">Vista general de los anaqueles y su estado de ocupación</p>
        </div>
        <div>
            <a asp-controller="ZonaTrabajo" asp-action="Index" class="figma-btn-secondary">
                <i class="bi bi-arrow-left"></i> Volver a Zona de Trabajo
            </a>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="anaquel-grid">
            @{
                // Agrupamos por Código del Anaquel y Nombre de Cuerpo (Ej: A1 - Lado Izquierdo)
                var anaquelesGrouped = Model
                    .GroupBy(m => new { m.CodigoAnaquel, m.NombreCuerpo })
                    .OrderBy(g => g.Key.CodigoAnaquel).ThenBy(g => g.Key.NombreCuerpo);
                
                foreach(var grupo in anaquelesGrouped)
                {
                    <div class="anaquel-card">
                        <div class="anaquel-header">
                            <div class="anaquel-title">ANAQUEL @grupo.Key.CodigoAnaquel</div>
                            <div style="font-size: 12px; color: #64748b; margin-top: 4px;">@grupo.Key.NombreCuerpo</div>
                        </div>
                        <div class="anaquel-body">
                            @{
                                // Ordenamos por piso para que al usar flex-direction-reverse, el 4 quede arriba y 1 abajo.
                                var pisos = grupo.OrderBy(p => p.NumeroPiso);
                                foreach(var piso in pisos)
                                {
                                    <div class="piso-row" title="Estado: @piso.EstadoUbicacion">
                                        <span><i class="bi bi-hdd-rack text-secondary me-2"></i> Piso @piso.NumeroPiso</span>
                                        @if(piso.EstadoUbicacion == "Disponible")
                                        {
                                            <span class="piso-status-disponible">Disponible</span>
                                        }
                                        else if (piso.EstadoUbicacion == "Lleno")
                                        {
                                            <span class="piso-status-lleno">Lleno</span>
                                        }
                                        else
                                        {
                                            <span class="piso-status-mantenimiento">Mantenimiento</span>
                                        }
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 bg-white border rounded-3 shadow-sm">
            <i class="bi bi-inboxes text-muted fs-1 mb-3 d-block"></i>
            <h5 class="fw-bold">No hay anaqueles registrados</h5>
            <p class="text-muted">El mapa físico aún no ha sido configurado.</p>
            @if(User.IsInRole("Coordinador") || User.IsInRole("Tecnico"))
            {
                <a asp-controller="UbicacionFisicas" asp-action="Index" class="btn btn-outline-primary mt-2">Configurar Anaqueles</a>
            }
        </div>
    }
</div>
