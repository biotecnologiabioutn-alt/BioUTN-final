@{
    ViewData["Title"] = "Checklist Pre-Siembra";
}

@section Styles {
<style>
    .checklist-hero {
        background: linear-gradient(135deg, rgba(220,53,69,0.08), rgba(255,193,7,0.05));
        border: 1px solid rgba(220,53,69,0.2);
        border-radius: 20px;
        padding: 1.5rem 2rem;
        margin-bottom: 1.5rem;
    }

    .phase-card {
        background: #F8FAFC;
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 1.5rem;
        margin-bottom: 1rem;
        transition: all 0.3s;
    }
    .phase-card.completed {
        border-color: rgba(32,201,151,0.4);
        background: rgba(32,201,151,0.05);
    }
    .phase-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
    }
    .phase-icon {
        width: 48px; height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        flex-shrink: 0;
    }
    .phase-num {
        font-size: 0.65rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #64748B;
        margin-bottom: 0.1rem;
    }
    .phase-title {
        font-size: 1.05rem;
        font-weight: 700;
        
        margin: 0;
    }
    .phase-progress {
        font-size: 0.75rem;
        color: #64748B;
    }

    .check-item {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        padding: 0.6rem 0;
        border-bottom: 1px solid var(--border-color);
        cursor: pointer;
        transition: all 0.2s;
        border-radius: 8px;
        padding-left: 0.5rem;
    }
    .check-item:last-child { border-bottom: none; }
    .check-item:hover { background: #E2E8F0; }
    .check-item.done .check-text { text-decoration: line-through; color: #94A3B8 !important; }

    .custom-cb {
        appearance: none;
        width: 20px; height: 20px;
        border: 2px solid #CBD5E1;
        border-radius: 6px;
        background: transparent;
        cursor: pointer;
        flex-shrink: 0;
        margin-top: 1px;
        transition: all 0.2s;
        position: relative;
    }
    .custom-cb:checked {
        background: #20c997;
        border-color: #20c997;
    }
    .custom-cb:checked::after {
        content: '✓';
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        
        font-size: 0.75rem;
        font-weight: 900;
    }

    .check-text {
        font-size: 0.88rem;
        color: var(--text-main);
        line-height: 1.4;
    }
    .check-note {
        font-size: 0.72rem;
        color: #64748B;
        margin-top: 2px;
    }

    .global-progress {
        height: 8px;
        border-radius: 10px;
        background: #E2E8F0;
        overflow: hidden;
        margin-top: 0.5rem;
    }
    .global-progress-bar {
        height: 100%;
        background: linear-gradient(90deg, #20c997, #0dcaf0);
        border-radius: 10px;
        transition: width 0.5s ease;
    }

    .btn-start-seeding {
        background: linear-gradient(135deg, #20c997, #0dcaf0);
        border: none;
        border-radius: 12px;
        color: #0a1628;
        font-weight: 800;
        font-size: 1.05rem;
        padding: 0.85rem 2rem;
        width: 100%;
        transition: all 0.3s;
        opacity: 0.4;
        pointer-events: none;
    }
    .btn-start-seeding.ready {
        opacity: 1;
        pointer-events: all;
        box-shadow: 0 8px 25px rgba(32,201,151,0.3);
    }
    .btn-start-seeding.ready:hover {
        transform: translateY(-2px);
        box-shadow: 0 12px 30px rgba(32,201,151,0.4);
    }

    .warning-banner {
        background: rgba(255,193,7,0.08);
        border: 1px solid rgba(255,193,7,0.25);
        border-radius: 10px;
        padding: 0.75rem 1rem;
        font-size: 0.8rem;
        color: #ffc107;
        display: flex;
        gap: 0.5rem;
        align-items: flex-start;
        margin-top: 1rem;
    }
</style>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="bioutn-title mb-0"><i class="bi bi-clipboard2-check text-danger me-2"></i>Checklist Pre-Siembra</h2>
        <p class="bioutn-subtitle mt-1">Completa todos los pasos antes de iniciar la siembra. Obligatorio.</p>
    </div>
    <a asp-controller="ZonaTrabajo" asp-action="Index" class="btn bioutn-btn bioutn-btn-secondary shadow-sm">
        <i class="bi bi-arrow-left me-1"></i> Volver
    </a>
</div>

<!-- Hero con progreso global -->
<div class="checklist-hero">
    <div class="row align-items-center">
        <div class="col-md-8">
            <h5 class="text-dark mb-1 fw-bold">Progreso General</h5>
            <p class="text-muted small mb-2">Completa los <strong id="totalItems">0</strong> pasos para habilitar la siembra</p>
            <div class="global-progress">
                <div class="global-progress-bar" id="globalBar" style="width: 0%;"></div>
            </div>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
            <span class="display-6 fw-black text-dark" id="pctText">0%</span>
            <div class="text-muted small"><span id="doneCount">0</span> / <span id="totalCount">0</span> pasos</div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">

        <!-- FASE 1: Preparación de Material -->
        <div class="phase-card" id="phase1">
            <div class="phase-header">
                <div class="phase-icon" style="background: rgba(13,202,240,0.1); color: #0dcaf0;">
                    <i class="bi bi-bucket"></i>
                </div>
                <div class="flex-grow-1">
                    <div class="phase-num">Fase 1 de 4</div>
                    <div class="phase-title">Limpieza y Preparación de Material</div>
                    <div class="phase-progress" id="prog1">0 / 4 completados</div>
                </div>
                <i class="bi bi-check-circle-fill text-success fs-4 d-none" id="done1"></i>
            </div>

            <div class="check-item" onclick="toggle(this)">
                <input type="checkbox" class="custom-cb" onchange="updateProgress()">
                <div>
                    <div class="check-text">Lavado de pinzas, bisturíes y frascos con detergente neutro</div>
                    <div class="check-note">Usar agua destilada para el enjuague final</div>
                </div>
            </div>
            <div class="check-item" onclick="toggle(this)">
                <input type="checkbox" class="custom-cb" onchange="updateProgress()">
                <div>
                    <div class="check-text">Secado completo del material en el horno a 60°C por 30 min</div>
                    <div class="check-note">No pasar a autoclave material húmedo</div>
                </div>
            </div>
            <div class="check-item" onclick="toggle(this)">
                <input type="checkbox" class="custom-cb" onchange="updateProgress()">
                <div>
                    <div class="check-text">Empaquetado hermético del material en papel kraft o bolsa autoclavable</div>
                    <div class="check-note">Verificar que los paquetes estén bien sellados</div>
                </div>
            </div>
            <div class="check-item" onclick="toggle(this)">
                <input type="checkbox" class="custom-cb" onchange="updateProgress()">
                <div>
                    <div class="check-text">Etiquetado del material con nombre del operador y fecha</div>
                    <div class="check-note">Formato: [Iniciales]-[Fecha]</div>
                </div>
            </div>
        </div>

        <!-- FASE 2: Esterilización -->
        <div class="phase-card" id="phase2">
            <div class="phase-header">
                <div class="phase-icon" style="background: rgba(255,193,7,0.1); color: #ffc107;">
                    <i class="bi bi-thermometer-high"></i>
                </div>
                <div class="flex-grow-1">
                    <div class="phase-num">Fase 2 de 4</div>
                    <div class="phase-title">Esterilización (Autoclave)</div>
                    <div class="phase-progress" id="prog2">0 / 4 completados</div>
                </div>
                <i class="bi bi-check-circle-fill text-success fs-4 d-none" id="done2"></i>
            </div>

            <div class="check-item" onclick="toggle(this)">
                <input type="checkbox" class="custom-cb" onchange="updateProgress()">
                <div>
                    <div class="check-text">Reserva de turno en Autoclave confirmada en el sistema</div>
                    <div class="check-note">Verificar que la reserva esté aprobada por el Técnico</div>
                </div>
            </div>
            <div class="check-item" onclick="toggle(this)">
                <input type="checkbox" class="custom-cb" onchange="updateProgress()">
                <div>
                    <div class="check-text">Autoclave a 121°C durante 15 minutos a 1 atm completado</div>
                    <div class="check-note">Verificar el indicador de cinta autoclavable (cambio de color)</div>
                </div>
            </div>
            <div class="check-item" onclick="toggle(this)">
                <input type="checkbox" class="custom-cb" onchange="updateProgress()">
                <div>
                    <div class="check-text">Material retirado de la autoclave y en enfriamiento</div>
                    <div class="check-note">Esperar al menos 30 min antes de usar</div>
                </div>
            </div>
            <div class="check-item" onclick="toggle(this)">
                <input type="checkbox" class="custom-cb" onchange="updateProgress()">
                <div>
                    <div class="check-text">Autoclave limpia y llave de vapor cerrada correctamente</div>
                    <div class="check-note">Dejar la puerta entreabierta para ventilación</div>
                </div>
            </div>
        </div>

        <!-- FASE 3: Preparación del Medio de Cultivo -->
        <div class="phase-card" id="phase3">
            <div class="phase-header">
                <div class="phase-icon" style="background: rgba(32,201,151,0.1); color: #20c997;">
                    <i class="bi bi-eyedropper"></i>
                </div>
                <div class="flex-grow-1">
                    <div class="phase-num">Fase 3 de 4</div>
                    <div class="phase-title">Preparación del Medio de Cultivo</div>
                    <div class="phase-progress" id="prog3">0 / 4 completados</div>
                </div>
                <i class="bi bi-check-circle-fill text-success fs-4 d-none" id="done3"></i>
            </div>

            <div class="check-item" onclick="toggle(this)">
                <input type="checkbox" class="custom-cb" onchange="updateProgress()">
                <div>
                    <div class="check-text">Protocolo del medio de cultivo revisado</div>
                    <div class="check-note">Confirmar concentraciones de sales, vitaminas y hormonas</div>
                </div>
            </div>
            <div class="check-item" onclick="toggle(this)">
                <input type="checkbox" class="custom-cb" onchange="updateProgress()">
                <div>
                    <div class="check-text">Reactivos pesados con balanza analítica y anotados en el registro</div>
                    <div class="check-note">Registrar peso exacto en el cuaderno de laboratorio</div>
                </div>
            </div>
            <div class="check-item" onclick="toggle(this)">
                <input type="checkbox" class="custom-cb" onchange="updateProgress()">
                <div>
                    <div class="check-text">pH ajustado a 5.7 - 5.8 antes de autoclavar</div>
                    <div class="check-note">Usar KOH para subir o HCl para bajar el pH</div>
                </div>
            </div>
            <div class="check-item" onclick="toggle(this)">
                <input type="checkbox" class="custom-cb" onchange="updateProgress()">
                <div>
                    <div class="check-text">Medio distribuido en frascos y esterilizado</div>
                    <div class="check-note">Cantidad exacta según el número de frascos del lote</div>
                </div>
            </div>
        </div>

        <!-- FASE 4: Cabina de Flujo Laminar -->
        <div class="phase-card" id="phase4">
            <div class="phase-header">
                <div class="phase-icon" style="background: rgba(220,53,69,0.1); color: #dc3545;">
                    <i class="bi bi-wind"></i>
                </div>
                <div class="flex-grow-1">
                    <div class="phase-num">Fase 4 de 4</div>
                    <div class="phase-title">Preparación Cabina de Flujo Laminar</div>
                    <div class="phase-progress" id="prog4">0 / 4 completados</div>
                </div>
                <i class="bi bi-check-circle-fill text-success fs-4 d-none" id="done4"></i>
            </div>

            <div class="check-item" onclick="toggle(this)">
                <input type="checkbox" class="custom-cb" onchange="updateProgress()">
                <div>
                    <div class="check-text">Reserva de Cabina de Flujo Laminar confirmada en el sistema</div>
                    <div class="check-note">Sin reserva aprobada por el Técnico, no se enciende</div>
                </div>
            </div>
            <div class="check-item" onclick="toggle(this)">
                <input type="checkbox" class="custom-cb" onchange="updateProgress()">
                <div>
                    <div class="check-text">Cabina desinfectada con alcohol al 70% — superficies y paredes</div>
                    <div class="check-note">Encender UV por 15 min antes de trabajar</div>
                </div>
            </div>
            <div class="check-item" onclick="toggle(this)">
                <input type="checkbox" class="custom-cb" onchange="updateProgress()">
                <div>
                    <div class="check-text">Manos lavadas con jabón antibacterial + guantes + mascarilla puestos</div>
                    <div class="check-note">Desinfectar manos con etanol al 70% dentro de la cabina</div>
                </div>
            </div>
            <div class="check-item" onclick="toggle(this)">
                <input type="checkbox" class="custom-cb" onchange="updateProgress()">
                <div>
                    <div class="check-text">Lote registrado en el sistema con código asignado antes de empezar</div>
                    <div class="check-note">El código de trazabilidad debe estar generado y visible</div>
                </div>
            </div>
        </div>

    </div>

    <!-- Panel lateral de resumen -->
    <div class="col-lg-4">
        <div class="bioutn-card p-4 sticky-top" style="top: 80px;">
            <h6 class="text-muted text-uppercase fw-bold small mb-3">Resumen</h6>

            <div class="mb-3">
                <div class="d-flex justify-content-between small text-muted mb-1">
                    <span><i class="bi bi-bucket me-1 text-info"></i> Limpieza</span>
                    <span id="s1">0/4</span>
                </div>
                <div class="d-flex justify-content-between small text-muted mb-1">
                    <span><i class="bi bi-thermometer-high me-1 text-warning"></i> Autoclave</span>
                    <span id="s2">0/4</span>
                </div>
                <div class="d-flex justify-content-between small text-muted mb-1">
                    <span><i class="bi bi-eyedropper me-1 text-success"></i> Medio de Cultivo</span>
                    <span id="s3">0/4</span>
                </div>
                <div class="d-flex justify-content-between small text-muted">
                    <span><i class="bi bi-wind me-1 text-danger"></i> Cabina Flujo Laminar</span>
                    <span id="s4">0/4</span>
                </div>
            </div>

            <hr class="mb-3">

            <div class="text-center mb-3">
                <div class="display-5 fw-black" id="bigPct" style="color: #CBD5E1;">0%</div>
                <p class="small text-muted" id="statusMsg">Completa todos los pasos para iniciar</p>
            </div>

            <button class="btn-start-seeding" id="btnStart" onclick="startSeeding()">
                <i class="bi bi-flower2 me-2"></i> ¡Iniciar Siembra!
            </button>

            <div class="warning-banner">
                <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
                <span>Regla de Laboratorio: <em>"Si no está anotado, el experimento no existe."</em> Registra todo en el sistema.</span>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const TOTAL = 16;
    let doneGlobal = 0;

    function toggle(el) {
        const cb = el.querySelector('.custom-cb');
        if (!cb) return;
        cb.checked = !cb.checked;
        el.classList.toggle('done', cb.checked);
        updateProgress();
    }

    function updateProgress() {
        const phases = [1, 2, 3, 4];
        let totalDone = 0;

        phases.forEach(p => {
            const phase = document.getElementById('phase' + p);
            const cbs = phase.querySelectorAll('.custom-cb');
            const done = Array.from(cbs).filter(c => c.checked).length;
            document.getElementById('prog' + p).textContent = done + ' / ' + cbs.length + ' completados';
            document.getElementById('s' + p).textContent = done + '/' + cbs.length;

            if (done === cbs.length) {
                phase.classList.add('completed');
                document.getElementById('done' + p).classList.remove('d-none');
            } else {
                phase.classList.remove('completed');
                document.getElementById('done' + p).classList.add('d-none');
            }
            totalDone += done;
        });

        const pct = Math.round((totalDone / TOTAL) * 100);
        document.getElementById('globalBar').style.width = pct + '%';
        document.getElementById('pctText').textContent = pct + '%';
        document.getElementById('bigPct').textContent = pct + '%';
        document.getElementById('doneCount').textContent = totalDone;
        document.getElementById('totalCount').textContent = TOTAL;

        const bigPct = document.getElementById('bigPct');
        if (pct === 100) {
            bigPct.style.color = '#20c997';
            document.getElementById('statusMsg').textContent = '¡Todo listo! Puedes iniciar la siembra.';
            document.getElementById('btnStart').classList.add('ready');
        } else if (pct >= 50) {
            bigPct.style.color = '#ffc107';
            document.getElementById('statusMsg').textContent = 'Vas bien, continúa con los pasos.';
        } else {
            bigPct.style.color = '#CBD5E1';
            document.getElementById('statusMsg').textContent = 'Completa todos los pasos para iniciar.';
        }
    }

    function startSeeding() {
        if (confirm('¿Confirmas que completaste TODOS los pasos de preparación y estás listo para iniciar la siembra?')) {
            window.location.href = '@Url.Action("Create", "LoteCultivos")';
        }
    }

    // Contar total al cargar
    document.getElementById('totalItems').textContent = TOTAL;
    document.getElementById('totalCount').textContent = TOTAL;
</script>
}
