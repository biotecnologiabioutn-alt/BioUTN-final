@{
    ViewData["Title"] = "Restablecer Contraseña";
    ViewData["HideSidebar"] = true;
}

<style>
    body { background-color: white !important; }
    .login-container { max-width: 440px; margin: 0 auto; padding: 2rem 1rem; background: transparent; }
    .login-logo { width: 70px; height: 70px; background-color: #F0F6F1; color: #275432; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 2.2rem; margin: 0 auto 1.5rem; }
    .login-title { font-weight: 800; font-size: 1.6rem; color: #0A192F; margin-bottom: 0.2rem; text-align: center; }
    .login-subtitle { color: #6B7A90; font-size: 0.9rem; text-align: center; margin-bottom: 2.5rem; }
    .form-label-custom { font-weight: 700; color: #0A192F; font-size: 0.85rem; margin-bottom: 0.5rem; display: block; }
    .input-wrapper { position: relative; margin-bottom: 1.5rem; }
    .input-wrapper i { position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: #64748B; font-size: 1.1rem; }
    .input-wrapper input { width: 100%; padding: 14px 15px 14px 45px; border: 1px solid #E2E8F0; border-radius: 10px; font-size: 0.95rem; color: #334155; transition: border-color 0.2s; }
    .input-wrapper input:focus { border-color: #275432; outline: none; box-shadow: 0 0 0 3px rgba(39, 84, 50, 0.1); }
    .btn-login { background-color: #1E5128; color: white; border: none; border-radius: 10px; padding: 14px; width: 100%; font-weight: 600; font-size: 1rem; transition: background-color 0.2s; display: flex; justify-content: center; align-items: center; gap: 6px; }
    .btn-login:hover { background-color: #153E1E; color: white; }
    
    .password-rules { font-size: 0.75rem; color: #64748B; margin-top: -1rem; margin-bottom: 1.5rem; padding-left: 10px; }
    .rule-item { margin-bottom: 3px; display: flex; align-items: center; gap: 5px; }
</style>

<div class="row justify-content-center align-items-center" style="min-height: 85vh;">
    <div class="col-md-7 col-lg-5 col-xl-4">
        <div class="login-container">
            <div class="login-logo">
                <i class="bi bi-shield-lock"></i>
            </div>
            <h2 class="login-title">Nueva Contraseña</h2>
            <p class="login-subtitle">Asegure su cuenta con una contraseña fuerte</p>

            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger bg-danger bg-opacity-10 border-danger text-danger py-2 small mb-4">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i> @ViewBag.Error
                </div>
            }

            <form asp-action="ResetPassword" method="post">
                <input type="hidden" name="token" value="@ViewBag.Token" />
                <input type="hidden" name="email" value="@ViewBag.Email" />

                <label class="form-label-custom">Nueva Contraseña</label>
                <div class="input-wrapper">
                    <i class="bi bi-key" style="color: #E59866;"></i>
                    <input type="password" name="newPassword" placeholder="Ingrese su nueva contraseña" required />
                </div>
                
                <div class="password-rules">
                    <div class="rule-item"><i class="bi bi-dot"></i> Mínimo 8 caracteres</div>
                    <div class="rule-item"><i class="bi bi-dot"></i> Al menos 1 mayúscula</div>
                    <div class="rule-item"><i class="bi bi-dot"></i> SIN caracteres especiales (!, $, -, etc.)</div>
                </div>

                <label class="form-label-custom">Confirmar Contraseña</label>
                <div class="input-wrapper">
                    <i class="bi bi-key-fill" style="color: #E59866;"></i>
                    <input type="password" name="confirmPassword" placeholder="Confirme la contraseña" required />
                </div>

                <button type="submit" class="btn-login shadow-sm mb-3 mt-2">
                    Actualizar Contraseña <i class="bi bi-shield-check ms-1" style="font-size: 0.9rem;"></i>
                </button>
            </form>
        </div>
    </div>
</div>
