@model BioUTN.Modelos.Rol

@{
    ViewData["Title"] = "Editar Rol";
}

@section Styles {
<style>
    body { background-color: #f9fafb; font-family: 'Inter', -apple-system, sans-serif; }
    .figma-container { padding: 40px 20px; max-width: 600px; margin: 0 auto; }
    .figma-header { margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center; }
    .figma-title { font-size: 24px; font-weight: 700; color: #111827; margin-bottom: 0.25rem; }
    .figma-subtitle { font-size: 14px; color: #6b7280; }
    
    .figma-btn-secondary { background-color: #f3f4f6; color: #4b5563; border: 1px solid #e5e7eb; padding: 0.5rem 1rem; border-radius: 8px; font-size: 14px; font-weight: 500; transition: all 0.2s; display: inline-flex; align-items: center; gap: 0.5rem; text-decoration: none; }
    .figma-btn-secondary:hover { background-color: #e5e7eb; color: #374151; transform: translateY(-1px); }
    
    .figma-btn-primary { background-color: #7c3aed; color: white; border: none; padding: 0.6rem 1.5rem; border-radius: 8px; font-size: 14px; font-weight: 500; transition: all 0.2s; display: inline-flex; align-items: center; gap: 0.5rem; cursor: pointer; }
    .figma-btn-primary:hover { background-color: #6d28d9; transform: translateY(-1px); box-shadow: 0 4px 6px -1px rgba(124, 58, 237, 0.2); }
    
    .figma-card { background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 2rem; box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1); }
    
    .figma-form-group { margin-bottom: 1.5rem; }
    .figma-label { display: block; font-size: 14px; font-weight: 500; color: #374151; margin-bottom: 0.5rem; }
    .figma-input { width: 100%; padding: 0.6rem 1rem; font-size: 14px; border: 1px solid #d1d5db; border-radius: 8px; transition: all 0.2s; background-color: #f9fafb; color: #111827; }
    .figma-input:focus { outline: none; border-color: #7c3aed; ring: 2px solid #ddd6fe; background-color: #ffffff; box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1); }
</style>
}

<div class="figma-container">
    <div class="figma-header">
        <div>
            <h1 class="figma-title">Editar Rol</h1>
            <p class="figma-subtitle">Actualiza la información del nivel de acceso</p>
        </div>
        <a asp-action="Index" class="figma-btn-secondary">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>

    <div class="figma-card">
        <form asp-action="Edit" id="editForm">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3 text-sm"></div>
            <input type="hidden" asp-for="Id" />

            <div class="figma-form-group">
                <label asp-for="NombreRol" class="figma-label">Nombre del Rol <span class="text-danger">*</span></label>
                <input asp-for="NombreRol" class="figma-input" placeholder="Ej: Auditor" autocomplete="off" />
                <span asp-validation-for="NombreRol" class="text-danger small mt-1 d-block"></span>
            </div>

            <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                <button type="submit" class="figma-btn-primary">
                    <i class="bi bi-save"></i> Guardar Cambios
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.getElementById('editForm').addEventListener('submit', function(e) {
            e.preventDefault();
            var form = this;
            if($(form).valid()) {
                Swal.fire({
                    title: '¿Guardar Cambios?',
                    text: "Se actualizará la información del rol.",
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#7c3aed',
                    cancelButtonColor: '#6b7280',
                    confirmButtonText: 'Sí, guardar',
                    cancelButtonText: 'Cancelar'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                })
            }
        });
    </script>
}
