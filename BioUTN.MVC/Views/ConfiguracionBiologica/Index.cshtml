@{
    ViewData["Title"] = "Configuración Biológica";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4 bioutn-title text-primary-custom">Configuración y Catálogos</h1>
        <p class="lead text-muted">Administración de Diccionarios y Maestros del Sistema</p>
    </div>

    <div class="row g-4 justify-content-center">
        <!-- Taxonomía -->
        <div class="col-md-3 col-sm-6">
            <div class="card h-100 bioutn-card dashboard-card border-success">
                <div class="card-body text-center p-3">
                    <div class="icon-box mb-2 mx-auto text-success" style="font-size: 2rem;">
                        <i class="bi bi-diagram-3"></i>
                    </div>
                    <h5 class="card-title fw-bold">Taxonomía</h5>
                    <p class="card-text text-muted small">Familias, Géneros y Especies.</p>
                    <div class="d-grid gap-2 mt-3">
                        <a asp-controller="Taxonomias" asp-action="Index" class="btn btn-sm bioutn-btn bioutn-btn-outline">Taxonomías</a>
                        <a asp-controller="Generos" asp-action="Index" class="btn btn-sm bioutn-btn bioutn-btn-outline">Géneros</a>
                        <a asp-controller="Especies" asp-action="Index" class="btn btn-sm bioutn-btn bioutn-btn-outline">Especies</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tipos y Fases -->
        <div class="col-md-3 col-sm-6">
            <div class="card h-100 bioutn-card dashboard-card border-info">
                <div class="card-body text-center p-3">
                    <div class="icon-box mb-2 mx-auto text-info" style="font-size: 2rem;">
                        <i class="bi bi-tags"></i>
                    </div>
                    <h5 class="card-title fw-bold">Clasificaciones</h5>
                    <p class="card-text text-muted small">Tipos de Plantas, Cultivos y Fases.</p>
                    <div class="d-grid gap-2 mt-3">
                        <a asp-controller="TipoPlantas" asp-action="Index" class="btn btn-sm bioutn-btn bioutn-btn-outline">Tipos Planta</a>
                        <a asp-controller="TipoCultivos" asp-action="Index" class="btn btn-sm bioutn-btn bioutn-btn-outline">Tipos Cultivo</a>
                        <a asp-controller="FaseCultivos" asp-action="Index" class="btn btn-sm bioutn-btn bioutn-btn-outline">Fases</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Entorno y Logística -->
        <div class="col-md-3 col-sm-6">
            <div class="card h-100 bioutn-card dashboard-card border-warning">
                <div class="card-body text-center p-3">
                    <div class="icon-box mb-2 mx-auto text-warning" style="font-size: 2rem;">
                        <i class="bi bi-geo-alt"></i>
                    </div>
                    <h5 class="card-title fw-bold">Entorno Físico</h5>
                    <p class="card-text text-muted small">Anaqueles, Permisos y Medios.</p>
                    <div class="d-grid gap-2 mt-3">
                        <a asp-controller="UbicacionFisicas" asp-action="Index" class="btn btn-sm bioutn-btn bioutn-btn-outline">Ubicaciones</a>
                        <a asp-controller="MedioCultivos" asp-action="Index" class="btn btn-sm bioutn-btn bioutn-btn-outline">Medios</a>
                        <a asp-controller="PermisoAmbientals" asp-action="Index" class="btn btn-sm bioutn-btn bioutn-btn-outline">Permisos</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Extras de Sistema -->
        <div class="col-md-3 col-sm-6">
            <div class="card h-100 bioutn-card dashboard-card border-primary">
                <div class="card-body text-center p-3">
                    <div class="icon-box mb-2 mx-auto text-primary" style="font-size: 2rem;">
                        <i class="bi bi-person-badge"></i>
                    </div>
                    <h5 class="card-title fw-bold">Extras</h5>
                    <p class="card-text text-muted small">Catálogos auxiliares.</p>
                    <div class="d-grid gap-2 mt-3">
                        <a asp-controller="TipoIdentificacions" asp-action="Index" class="btn btn-sm bioutn-btn bioutn-btn-outline">Identificaciones</a>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
