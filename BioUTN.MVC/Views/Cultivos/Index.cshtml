@{
    ViewData["Title"] = "Gestión de Cultivos In Vitro";
}

<style>
    /* Custom Figma-like styles */
    .figma-container {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background-color: #f9fafb; /* bg-gray-50 */
        padding: 20px;
        border-radius: 12px;
    }
    .figma-card {
        background-color: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 0.75rem; /* rounded-xl */
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        padding: 1.25rem;
        transition: all 0.2s;
    }
    .figma-section-title {
        font-size: 11px;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        margin-bottom: 1.25rem;
    }
    .kpi-card {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.5rem;
        padding: 0.75rem;
        border-radius: 0.75rem;
        border: 1px solid #e5e7eb;
        background-color: #f9fafb;
        transition: all 0.2s;
        text-decoration: none;
    }
    .kpi-card:hover {
        border-color: rgba(16, 185, 129, 0.3);
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    }
    .kpi-icon-box {
        width: 32px;
        height: 32px;
        border-radius: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .kpi-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: #111827;
        line-height: 1;
        margin: 0;
    }
    .kpi-label {
        font-size: 11px;
        color: #6b7280;
        margin: 0;
    }

    /* Process Flow */
    .process-flow {
        display: flex;
        flex-wrap: wrap;
        gap: 0;
        align-items: flex-start;
    }
    .process-step {
        display: flex;
        align-items: flex-start;
    }
    .process-btn {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        width: 120px;
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
        text-decoration: none;
    }
    .process-icon-box {
        position: relative;
        width: 48px;
        height: 48px;
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: transform 0.2s;
    }
    .process-btn:hover .process-icon-box {
        transform: scale(1.05);
    }
    .process-badge {
        position: absolute;
        top: -8px;
        left: -8px;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background-color: #2d7d32;
        color: white;
        font-size: 10px;
        font-weight: bold;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05);
    }
    .process-title {
        font-size: 12px;
        font-weight: 600;
        color: #111827;
        line-height: 1.2;
        transition: color 0.2s;
        margin: 0;
    }
    .process-btn:hover .process-title {
        color: #10b981;
    }
    .process-subtitle {
        font-size: 10px;
        color: #6b7280;
        margin-top: 2px;
        margin-bottom: 0;
    }
    .process-arrow {
        display: flex;
        align-items: center;
        margin-top: 20px;
        padding: 0 2px;
        color: rgba(107, 114, 128, 0.3);
    }

    /* Modules */
    .module-card {
        background-color: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 0.75rem;
        padding: 1rem;
        display: flex;
        gap: 0.75rem;
        align-items: flex-start;
        text-align: left;
        box-shadow: 0 1px 2px 0 rgba(0,0,0,0.05);
        transition: all 0.2s;
        cursor: pointer;
        text-decoration: none;
        color: inherit;
    }
    .module-card:hover {
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border-color: rgba(16, 185, 129, 0.2);
    }
    .module-icon {
        width: 36px;
        height: 36px;
        border-radius: 0.75rem;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }
    .module-title {
        font-size: 13px;
        font-weight: 600;
        color: #111827;
        margin: 0;
        transition: color 0.2s;
        line-height: 1.4;
    }
    .module-card:hover .module-title {
        color: #10b981;
    }
    .module-desc {
        font-size: 11px;
        color: #6b7280;
        margin-top: 4px;
        line-height: 1.5;
        margin-bottom: 0;
    }
    .module-arrow {
        color: rgba(107,114,128,0.35);
        transition: color 0.2s;
        margin-top: 2px;
    }
    .module-card:hover .module-arrow {
        color: #10b981;
    }

    /* Health Bar */
    .health-bar-container {
        display: flex;
        height: 12px;
        border-radius: 9999px;
        overflow: hidden;
        gap: 2px;
    }
    
    /* Colors */
    .bg-emerald-50 { background-color: #ecfdf5; }
    .text-emerald-600 { color: #059669; }
    .bg-purple-50 { background-color: #faf5ff; }
    .text-purple-600 { color: #9333ea; }
    .bg-teal-50 { background-color: #f0fdfa; }
    .text-teal-600 { color: #0d9488; }
    .bg-blue-50 { background-color: #eff6ff; }
    .text-blue-600 { color: #2563eb; }
    .bg-violet-50 { background-color: #f5f3ff; }
    .text-violet-600 { color: #7c3aed; }
    .bg-orange-50 { background-color: #fff7ed; }
    .text-orange-600 { color: #ea580c; }
</style>

<div class="container-fluid py-4 figma-container">
    <div class="mb-4">
        <h1 class="h3 mb-1" style="font-weight: 700; color: #111827;">Gestión de Cultivos In Vitro</h1>
        <p class="text-muted" style="font-size: 14px;">Administración integral de lotes, siembras y trazabilidad</p>
    </div>

    <!-- Procesos -->
    <div class="figma-card mb-4">
        <p class="figma-section-title">Procesos</p>
        <div class="process-flow">
            <!-- Taxonomía -->
            <div class="process-step">
                <a asp-controller="Taxonomias" asp-action="Index" class="process-btn">
                    <div class="process-icon-box bg-purple-50 text-purple-600">
                        <i class="bi bi-diagram-3"></i>
                        <span class="process-badge">1</span>
                    </div>
                    <div class="text-center">
                        <p class="process-title">Taxonomía</p>
                        <p class="process-subtitle">Árbol evolutivo</p>
                    </div>
                </a>
                <div class="process-arrow"><i class="bi bi-chevron-right"></i></div>
            </div>
            <!-- Especie -->
            <div class="process-step">
                <a asp-controller="Especies" asp-action="Index" class="process-btn">
                    <div class="process-icon-box bg-emerald-50 text-emerald-600">
                        <i class="bi bi-box-seam"></i>
                        <span class="process-badge">2</span>
                    </div>
                    <div class="text-center">
                        <p class="process-title">Especie</p>
                        <p class="process-subtitle">Nombre + código</p>
                    </div>
                </a>
                <div class="process-arrow"><i class="bi bi-chevron-right"></i></div>
            </div>
            @if (!User.IsInRole("Estudiante"))
            {
                <!-- Proyectos -->
                <div class="process-step">
                    <a asp-controller="Proyectos" asp-action="Index" class="process-btn">
                        <div class="process-icon-box bg-orange-50 text-orange-600">
                            <i class="bi bi-folder2-open"></i>
                            <span class="process-badge">3</span>
                        </div>
                        <div class="text-center">
                            <p class="process-title">Proyectos</p>
                            <p class="process-subtitle">Carpetas verde/azul</p>
                        </div>
                    </a>
                    <div class="process-arrow"><i class="bi bi-chevron-right"></i></div>
                </div>
            }
            <!-- Planta Madre -->
            <div class="process-step">
                <a asp-controller="PlantaMadres" asp-action="Index" class="process-btn">
                    <div class="process-icon-box bg-teal-50 text-teal-600">
                        <i class="bi bi-tree"></i>
                        <span class="process-badge">4</span>
                    </div>
                    <div class="text-center">
                        <p class="process-title">Planta Madre</p>
                        <p class="process-subtitle">Espécimen élite</p>
                    </div>
                </a>
                <div class="process-arrow"><i class="bi bi-chevron-right"></i></div>
            </div>
            <!-- Lote + Frascos -->
            <div class="process-step">
                <a asp-controller="LoteCultivos" asp-action="Index" class="process-btn">
                    <div class="process-icon-box bg-blue-50 text-blue-600">
                        <i class="bi bi-grid"></i>
                        <span class="process-badge">5</span>
                    </div>
                    <div class="text-center">
                        <p class="process-title">Lote + Frascos</p>
                        <p class="process-subtitle">Siembra in vitro</p>
                    </div>
                </a>
                <div class="process-arrow"><i class="bi bi-chevron-right"></i></div>
            </div>
            <!-- Monitoreo -->
            <div class="process-step">
                <a asp-controller="MonitoreoFitosanitarios" asp-action="Index" class="process-btn">
                    <div class="process-icon-box bg-violet-50 text-violet-600">
                        <i class="bi bi-activity"></i>
                        <span class="process-badge">6</span>
                    </div>
                    <div class="text-center">
                        <p class="process-title">Monitoreo</p>
                        <p class="process-subtitle">Revisión periódica</p>
                    </div>
                </a>
                <div class="process-arrow"><i class="bi bi-chevron-right"></i></div>
            </div>
            <!-- Resiembras -->
            <div class="process-step">
                <a asp-controller="UnidadFrascos" asp-action="Index" class="process-btn">
                    <div class="process-icon-box bg-blue-50 text-blue-600">
                        <i class="bi bi-diagram-2"></i>
                        <span class="process-badge">7</span>
                    </div>
                    <div class="text-center">
                        <p class="process-title">Resiembras</p>
                        <p class="process-subtitle">Multiplicación</p>
                    </div>
                </a>
                <div class="process-arrow"><i class="bi bi-chevron-right"></i></div>
            </div>
            <!-- Enraizamiento -->
            <div class="process-step">
                <a asp-controller="LoteCultivos" asp-action="Index" class="process-btn">
                    <div class="process-icon-box bg-teal-50 text-teal-600">
                        <i class="bi bi-flower2"></i>
                        <span class="process-badge">8</span>
                    </div>
                    <div class="text-center">
                        <p class="process-title">Enraizamiento</p>
                        <p class="process-subtitle">Raíces fuertes</p>
                    </div>
                </a>
                <div class="process-arrow"><i class="bi bi-chevron-right"></i></div>
            </div>
            <!-- Aclimatación -->
            <div class="process-step">
                <a asp-controller="LoteCultivos" asp-action="Index" class="process-btn">
                    <div class="process-icon-box bg-emerald-50 text-emerald-600">
                        <i class="bi bi-sun"></i>
                        <span class="process-badge">9</span>
                    </div>
                    <div class="text-center">
                        <p class="process-title">Aclimatación</p>
                        <p class="process-subtitle">Ex vitro (Tierra)</p>
                    </div>
                </a>
                <div class="process-arrow"><i class="bi bi-chevron-right"></i></div>
            </div>
            <!-- Cuaderno -->
            <div class="process-step">
                <a asp-controller="EntradasDiario" asp-action="Index" class="process-btn">
                    <div class="process-icon-box bg-orange-50 text-orange-600">
                        <i class="bi bi-journal-text"></i>
                        <span class="process-badge">10</span>
                    </div>
                    <div class="text-center">
                        <p class="process-title">Fichas</p>
                        <p class="process-subtitle">Observaciones</p>
                    </div>
                </a>
            </div>
        </div>
    </div>

    <!-- Modulos / Pasos del Proceso (Grid) -->
    <div class="row g-3 mb-4">
        <div class="col-12 col-md-6 col-lg-4">
            <a asp-controller="Taxonomias" asp-action="Index" class="module-card">
                <div class="module-icon bg-purple-50 text-purple-600"><i class="bi bi-diagram-3"></i></div>
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between align-items-start">
                        <p class="module-title">Taxonomía</p>
                        <i class="bi bi-chevron-right module-arrow"></i>
                    </div>
                    <p class="module-desc">Registra el árbol evolutivo completo: Dominio → Reino → Filo → Clase → Orden → Familia → Género → Especie.</p>
                </div>
            </a>
        </div>
        <div class="col-12 col-md-6 col-lg-4">
            <a asp-controller="Especies" asp-action="Index" class="module-card">
                <div class="module-icon bg-emerald-50 text-emerald-600"><i class="bi bi-box-seam"></i></div>
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between align-items-start">
                        <p class="module-title">Catálogo de Especies</p>
                        <i class="bi bi-chevron-right module-arrow"></i>
                    </div>
                    <p class="module-desc">Registra la especie con su nombre científico y código de trazabilidad. Vincula a su clasificación taxonómica.</p>
                </div>
            </a>
        </div>
        @if (!User.IsInRole("Estudiante"))
        {
            <div class="col-12 col-md-6 col-lg-4">
                <a asp-controller="Proyectos" asp-action="Index" class="module-card">
                    <div class="module-icon bg-orange-50 text-orange-600"><i class="bi bi-folder2-open"></i></div>
                    <div class="flex-grow-1">
                        <div class="d-flex justify-content-between align-items-start">
                            <p class="module-title">Proyectos / Carpetas</p>
                            <i class="bi bi-chevron-right module-arrow"></i>
                        </div>
                        <p class="module-desc">Gestiona las Carpetas Verdes (Tesis) y Azules (Investigación). Configura Docentes y Tesistas para las Fichas.</p>
                    </div>
                </a>
            </div>
        }
        <div class="col-12 col-md-6 col-lg-4">
            <a asp-controller="PlantaMadres" asp-action="Index" class="module-card">
                <div class="module-icon bg-teal-50 text-teal-600"><i class="bi bi-tree"></i></div>
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between align-items-start">
                        <p class="module-title">Plantas Madre</p>
                        <i class="bi bi-chevron-right module-arrow"></i>
                    </div>
                    <p class="module-desc">Registra el espécimen élite del invernadero del que van a salir todos los explantes del cultivo.</p>
                </div>
            </a>
        </div>
        <div class="col-12 col-md-6 col-lg-4">
            <a asp-controller="LoteCultivos" asp-action="Index" class="module-card">
                <div class="module-icon bg-blue-50 text-blue-600"><i class="bi bi-grid"></i></div>
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between align-items-start">
                        <p class="module-title">Lotes y Frascos</p>
                        <i class="bi bi-chevron-right module-arrow"></i>
                    </div>
                    <p class="module-desc">Crea el lote de siembra. El sistema genera automáticamente todos los frascos con sus códigos únicos.</p>
                </div>
            </a>
        </div>
        <div class="col-12 col-md-6 col-lg-4">
            <a asp-controller="MonitoreoFitosanitarios" asp-action="Index" class="module-card">
                <div class="module-icon bg-violet-50 text-violet-600"><i class="bi bi-activity"></i></div>
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between align-items-start">
                        <p class="module-title">Monitoreo por Frasco</p>
                        <i class="bi bi-chevron-right module-arrow"></i>
                    </div>
                    <p class="module-desc">Revisión periódica: marca contaminaciones, oxidación, respuesta fisiológica. El sistema calcula la eficiencia.</p>
                </div>
            </a>
        </div>
        <div class="col-12 col-md-6 col-lg-4">
            <a asp-controller="Reportes" asp-action="Cultivos" class="module-card">
                <div class="module-icon bg-orange-50 text-orange-600"><i class="bi bi-journal-text"></i></div>
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between align-items-start">
                        <p class="module-title">Cuaderno Digital</p>
                        <i class="bi bi-chevron-right module-arrow"></i>
                    </div>
                    <p class="module-desc">Todas las observaciones de seguimiento en orden cronológico. El diario de laboratorio digital.</p>
                </div>
            </a>
        </div>
        <div class="col-12 col-md-6 col-lg-4">
            <a asp-controller="UnidadFrascos" asp-action="Index" class="module-card">
                <div class="module-icon bg-blue-50 text-blue-600"><i class="bi bi-diagram-2"></i></div>
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between align-items-start">
                        <p class="module-title">Resiembras</p>
                        <i class="bi bi-chevron-right module-arrow"></i>
                    </div>
                    <p class="module-desc">Genera nuevos frascos subdividiendo el tejido (multiplicación in vitro). Máximo 10 repeticiones.</p>
                </div>
            </a>
        </div>
        <div class="col-12 col-md-6 col-lg-4">
            <a asp-controller="LoteCultivos" asp-action="Index" class="module-card">
                <div class="module-icon bg-teal-50 text-teal-600"><i class="bi bi-flower2"></i></div>
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between align-items-start">
                        <p class="module-title">Enraizamiento</p>
                        <i class="bi bi-chevron-right module-arrow"></i>
                    </div>
                    <p class="module-desc">Cambio a medio especializado con auxinas para desarrollar el sistema radicular previo a la salida.</p>
                </div>
            </a>
        </div>
        <div class="col-12 col-md-6 col-lg-4">
            <a asp-controller="LoteCultivos" asp-action="Index" class="module-card">
                <div class="module-icon bg-emerald-50 text-emerald-600"><i class="bi bi-sun"></i></div>
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between align-items-start">
                        <p class="module-title">Aclimatación</p>
                        <i class="bi bi-chevron-right module-arrow"></i>
                    </div>
                    <p class="module-desc">Transferencia a invernadero. Adaptación de las plantas a la luz solar y humedad natural ex vitro.</p>
                </div>
            </a>
        </div>
        <div class="col-12 col-md-6 col-lg-4">
            <a asp-controller="PlantaMadres" asp-action="TrazabilidadIndex" class="module-card" style="border-color: rgba(139, 92, 246, 0.4); background: #faf5ff;">
                <div class="module-icon bg-purple-100 text-purple-700" style="background-color: #f3e8ff; color: #7e22ce;"><i class="bi bi-diagram-3-fill"></i></div>
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between align-items-start">
                        <p class="module-title" style="color: #6b21a8;">Árbol de Trazabilidad</p>
                        <i class="bi bi-chevron-right module-arrow" style="color: #6b21a8;"></i>
                    </div>
                        <p class="module-desc" style="color: #4c1d95;">Visualiza el árbol genealógico interactivo de una Planta Madre, todas sus siembras y resiembras asociadas.</p>
                </div>
            </a>
        </div>
    </div>
</div>
