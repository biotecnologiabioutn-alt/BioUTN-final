@model BioUTN.Modelos.Especie

@{
    ViewData["Title"] = "Detalles de la Especie";
}

@section Styles {
<style>
    .figma-container { font-family: 'Inter', -apple-system, sans-serif; background-color: #f9fafb; padding: 20px; border-radius: 12px; }
    .figma-card { background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 0.75rem; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); padding: 1.5rem; }
    .figma-title { font-size: 1.125rem; font-weight: 700; color: #111827; margin-bottom: 1rem; border-bottom: 1px solid #f3f4f6; padding-bottom: 0.5rem; }
    .detail-label { font-size: 13px; font-weight: 600; color: #6b7280; text-transform: uppercase; letter-spacing: 0.025em; margin-bottom: 0.25rem; }
    .detail-value { font-size: 14px; font-weight: 500; color: #111827; margin-bottom: 1.25rem; }
    .badge-status { display: inline-block; padding: 0.25rem 0.75rem; font-size: 12px; font-weight: 600; border-radius: 9999px; background-color: #d1fae5; color: #065f46; }
    .figma-btn-secondary { background-color: white; color: #374151; border: 1px solid #e5e7eb; padding: 0.5rem 1rem; border-radius: 0.5rem; font-size: 14px; font-weight: 500; transition: all 0.2s; text-decoration: none; display: inline-block; }
    .figma-btn-secondary:hover { background-color: #f9fafb; color: #111827; }
    .figma-btn-primary { background-color: #10b981; color: white; border: none; padding: 0.5rem 1rem; border-radius: 0.5rem; font-size: 14px; font-weight: 500; transition: all 0.2s; text-decoration: none; display: inline-block; }
    .figma-btn-primary:hover { background-color: #059669; color: white; }
    .badge-danger-alt { background-color: #fef2f2; color: #991b1b; display: inline-block; padding: 0.25rem 0.75rem; font-size: 12px; font-weight: 600; border-radius: 9999px; }
</style>
}

<div class="figma-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 style="font-weight: 700; color: #111827; font-size: 20px; margin-bottom: 0;">Detalles de Especie: @Model.NombreCientifico</h3>
            <p class="text-muted mb-0" style="font-size: 13px;">Información taxonómica y biológica</p>
        </div>
        <div class="gap-2 d-flex">
            <a asp-action="Index" class="figma-btn-secondary">Volver al listado</a>
            @if (User.IsInRole("Tecnico"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="figma-btn-primary">
                    <i class="bi bi-pencil-square me-1"></i> Editar Especie
                </a>
            }
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="figma-card h-100">
                <h4 class="figma-title">Información Principal</h4>
                
                <div class="row">
                    <div class="col-6">
                        <div class="detail-label">Nombre Científico</div>
                        <div class="detail-value" style="font-style: italic;">@Model.NombreCientifico</div>
                    </div>
                    <div class="col-6">
                        <div class="detail-label">Nombre Común</div>
                        <div class="detail-value">@(string.IsNullOrEmpty(Model.NombreComun) ? "N/A" : Model.NombreComun)</div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-6">
                        <div class="detail-label">Código Estricto</div>
                        <div class="detail-value font-mono">@Model.CodigoEstricto</div>
                    </div>
                    <div class="col-6">
                        <div class="detail-label">Sinónimos Taxonómicos</div>
                        <div class="detail-value">@(string.IsNullOrEmpty(Model.SinonimosTaxonomicos) ? "N/A" : Model.SinonimosTaxonomicos)</div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-6">
                        <div class="detail-label">Estado de Conservación</div>
                        <div class="detail-value">
                            @if (Model.EstadoConservacion == "Desconocido")
                            {
                                <span>@Model.EstadoConservacion</span>
                            }
                            else
                            {
                                <span class="badge-danger-alt">@Model.EstadoConservacion</span>
                            }
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="detail-label">Endémica</div>
                        <div class="detail-value">
                            @(Model.EsEndemica ? "Sí" : "No")
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="figma-card h-100">
                <h4 class="figma-title">Clasificación y Taxonomía</h4>
                
                <div class="row">
                    <div class="col-6">
                        <div class="detail-label">Taxonomía Asociada</div>
                        <div class="detail-value">@(Model.Taxonomia?.Especie ?? "N/A")</div>
                    </div>
                    <div class="col-6">
                        <div class="detail-label">Familia</div>
                        <div class="detail-value">@(Model.Taxonomia?.Familia ?? "N/A")</div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-6">
                        <div class="detail-label">Tipo de Planta</div>
                        <div class="detail-value">
                            <span class="badge-status" style="background-color: #ecfdf5; color: #047857;">
                                @(Model.TipoPlanta?.Nombre ?? "N/A")
                            </span>
                        </div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-12 mt-3">
                        <div class="detail-label">Importancia de la Especie</div>
                        <div class="detail-value mb-0" style="white-space: pre-line; line-height: 1.5; font-size: 13px;">
                            @(string.IsNullOrEmpty(Model.ImportanciaEspecie) ? "Sin descripción detallada." : Model.ImportanciaEspecie)
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
