@model BioUTN.Modelos.Especie

@{
    ViewData["Title"] = "Crear Especie";
}

@section Styles {
<style>
    .figma-container { font-family: 'Inter', -apple-system, sans-serif; background-color: #f9fafb; padding: 20px; border-radius: 12px; }
    .figma-card { background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 0.75rem; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); padding: 1.5rem; }
    .figma-label { font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 0.5rem; display: block; }
    .figma-input { width: 100%; padding: 0.625rem 0.75rem; border-radius: 0.5rem; border: 1px solid #e5e7eb; font-size: 14px; color: #111827; outline: none; transition: all 0.2s; background-color: #ffffff; }
    .figma-input:focus { border-color: rgba(16, 185, 129, 0.6); box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.2); }
    .figma-btn-primary { background-color: #10b981; color: white; border: none; padding: 0.625rem 1.25rem; border-radius: 0.5rem; font-size: 14px; font-weight: 500; transition: all 0.2s; }
    .figma-btn-primary:hover { background-color: #059669; color: white; }
    .figma-btn-secondary { background-color: white; color: #374151; border: 1px solid #e5e7eb; padding: 0.625rem 1.25rem; border-radius: 0.5rem; font-size: 14px; font-weight: 500; transition: all 0.2s; text-decoration: none; display: inline-flex; align-items: center; }
    .figma-btn-secondary:hover { background-color: #f9fafb; color: #111827; }
</style>
}

<div class="figma-container">
    <div class="mb-4">
        <h3 style="font-weight: 700; color: #111827; font-size: 18px;">Registrar Especie</h3>
        <p class="text-muted" style="font-size: 13px;">Ingrese los datos de la nueva especie para el catálogo</p>
    </div>

    <div class="row">
        <div class="col-md-8 col-lg-6">
            <div class="figma-card">
                <form asp-action="Create" class="space-y-4">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 13px;"></div>

                    <div class="mb-3">
                        <label asp-for="CodigoEstricto" class="figma-label">Código Estricto *</label>
                        <input asp-for="CodigoEstricto" class="figma-input" placeholder="Ej. ESP-001" />
                        <span asp-validation-for="CodigoEstricto" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NombreCientifico" class="figma-label">Nombre Científico *</label>
                        <input asp-for="NombreCientifico" class="figma-input" placeholder="Ej. Solanum lycopersicum" />
                        <span asp-validation-for="NombreCientifico" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NombreComun" class="figma-label">Nombre Común</label>
                        <input asp-for="NombreComun" class="figma-input" placeholder="Ej. Tomate" />
                        <span asp-validation-for="NombreComun" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="SinonimosTaxonomicos" class="figma-label">Sinónimos Taxonómicos</label>
                        <input asp-for="SinonimosTaxonomicos" class="figma-input" placeholder="Ej. Cyanococcus corymbosus..." />
                        <span asp-validation-for="SinonimosTaxonomicos" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <label asp-for="IdTipoPlanta" class="figma-label mb-0">Tipo de Planta *</label>
                                <button type="button" id="btnNuevoTipoPlanta" class="btn btn-sm btn-link text-decoration-none p-0" style="font-size: 12px; color: #10b981;">
                                    <i class="bi bi-plus-circle me-1"></i>Nuevo
                                </button>
                            </div>
                            <select asp-for="IdTipoPlanta" class="figma-input form-select" asp-items="ViewBag.TipoPlantas">
                                <option value="">-- Seleccione Tipo --</option>
                            </select>
                            <span asp-validation-for="IdTipoPlanta" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-6 mb-3">
                            <label asp-for="IdTaxonomia" class="figma-label">Taxonomía (Especie) *</label>
                            <select asp-for="IdTaxonomia" class="figma-input form-select" asp-items="ViewBag.Taxonomias">
                                <option value="">-- Seleccione Taxonomía --</option>
                            </select>
                            <span asp-validation-for="IdTaxonomia" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <h4 class="mt-4 mb-3" style="font-size: 15px; font-weight: 700; color: #111827; border-bottom: 1px solid #e5e7eb; padding-bottom: 5px;">Información Biológica</h4>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label asp-for="CicloVida" class="figma-label">Ciclo de Vida *</label>
                            <input asp-for="CicloVida" class="figma-input" placeholder="Ej. Perenne, Anual" />
                            <span asp-validation-for="CicloVida" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-6 mb-3">
                            <label asp-for="CategoriaUso" class="figma-label">Categoría / Uso *</label>
                            <input asp-for="CategoriaUso" class="figma-input" placeholder="Ej. Frutal comercial" />
                            <span asp-validation-for="CategoriaUso" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12 mb-3">
                            <label asp-for="EstadoConservacion" class="figma-label">Estado de Conservación *</label>
                            <input asp-for="EstadoConservacion" class="figma-input" placeholder="Ej. Desconocido, En Peligro" />
                            <span asp-validation-for="EstadoConservacion" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-6 d-flex align-items-center gap-2">
                            <input asp-for="EsEndemica" class="form-check-input mt-0" type="checkbox" style="width: 1.25rem; height: 1.25rem; border-color: #e5e7eb; cursor: pointer;" />
                            <label asp-for="EsEndemica" class="figma-label mb-0" style="cursor: pointer;">¿Es Endémica?</label>
                        </div>
                        <div class="col-6 d-flex align-items-center gap-2">
                            <input asp-for="EsNativa" class="form-check-input mt-0" type="checkbox" style="width: 1.25rem; height: 1.25rem; border-color: #e5e7eb; cursor: pointer;" />
                            <label asp-for="EsNativa" class="figma-label mb-0" style="cursor: pointer;">¿Es Nativa?</label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="DistribucionNatural" class="figma-label">Distribución Natural *</label>
                        <input asp-for="DistribucionNatural" class="figma-input" placeholder="Ej. América del Sur, Europa..." />
                        <span asp-validation-for="DistribucionNatural" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ImportanciaEspecie" class="figma-label">Importancia de la Especie *</label>
                        <textarea asp-for="ImportanciaEspecie" class="figma-input" rows="3" placeholder="Describa la importancia biotecnológica..."></textarea>
                        <span asp-validation-for="ImportanciaEspecie" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <h4 class="mt-4 mb-3" style="font-size: 15px; font-weight: 700; color: #111827; border-bottom: 1px solid #e5e7eb; padding-bottom: 5px;">Parámetros Biológicos In-Vitro</h4>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label asp-for="DiasResiembra" class="figma-label">Días de resiembra para nuevos lotes</label>
                            <input asp-for="DiasResiembra" type="number" class="figma-input" placeholder="Ej. 90" />
                            <span asp-validation-for="DiasResiembra" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-6 mb-3">
                            <label asp-for="MaxResiembras" class="figma-label">Máx. Resiembras (Límite)</label>
                            <input asp-for="MaxResiembras" type="number" class="figma-input" placeholder="Ej. 10" />
                            <span asp-validation-for="MaxResiembras" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4 pt-3" style="border-top: 1px solid #e5e7eb;">
                        <a asp-action="Index" class="figma-btn-secondary">Volver</a>
                        <button type="button" id="btnGuardar" class="figma-btn-primary">Guardar Especie</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.getElementById('btnGuardar').addEventListener('click', function (e) {
            e.preventDefault();
            
            var form = this.closest('form');
            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }

            Swal.fire({
                title: '¿Confirmar Especie?',
                text: "El código de trazabilidad ingresado será la base para todos los frascos de esta especie.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#10b981',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Sí, Guardar',
                cancelButtonText: 'Revisar'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            })
        });

        document.getElementById('btnNuevoTipoPlanta').addEventListener('click', function() {
            Swal.fire({
                title: 'Nuevo Tipo de Planta',
                input: 'text',
                inputPlaceholder: 'Ej. Arbustivo, Herbáceo...',
                showCancelButton: true,
                confirmButtonText: 'Crear',
                cancelButtonText: 'Cancelar',
                inputValidator: (value) => {
                    if (!value) {
                        return '¡Necesitas escribir un nombre!'
                    }
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    fetch('/Especies/CrearTipoPlantaAjax', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                        },
                        body: 'nombre=' + encodeURIComponent(result.value)
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            var select = document.getElementById('IdTipoPlanta');
                            select.innerHTML = '<option value="">-- Seleccione Tipo --</option>';
                            
                            var lastId = '';
                            data.data.forEach(item => {
                                var option = document.createElement('option');
                                option.value = item.id;
                                option.text = item.nombre;
                                select.appendChild(option);
                                lastId = item.id; // Guarda el último insertado
                            });
                            
                            // Selecciona automáticamente el recién creado
                            select.value = lastId;

                            Swal.fire('Creado!', 'El tipo de planta ha sido agregado.', 'success');
                        } else {
                            Swal.fire('Error', 'No se pudo crear.', 'error');
                        }
                    })
                    .catch(error => {
                        Swal.fire('Error', 'Ocurrió un problema de red.', 'error');
                    });
                }
            });
        });
    </script>
}
