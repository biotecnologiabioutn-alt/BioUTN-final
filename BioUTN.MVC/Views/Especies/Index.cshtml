@model IEnumerable<BioUTN.Modelos.Especie>

@{
    ViewData["Title"] = "Catálogo de Especies";
}

<style>
    /* Custom Figma-like styles */
    .figma-container {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background-color: #f9fafb;
        padding: 20px;
        border-radius: 12px;
    }
    .figma-card {
        background-color: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 0.75rem;
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        padding: 1.25rem;
        transition: all 0.2s;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }
    .figma-card:hover {
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border-color: rgba(16, 185, 129, 0.2);
    }
    .search-input {
        background-color: #ffffff;
        border: 1px solid #d1d5db;
        border-radius: 0.5rem;
        padding: 0.625rem 1rem;
        font-size: 0.875rem;
        width: 100%;
        transition: all 0.2s;
    }
    .search-input:focus {
        outline: none;
        border-color: #10b981;
        box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
    }
    .btn-custom-primary {
        background-color: #10b981;
        color: white;
        border-radius: 0.5rem;
        padding: 0.5rem 1rem;
        font-weight: 500;
        font-size: 0.875rem;
        transition: all 0.2s;
        border: none;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }
    .btn-custom-primary:hover {
        background-color: #059669;
        color: white;
    }
    .btn-custom-secondary {
        background-color: #f3f4f6;
        color: #374151;
        border-radius: 0.5rem;
        padding: 0.5rem 1rem;
        font-weight: 500;
        font-size: 0.875rem;
        transition: all 0.2s;
        border: 1px solid #e5e7eb;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }
    .btn-custom-secondary:hover {
        background-color: #e5e7eb;
        color: #111827;
    }
    .badge-family {
        background-color: #f3e8ff;
        color: #6b21a8;
        font-size: 0.75rem;
        font-weight: 500;
        padding: 0.25rem 0.5rem;
        border-radius: 9999px;
    }
    .badge-plant {
        background-color: #ecfdf5;
        color: #047857;
        font-size: 0.75rem;
        font-weight: 500;
        padding: 0.25rem 0.5rem;
        border-radius: 9999px;
    }
    .badge-danger {
        background-color: #fef2f2;
        color: #991b1b;
        font-size: 0.75rem;
        font-weight: 500;
        padding: 0.25rem 0.5rem;
        border-radius: 9999px;
    }
    .card-actions {
        display: flex;
        gap: 0.5rem;
        margin-top: 1rem;
        border-top: 1px solid #f3f4f6;
        padding-top: 0.75rem;
    }
    .action-link {
        font-size: 0.75rem;
        color: #4b5563;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.25rem 0.5rem;
        border-radius: 0.375rem;
        transition: all 0.2s;
    }
    .action-link:hover {
        background-color: #f3f4f6;
        color: #111827;
    }
    .action-link-delete {
        color: #dc2626;
    }
    .action-link-delete:hover {
        background-color: #fef2f2;
        color: #991b1b;
    }
</style>

<div class="container-fluid py-4 figma-container">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h1 class="h3 mb-1" style="font-weight: 700; color: #111827;">Catálogo de Especies</h1>
            <p class="text-muted mb-0" style="font-size: 14px;">Registro taxonómico y catálogo general de especies</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Cultivos" asp-action="Index" class="btn-custom-secondary">
                <i class="bi bi-arrow-left"></i> Volver a Cultivos
            </a>
            @if (User.IsInRole("Tecnico"))
            {
                <a asp-action="Create" class="btn-custom-primary">
                    <i class="bi bi-plus-lg"></i> Nueva Especie
                </a>
            }
        </div>
    </div>

    <!-- Search Input -->
    <div class="mb-4">
        <div class="position-relative">
            <input type="text" id="searchInput" class="search-input" placeholder="Buscar por nombre científico, común o Taxonomia...">
        </div>
    </div>

    <!-- Grid Layout -->
    <div class="row g-4" id="speciesGrid">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-12 col-md-6 col-lg-4 species-card-wrapper" 
                     data-scientific="@item.NombreCientifico" 
                     data-common="@item.NombreComun" 
                     data-family="@(item.Taxonomia?.Familia ?? "")">
                    <div class="figma-card">
                        <div>
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                <div>
                                    <p class="font-mono text-xs text-primary fw-bold mb-1">@item.CodigoEstricto</p>
                                    <h3 class="h6 font-semibold italic text-dark mb-1">@item.NombreCientifico</h3>
                                    <p class="text-xs text-muted mb-0">@item.NombreComun</p>
                                </div>
                            </div>
                            <div class="d-flex flex-wrap gap-1.5 mt-3">
                                @if (item.Taxonomia != null)
                                {
                                    <span class="badge-family">@item.Taxonomia.Familia</span>
                                }
                                @if (item.TipoPlanta != null)
                                {
                                    <span class="badge-plant">@item.TipoPlanta.Nombre</span>
                                }
                                @if (item.EstadoConservacion != "Desconocido")
                                {
                                    <span class="badge-danger"><i class="bi bi-exclamation-triangle"></i> @item.EstadoConservacion</span>
                                }
                            </div>
                        </div>
                        <div class="card-actions">
                            <a asp-action="Details" asp-route-id="@item.Id" class="action-link">
                                <i class="bi bi-eye"></i> Detalles
                            </a>
                            @if (User.IsInRole("Tecnico"))
                            {
                                <a asp-action="Edit" asp-route-id="@item.Id" class="action-link">
                                    <i class="bi bi-pencil"></i> Editar
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline ms-auto">
                                    <button type="submit" class="action-link action-link-delete border-0 bg-transparent" onclick="return confirm('¿Está seguro de eliminar esta especie?');">
                                        <i class="bi bi-trash3"></i> Eliminar
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted mb-3 d-block"></i>
                <p class="text-muted">No se encontraron especies en el catálogo.</p>
            </div>
        }
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const searchInput = document.getElementById("searchInput");
        const cardWrappers = document.querySelectorAll(".species-card-wrapper");

        searchInput.addEventListener("input", function (e) {
            const query = e.target.value.toLowerCase().trim();

            cardWrappers.forEach(card => {
                const scientific = card.getAttribute("data-scientific").toLowerCase();
                const common = card.getAttribute("data-common").toLowerCase();
                const family = card.getAttribute("data-family").toLowerCase();

                if (scientific.includes(query) || common.includes(query) || family.includes(query)) {
                    card.style.display = "";
                } else {
                    card.style.display = "none";
                }
            });
        });
    });
</script>

