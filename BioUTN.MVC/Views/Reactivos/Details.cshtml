@model BioUTN.Modelos.Reactivo

@{
    ViewData["Title"] = "Detalles del Insumo / Reactivo";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="bioutn-title mb-0">Detalles de Insumo / Reactivo</h2>
    </div>
    <a asp-action="Index" class="btn bioutn-btn bioutn-btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Volver al Inventario
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-10">
        <div class="bioutn-card mb-4">
            <div class="bioutn-card-header">
                <h5><i class="bi bi-box-seam me-2"></i> Información General</h5>
            </div>
            <div class="bioutn-card-body">
                <div class="row">
                    <div class="col-md-6">
                        <dl class="row mb-0">
                            <dt class="col-sm-4 text-muted">Nombre</dt>
                            <dd class="col-sm-8 fw-bold">@Model.Nombre</dd>

                            <dt class="col-sm-4 text-muted">Categoría</dt>
                            <dd class="col-sm-8"><span class="badge bg-secondary">@Model.Categoria</span></dd>
                        </dl>
                    </div>
                    <div class="col-md-6">
                        <dl class="row mb-0">
                            <dt class="col-sm-4 text-muted">Stock Actual</dt>
                            <dd class="col-sm-8 fw-bold @(Model.StockActual <= Model.StockMinimo ? "text-danger" : "text-success")">
                                @Model.StockActual 
                                @if(Model.StockActual <= Model.StockMinimo)
                                {
                                    <span class="badge bg-danger ms-2">Crítico</span>
                                }
                            </dd>

                            <dt class="col-sm-4 text-muted">Stock Mínimo</dt>
                            <dd class="col-sm-8">@Model.StockMinimo</dd>

                            <dt class="col-sm-4 text-muted">Fecha de Caducidad</dt>
                            <dd class="col-sm-8">@(Model.FechaCaducidad?.ToString("dd/MM/yyyy") ?? "-")</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <div class="bioutn-card">
            <div class="bioutn-card-header">
                <h5><i class="bi bi-building me-2"></i> Datos del Proveedor</h5>
            </div>
            <div class="bioutn-card-body">
                <div class="row">
                    <div class="col-md-6">
                        <dl class="row mb-0">
                            <dt class="col-sm-4 text-muted">Marca</dt>
                            <dd class="col-sm-8">@(Model.Marca ?? "-")</dd>

                            <dt class="col-sm-4 text-muted">Proveedor</dt>
                            <dd class="col-sm-8 fw-bold">@(Model.ProveedorNombre ?? "-")</dd>

                            <dt class="col-sm-4 text-muted">Sucursal / Dirección</dt>
                            <dd class="col-sm-8">@(Model.ProveedorSucursal ?? "-")</dd>
                        </dl>
                    </div>
                    <div class="col-md-6">
                        <dl class="row mb-0">
                            <dt class="col-sm-4 text-muted">Teléfono</dt>
                            <dd class="col-sm-8">@(Model.ProveedorTelefono ?? "-")</dd>

                            <dt class="col-sm-4 text-muted">Correo Electrónico</dt>
                            <dd class="col-sm-8">@(Model.ProveedorEmail ?? "-")</dd>

                            <dt class="col-sm-4 text-muted">Contacto</dt>
                            <dd class="col-sm-8">@(Model.ProveedorContacto ?? "-")</dd>

                            <dt class="col-sm-4 text-muted">RUC</dt>
                            <dd class="col-sm-8">@(Model.ProveedorRUC ?? "-")</dd>
                        </dl>
                    </div>
                </div>

                <div class="text-end mt-4 pt-3 border-top">
                    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn bioutn-btn bioutn-btn-primary px-4 shadow-sm">
                        <i class="bi bi-pencil me-1"></i> Editar Insumo
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
