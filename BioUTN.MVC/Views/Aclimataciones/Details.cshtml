@model BioUTN.Modelos.Aclimatacion

@{
    ViewData["Title"] = "Detalles de Aclimatación";
}

@section Styles {
<style>
    .figma-container { font-family: 'Inter', -apple-system, sans-serif; background-color: #f9fafb; padding: 20px; border-radius: 12px; }
    .figma-card { background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 0.75rem; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); padding: 1.5rem; }
    .figma-title { font-size: 1.125rem; font-weight: 700; color: #111827; margin-bottom: 1rem; border-bottom: 1px solid #f3f4f6; padding-bottom: 0.5rem; }
    .detail-label { font-size: 13px; font-weight: 600; color: #6b7280; text-transform: uppercase; letter-spacing: 0.025em; margin-bottom: 0.25rem; }
    .detail-value { font-size: 14px; font-weight: 500; color: #111827; margin-bottom: 1.25rem; }
    .figma-btn-secondary { background-color: white; color: #374151; border: 1px solid #e5e7eb; padding: 0.5rem 1rem; border-radius: 0.5rem; font-size: 14px; font-weight: 500; transition: all 0.2s; text-decoration: none; display: inline-block; }
    .figma-btn-secondary:hover { background-color: #f9fafb; color: #111827; }
</style>
}

<div class="figma-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 style="font-weight: 700; color: #111827; font-size: 20px; margin-bottom: 0;">Detalles de Aclimatación Ex-Vitro</h3>
        </div>
        <div class="gap-2 d-flex">
            <a asp-action="Index" class="figma-btn-secondary">Volver al listado</a>
            @if (Model.Activo)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="figma-btn-secondary" style="color: #059669;">
                    <i class="bi bi-pencil-square me-1"></i> Evaluar Supervivencia
                </a>
            }
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="figma-card h-100">
                <h4 class="figma-title">Traspaso y Condiciones</h4>
                
                <div class="row">
                    <div class="col-6">
                        <div class="detail-label">Lote Enraizado Origen</div>
                        <div class="detail-value">ENR-@Model.IdLoteEnraizado</div>
                    </div>
                    <div class="col-6">
                        <div class="detail-label">Fecha de Traspaso</div>
                        <div class="detail-value">@Model.FechaTraspaso.ToString("dd/MM/yyyy")</div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-6">
                        <div class="detail-label">Sustrato Utilizado</div>
                        <div class="detail-value">@Model.SustratoUtilizado</div>
                    </div>
                    <div class="col-6">
                        <div class="detail-label">Invernadero/Ubicación</div>
                        <div class="detail-value">@(Model.UbicacionFisica?.NombreCuerpo ?? "N/A")</div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-6">
                        <div class="detail-label">Lavado de Raíces</div>
                        <div class="detail-value">@(Model.LavadoRaices ? "Sí" : "No")</div>
                    </div>
                    <div class="col-6">
                        <div class="detail-label">Cobertura Plástica</div>
                        <div class="detail-value">@(Model.CoberturaPlastica ? "Sí" : "No")</div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-6">
                        <div class="detail-label">Humedad Inicial</div>
                        <div class="detail-value">@(Model.HumedadInicial.HasValue ? $"{Model.HumedadInicial}%" : "N/A")</div>
                    </div>
                    <div class="col-6">
                        <div class="detail-label">Temperatura Controlada</div>
                        <div class="detail-value">@(Model.TemperaturaControlada.HasValue ? $"{Model.TemperaturaControlada}°C" : "N/A")</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="figma-card h-100">
                <h4 class="figma-title">Evaluación Final de Supervivencia</h4>
                
                @if (Model.PlantasSobrevivientes.HasValue)
                {
                    <div class="row">
                        <div class="col-6">
                            <div class="detail-label">Fecha de Evaluación</div>
                            <div class="detail-value">@Model.FechaEvaluacionFinal?.ToString("dd/MM/yyyy")</div>
                        </div>
                        <div class="col-6">
                            <div class="detail-label">Estado del Ciclo</div>
                            <div class="detail-value">@(Model.Activo ? "Abierto" : "Cerrado")</div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-6">
                            <div class="detail-label" style="color: #059669;">Plantas Vivas</div>
                            <div class="detail-value" style="font-size: 18px; font-weight: 700; color: #059669;">@Model.PlantasSobrevivientes</div>
                        </div>
                        <div class="col-6">
                            <div class="detail-label" style="color: #dc2626;">Plantas Muertas</div>
                            <div class="detail-value" style="font-size: 18px; font-weight: 700; color: #dc2626;">@(Model.PlantasMuertas ?? 0)</div>
                        </div>
                    </div>
                    
                    <div class="row mt-2">
                        <div class="col-12">
                            <div class="detail-label">Observaciones</div>
                            <div class="detail-value">@(string.IsNullOrEmpty(Model.Observaciones) ? "Sin observaciones" : Model.Observaciones)</div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-clock-history mb-2" style="font-size: 2rem; display: block;"></i>
                        Aún no se ha registrado la evaluación final de supervivencia.
                        <br />
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="mt-3 d-inline-block text-success">Registrar evaluación ahora</a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
