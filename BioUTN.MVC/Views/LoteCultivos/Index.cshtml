@model IEnumerable<BioUTN.Modelos.LoteCultivo>

@{
    ViewData["Title"] = "Lotes y Frascos";
}

<style>
    /* Custom Figma-like styles */
    .figma-container {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
        background-color: #f9fafb;
        padding: 20px;
        border-radius: 12px;
    }
    .figma-card {
        background-color: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 0.75rem;
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        padding: 1.25rem;
        transition: all 0.2s;
        height: 100%;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }
    .figma-card:hover {
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        border-color: rgba(16, 185, 129, 0.2);
    }
    .search-input {
        background-color: #ffffff;
        border: 1px solid #d1d5db;
        border-radius: 0.5rem;
        padding: 0.625rem 1rem;
        font-size: 0.875rem;
        width: 100%;
        transition: all 0.2s;
    }
    .search-input:focus {
        outline: none;
        border-color: #10b981;
        box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
    }
    .btn-custom-primary {
        background-color: #10b981;
        color: white;
        border-radius: 0.5rem;
        padding: 0.5rem 1rem;
        font-weight: 500;
        font-size: 0.875rem;
        transition: all 0.2s;
        border: none;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }
    .btn-custom-primary:hover {
        background-color: #059669;
        color: white;
    }
    .btn-custom-secondary {
        background-color: #f3f4f6;
        color: #374151;
        border-radius: 0.5rem;
        padding: 0.5rem 1rem;
        font-weight: 500;
        font-size: 0.875rem;
        transition: all 0.2s;
        border: 1px solid #e5e7eb;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }
    .btn-custom-secondary:hover {
        background-color: #e5e7eb;
        color: #111827;
    }
    
    /* Fase Badges */
    .badge-fase {
        font-size: 0.75rem;
        font-weight: 500;
        padding: 0.25rem 0.5rem;
        border-radius: 9999px;
        display: inline-block;
    }
    .badge-fase-introduccion { background-color: #faf5ff; color: #7e22ce; }
    .badge-fase-multiplicacion { background-color: #ecfdf5; color: #047857; }
    .badge-fase-enraizamiento { background-color: #eff6ff; color: #1d4ed8; }
    .badge-fase-aclimatacion { background-color: #f5f3ff; color: #6d28d9; }
    .badge-fase-conservacion { background-color: #fff7ed; color: #c2410c; }
    
    .badge-tipo {
        background-color: #f0fdfa;
        color: #0f766e;
        font-size: 0.75rem;
        font-weight: 500;
        padding: 0.25rem 0.5rem;
        border-radius: 9999px;
    }

    .card-actions {
        display: flex;
        gap: 0.5rem;
        margin-top: 1rem;
        border-top: 1px solid #f3f4f6;
        padding-top: 0.75rem;
    }
    .action-link {
        font-size: 0.75rem;
        color: #4b5563;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.25rem 0.5rem;
        border-radius: 0.375rem;
        transition: all 0.2s;
    }
    .action-link:hover {
        background-color: #f3f4f6;
        color: #111827;
    }
    .action-link-delete {
        color: #dc2626;
    }
    .action-link-delete:hover {
        background-color: #fef2f2;
        color: #991b1b;
    }
    .meta-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 0.75rem;
        font-size: 11px;
        margin-top: 1rem;
        color: #6b7280;
    }
    .meta-item p {
        margin: 0;
    }
    .meta-title {
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 600;
        color: #9ca3af;
    }
    .meta-val {
        font-weight: 500;
        color: #374151;
        margin-top: 2px !important;
    }
</style>

<div class="container-fluid py-4 figma-container">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h1 class="h3 mb-1" style="font-weight: 700; color: #111827;">Lotes y Frascos</h1>
            <p class="text-muted mb-0" style="font-size: 14px;">Trazabilidad y control del lote in vitro desde la siembra</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Cultivos" asp-action="Index" class="btn-custom-secondary">
                <i class="bi bi-arrow-left"></i> Volver a Cultivos
            </a>
            @if (User.IsInRole("Tecnico") || User.IsInRole("Coordinador"))
            {
                <a asp-action="Create" class="btn-custom-primary">
                    <i class="bi bi-plus-lg"></i> Crear Lote de Siembra
                </a>
            }
        </div>
    </div>

    <!-- Search Input -->
    <div class="mb-4">
        <input type="text" id="searchInput" class="search-input" placeholder="Buscar por código de trazabilidad, especie o medio de cultivo...">
    </div>

    <!-- Grid Layout -->
    <div class="row g-4" id="lotesGrid">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-12 col-md-6 col-lg-4 lote-card-wrapper" 
                     data-code="@item.CodigoTrazabilidad" 
                     data-species="@(item.PlantaMadre?.Especie?.NombreCientifico ?? "")"
                     data-medio="@(item.MedioCultivo?.Siglas ?? "")">
                    <div class="figma-card">
                        <div>   
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="w-10 h-10 rounded-3 bg-blue-50 text-blue-600 d-flex align-items-center justify-content-center shrink-0" style="width: 40px; height: 40px;">
                                        <i class="bi bi-grid" style="font-size: 1.25rem;"></i>
                                    </div>
                                    <div>
                                        <h3 class="h6 font-mono font-bold text-dark mb-1">@item.CodigoTrazabilidad</h3>
                                        <p class="text-xs text-muted mb-0">
                                            @(item.PlantaMadre?.Especie?.NombreCientifico ?? "Sin Especie") 
                                            · PM: @(item.PlantaMadre?.CodigoAsignado ?? "N/A")
                                        </p>
                                    </div>
                                </div>
                                @{
                                    var faseClass = "badge-fase-introduccion";
                                    var fase = item.FaseCultivo?.NombreFase?.ToLower() ?? "";
                                    if (fase.Contains("multipli")) faseClass = "badge-fase-multiplicacion";
                                    else if (fase.Contains("enraiza")) faseClass = "badge-fase-enraizamiento";
                                    else if (fase.Contains("aclima")) faseClass = "badge-fase-aclimatacion";
                                    else if (fase.Contains("conserva")) faseClass = "badge-fase-conservacion";
                                }
                                <span class="badge-fase @faseClass">@(item.FaseCultivo?.NombreFase ?? "Introducción")</span>
                            </div>

                            <div class="meta-grid">
                                <div class="meta-item">
                                    <p class="meta-title">Repique #</p>
                                    <p class="meta-val">@item.NumeroRepique</p>
                                </div>
                                <div class="meta-item">
                                    <p class="meta-title">Fecha Siembra</p>
                                    <p class="meta-val">@item.FechaSiembra.ToShortDateString()</p>
                                </div>
                                <div class="meta-item">
                                    <p class="meta-title">Ubicación Física</p>
                                    <p class="meta-val">@(item.UbicacionFisica?.NombreCuerpo ?? "N/A") · Piso @(item.UbicacionFisica?.NumeroPiso ?? 0)</p>
                                </div>
                                <div class="meta-item">
                                    <p class="meta-title">Medio Cultivo</p>
                                    <p class="meta-val">@(item.MedioCultivo?.Siglas ?? "N/A")</p>
                                </div>
                                <div class="meta-item">
                                    <p class="meta-title">Explante</p>
                                    <p class="meta-val">@(string.IsNullOrEmpty(item.TipoExplante) ? "N/A" : item.TipoExplante)</p>
                                </div>
                                <div class="meta-item">
                                    <p class="meta-title">Cant. Explantes</p>
                                    <p class="meta-val">@(item.ExplantesPorUnidad) / frasco</p>
                                </div>
                                <div class="meta-item" style="grid-column: span 2;">
                                    <div class="d-flex align-items-center justify-content-between mt-2 pt-2 border-top" style="border-color: #f3f4f6 !important;">
                                        <span class="badge-tipo">@(item.DocumentoProtocolo != null ? item.DocumentoProtocolo.Titulo : "Sin Protocolo")</span>
                                        <span class="text-xs text-muted">Proyecto: @(item.Proyecto?.NombreProyecto ?? "General")</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="card-actions">
                            <a asp-action="Details" asp-route-id="@item.Id" class="action-link">
                                <i class="bi bi-eye"></i> Detalles
                            </a>
                            @if (User.IsInRole("Tecnico") || User.IsInRole("Coordinador"))
                            {
                                @if (item.NumeroRepique < 10)
                                {
                                    <a asp-action="Resiembra" asp-route-id="@item.Id" class="action-link" style="color: #0d6efd;">
                                        <i class="bi bi-diagram-3"></i> Sub-Lote (Resiembra)
                                    </a>
                                }
                                <a asp-action="Edit" asp-route-id="@item.Id" class="action-link">
                                    <i class="bi bi-pencil"></i> Editar
                                </a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline ms-auto">
                                    <button type="submit" class="action-link action-link-delete border-0 bg-transparent" onclick="return confirm('¿Está seguro de eliminar este lote?');">
                                        <i class="bi bi-trash3"></i> Eliminar
                                    </button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted mb-3 d-block"></i>
                <p class="text-muted">No se encontraron lotes de cultivo registrados.</p>
            </div>
        }
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const searchInput = document.getElementById("searchInput");
        const cards = document.querySelectorAll(".lote-card-wrapper");

        searchInput.addEventListener("input", function (e) {
            const query = e.target.value.toLowerCase().trim();

            cards.forEach(card => {
                const code = card.getAttribute("data-code").toLowerCase();
                const species = card.getAttribute("data-species").toLowerCase();
                const medio = card.getAttribute("data-medio").toLowerCase();

                if (code.includes(query) || species.includes(query) || medio.includes(query)) {
                    card.style.display = "";
                } else {
                    card.style.display = "none";
                }
            });
        });
    });
</script>

