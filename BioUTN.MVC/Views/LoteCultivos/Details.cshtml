@model BioUTN.Modelos.LoteCultivo

@{
    ViewData["Title"] = "Detalles del Lote de Cultivo";
}

@section Styles {
<style>
    .figma-container { font-family: 'Inter', -apple-system, sans-serif; background-color: #f9fafb; padding: 20px; border-radius: 12px; }
    .figma-card { background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 0.75rem; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); padding: 1.5rem; }
    .figma-title { font-size: 1.125rem; font-weight: 700; color: #111827; margin-bottom: 1rem; border-bottom: 1px solid #f3f4f6; padding-bottom: 0.5rem; }
    .detail-label { font-size: 13px; font-weight: 600; color: #6b7280; text-transform: uppercase; letter-spacing: 0.025em; margin-bottom: 0.25rem; }
    .detail-value { font-size: 14px; font-weight: 500; color: #111827; margin-bottom: 1.25rem; }
    .badge-status { display: inline-block; padding: 0.25rem 0.75rem; font-size: 12px; font-weight: 600; border-radius: 9999px; background-color: #d1fae5; color: #065f46; }
    .figma-btn-secondary { background-color: white; color: #374151; border: 1px solid #e5e7eb; padding: 0.5rem 1rem; border-radius: 0.5rem; font-size: 14px; font-weight: 500; transition: all 0.2s; text-decoration: none; display: inline-block; }
    .figma-btn-secondary:hover { background-color: #f9fafb; color: #111827; }
    .figma-btn-primary { background-color: #10b981; color: white; border: none; padding: 0.5rem 1rem; border-radius: 0.5rem; font-size: 14px; font-weight: 500; transition: all 0.2s; text-decoration: none; display: inline-block; }
    .figma-btn-primary:hover { background-color: #059669; color: white; }
</style>
}

<div class="figma-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 style="font-weight: 700; color: #111827; font-size: 20px; margin-bottom: 0;">Lote de Cultivo: @Model.CodigoTrazabilidad</h3>
            <p class="text-muted mb-0" style="font-size: 13px;">Información detallada del lote en curso</p>
        </div>
        <div class="gap-2 d-flex">
            <a asp-action="Index" class="figma-btn-secondary">Volver al listado</a>
            @if (Model.NumeroRepique < 10)
            {
                <a asp-action="Resiembra" asp-route-id="@Model.Id" class="figma-btn-secondary" style="color: #0d6efd;">
                    <i class="bi bi-diagram-3-fill me-1"></i> Resiembra
                </a>
            }
            <a asp-action="Edit" asp-route-id="@Model.Id" class="figma-btn-primary">
                <i class="bi bi-pencil-square me-1"></i> Editar Lote
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="figma-card h-100">
                <h4 class="figma-title">Información Principal</h4>
                
                <div class="row">
                    <div class="col-6">
                        <div class="detail-label">Código de Trazabilidad</div>
                        <div class="detail-value">@Model.CodigoTrazabilidad</div>
                    </div>
                    <div class="col-6">
                        <div class="detail-label">Estado del Lote</div>
                        <div class="detail-value">
                            <span class="badge-status" style="@(Model.Activo ? "" : "background-color: #fee2e2; color: #991b1b;")">@(Model.Activo ? "Activo" : "Inactivo")</span>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-4">
                        <div class="detail-label">Planta Madre (Origen)</div>
                        <div class="detail-value">@(Model.PlantaMadre?.CodigoAsignado ?? "N/A")</div>
                    </div>
                    <div class="col-4">
                        <div class="detail-label">Lote Padre (Resiembra)</div>
                        <div class="detail-value">@(Model.IdLotePadre.HasValue ? Model.IdLotePadre.Value.ToString() : "N/A")</div>
                    </div>
                    <div class="col-4">
                        <div class="detail-label">Frasco Origen</div>
                        <div class="detail-value">@(Model.UnidadFrascoOrigen?.CodigoUnidad ?? "N/A")</div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-6">
                        <div class="detail-label">Fase de Cultivo</div>
                        <div class="detail-value">@(Model.FaseCultivo?.NombreFase ?? "N/A")</div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-6">
                        <div class="detail-label">Total Frascos/Unidades</div>
                        <div class="detail-value">@Model.TotalUnidades unidades</div>
                    </div>
                    <div class="col-6">
                        <div class="detail-label">Técnico Responsable</div>
                        <div class="detail-value">@(Model.Usuario?.Nombres ?? "N/A") @(Model.Usuario?.Apellidos)</div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-12">
                        <div class="detail-label">Proyecto Asociado</div>
                        <div class="detail-value">@(Model.Proyecto?.NombreProyecto ?? "N/A")</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="figma-card h-100">
                <h4 class="figma-title">Fechas y Condiciones In-Vitro</h4>
                
                <div class="row">
                    <div class="col-6">
                        <div class="detail-label">Fecha de Siembra</div>
                        <div class="detail-value">@Model.FechaSiembra.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="col-6">
                        <div class="detail-label">Fecha Est. Repique (30 días)</div>
                        <div class="detail-value">
                            @Model.FechaSiembra.AddDays(30).ToString("dd/MM/yyyy")
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-6">
                        <div class="detail-label">Número de Repique</div>
                        <div class="detail-value">@Model.NumeroRepique</div>
                    </div>
                    <div class="col-6">
                        <div class="detail-label">Ubicación Física</div>
                        <div class="detail-value">
                            @(Model.UbicacionFisica?.NombreCuerpo ?? "N/A") - Piso @(Model.UbicacionFisica?.NumeroPiso ?? 0)
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-6">
                        <div class="detail-label">Medio de Cultivo</div>
                        <div class="detail-value">@(Model.MedioCultivo?.Descripcion ?? "N/A") (@(Model.MedioCultivo?.Siglas))</div>
                    </div>
                    <div class="col-6">
                        <div class="detail-label">Protocolo / Biblioteca</div>
                        <div class="detail-value">@(Model.DocumentoProtocolo?.Titulo ?? "Sin protocolo adjunto")</div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-6">
                        <div class="detail-label">Tipo de Explante</div>
                        <div class="detail-value">@(string.IsNullOrEmpty(Model.TipoExplante) ? "N/A" : Model.TipoExplante)</div>
                    </div>
                    <div class="col-6">
                        <div class="detail-label">Explantes por Frasco</div>
                        <div class="detail-value">@Model.ExplantesPorUnidad explantes</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="figma-card">
                <h4 class="figma-title">Checklist de Siembra</h4>
                <div class="detail-value mb-0" style="white-space: pre-line;">
                    @(string.IsNullOrEmpty(Model.ChecklistSiembra) ? "Sin checklist registrado." : Model.ChecklistSiembra)
                </div>
            </div>
        </div>
    </div>
</div>
