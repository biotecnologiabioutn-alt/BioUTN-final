@{
    ViewData["Title"] = "Cuaderno de Laboratorio";
}

@section Styles {
<style>
    .notebook-container {
        display: flex;
        gap: 1.5rem;
        height: 70vh;
    }
    
    .lote-sidebar {
        width: 300px;
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 16px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }
    .lote-sidebar-header {
        padding: 1.2rem;
        border-bottom: 1px solid rgba(255,255,255,0.06);
        background: rgba(0,0,0,0.2);
    }
    .lote-list {
        flex: 1;
        overflow-y: auto;
        padding: 0.5rem;
    }
    .lote-item {
        padding: 0.8rem 1rem;
        border-radius: 10px;
        cursor: pointer;
        transition: all 0.2s;
        margin-bottom: 0.25rem;
        border: 1px solid transparent;
    }
    .lote-item:hover {
        background: rgba(255,255,255,0.04);
    }
    .lote-item.active {
        background: rgba(102,16,242,0.1);
        border-color: rgba(102,16,242,0.3);
    }
    
    .notebook-main {
        flex: 1;
        background: #0e1e2d;
        border: 1px solid rgba(32,201,151,0.2);
        border-radius: 16px;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }
    
    .notebook-header {
        padding: 1.5rem;
        border-bottom: 1px solid rgba(32,201,151,0.15);
        background: linear-gradient(90deg, rgba(32,201,151,0.05), transparent);
    }
    
    .notebook-content {
        flex: 1;
        overflow-y: auto;
        padding: 1.5rem;
        background-image: 
            linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px);
        background-size: 100% 28px;
        line-height: 28px;
        font-family: 'Segoe UI', system-ui, sans-serif;
    }
    
    .entry-date {
        font-size: 0.75rem;
        color: #20c997;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.5rem;
        margin-top: 1.5rem;
    }
    .entry-date:first-child { margin-top: 0; }
    
    .entry-text {
        color: rgba(255,255,255,0.85);
        font-size: 0.95rem;
        margin-bottom: 0.5rem;
    }
    
    .entry-attachment {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(255,255,255,0.1);
        padding: 0.3rem 0.8rem;
        border-radius: 20px;
        font-size: 0.75rem;
        color: #0dcaf0;
        cursor: pointer;
    }
    
    .notebook-editor {
        padding: 1rem 1.5rem;
        border-top: 1px solid rgba(255,255,255,0.06);
        background: rgba(0,0,0,0.2);
    }
    
    .editor-textarea {
        width: 100%;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.1);
        border-radius: 12px;
        
        padding: 0.75rem 1rem;
        resize: none;
        outline: none;
        transition: all 0.3s;
    }
    .editor-textarea:focus {
        border-color: #20c997;
        background: rgba(255,255,255,0.06);
    }
</style>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="bioutn-title mb-0"><i class="bi bi-journal-text text-success me-2"></i>Cuaderno Digital</h2>
        <p class="bioutn-subtitle mt-1">"Si no está anotado, el experimento no existe." — Registro diario para tu tesis.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-controller="Home" asp-action="Index" class="btn bioutn-btn bioutn-btn-secondary shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Volver
        </a>
    </div>
</div>

<div class="notebook-container">
    
    <!-- Sidebar Lotes -->
    <div class="lote-sidebar">
        <div class="lote-sidebar-header">
            <h6 class="text-dark fw-bold mb-0">Mis Cultivos</h6>
            <div class="text-muted small" style="font-size:0.7rem;">Selecciona un lote para anotar</div>
        </div>
        <div class="lote-list">
            <div class="lote-item active">
                <div class="d-flex justify-content-between mb-1">
                    <span class="text-dark small fw-bold" style="font-family:'Courier New';">C-NUB-PM1-F20-R3-MS1</span>
                </div>
                <div class="text-muted" style="font-size:0.75rem;">Clinopodium nubigenum</div>
            </div>
            <div class="lote-item">
                <div class="d-flex justify-content-between mb-1">
                    <span class="text-dark small fw-bold" style="font-family:'Courier New';">ORC-SP-PM3-F05-R2-MS3</span>
                </div>
                <div class="text-muted" style="font-size:0.75rem;">Orquídea sp. (Carchi)</div>
            </div>
            <div class="lote-item border-danger" style="border-style:dashed;">
                <div class="d-flex justify-content-between mb-1">
                    <span class="text-danger small fw-bold" style="font-family:'Courier New';">FRZ-PM2-F15-R3-MS2</span>
                </div>
                <div class="text-danger" style="font-size:0.75rem;">Fresa — Contaminado</div>
            </div>
        </div>
    </div>

    <!-- Notebook Editor -->
    <div class="notebook-main">
        <div class="notebook-header">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h5 class="text-dark fw-bold mb-1" style="font-family:'Courier New'; color:#20c997 !important;">C-NUB-PM1-F20-R3-MS1</h5>
                    <div class="text-muted small">Proyecto: Conservación Germoplasma UTN</div>
                </div>
                <span class="badge bg-success bg-opacity-25 text-success"><i class="bi bi-clock-history me-1"></i>Última nota: Hoy</span>
            </div>
        </div>
        
        <div class="notebook-content">
            <div class="entry-date">Hace 5 días — 08 Jul 2026, 10:30 AM</div>
            <div class="entry-text">
                Realicé la resiembra R3. Los brotes presentan un color verde intenso, sin signos de clorosis. 
                Utilicé medio MS1 sin reguladores de crecimiento adicionales ya que la multiplicación anterior fue vigorosa.
            </div>
            <div class="entry-attachment">
                <i class="bi bi-camera"></i> foto_cultivo_r3.jpg
            </div>

            <div class="entry-date">Hace 2 días — 11 Jul 2026, 09:15 AM</div>
            <div class="entry-text">
                Monitoreo de rutina. Crecimiento normal. 0 frascos contaminados. Se observa ligero inicio de enraizamiento en 3 de los 20 frascos.
            </div>

            <div class="entry-date">Hoy — 13 Jul 2026, 14:00 PM</div>
            <div class="entry-text">
                La tasa de crecimiento es óptima. Planeo evaluar si en la próxima resiembra (R4) aplico BAP para inducir mayor brotación lateral. 
                Temperatura del cuarto estable a 23°C.
            </div>
        </div>
        
        <div class="notebook-editor">
            <form action="javascript:void(0)" class="d-flex gap-3 align-items-end">
                <div class="flex-grow-1">
                    <label class="text-muted small mb-2 fw-bold text-uppercase">Nueva Observación (13 Jul)</label>
                    <textarea class="editor-textarea" rows="2" placeholder="Escribe aquí tus observaciones del día..."></textarea>
                </div>
                <div class="d-flex flex-column gap-2">
                    <button type="button" class="btn btn-sm btn-outline-info rounded-circle" style="width:36px; height:36px;" title="Adjuntar Foto">
                        <i class="bi bi-camera"></i>
                    </button>
                    <button type="submit" class="btn btn-sm bioutn-btn-primary rounded-circle" style="width:36px; height:36px;" title="Guardar">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    document.querySelectorAll('.lote-item').forEach(item => {
        item.addEventListener('click', function() {
            document.querySelectorAll('.lote-item').forEach(i => i.classList.remove('active'));
            this.classList.add('active');
            // En la versión final, aquí se haría un fetch a la API para cargar las notas del lote seleccionado
        });
    });
</script>
}
