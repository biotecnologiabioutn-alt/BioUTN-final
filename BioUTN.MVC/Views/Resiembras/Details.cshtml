@model BioUTN.Modelos.LoteCultivo

@{
    ViewData["Title"] = "Detalles de Resiembra";
}

@section Styles {
<style>
    .figma-container { font-family: 'Inter', -apple-system, sans-serif; background-color: #f9fafb; padding: 20px; border-radius: 12px; }
    .figma-card { background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 0.75rem; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); padding: 1.5rem; }
    .figma-title { font-size: 1.125rem; font-weight: 700; color: #111827; margin-bottom: 1rem; border-bottom: 1px solid #f3f4f6; padding-bottom: 0.5rem; }
    .detail-label { font-size: 13px; font-weight: 600; color: #6b7280; text-transform: uppercase; letter-spacing: 0.025em; margin-bottom: 0.25rem; }
    .detail-value { font-size: 14px; font-weight: 500; color: #111827; margin-bottom: 1.25rem; }
    .figma-btn-secondary { background-color: white; color: #374151; border: 1px solid #e5e7eb; padding: 0.5rem 1rem; border-radius: 0.5rem; font-size: 14px; font-weight: 500; transition: all 0.2s; text-decoration: none; display: inline-block; }
    .figma-btn-secondary:hover { background-color: #f9fafb; color: #111827; }
</style>
}

<div class="figma-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 style="font-weight: 700; color: #111827; font-size: 20px; margin-bottom: 0;">Detalles de Resiembra</h3>
        </div>
        <div class="gap-2 d-flex">
            <a asp-action="Index" class="figma-btn-secondary">Volver al listado</a>
            <a asp-controller="LoteCultivos" asp-action="Details" asp-route-id="@Model.Id" class="figma-btn-secondary" style="color: #059669;">
                <i class="bi bi-box-seam me-1"></i> Ir al Lote Original
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-6">
            <div class="figma-card h-100">
                <h4 class="figma-title">Origen e Identificación</h4>
                
                <div class="row">
                    <div class="col-6">
                        <div class="detail-label">Lote Padre</div>
                        <div class="detail-value">@(Model.LotePadre?.CodigoTrazabilidad ?? "N/A")</div>
                    </div>
                    <div class="col-6">
                        <div class="detail-label">Frasco Origen</div>
                        <div class="detail-value">@(Model.UnidadFrascoOrigen?.CodigoUnidad ?? "No especificado")</div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-12">
                        <div class="detail-label">Código Autogenerado de esta Resiembra</div>
                        <div class="detail-value" style="font-size: 16px; font-weight: 700; color: #111827; background: #f3f4f6; padding: 8px; border-radius: 6px; display: inline-block;">
                            @Model.CodigoTrazabilidad
                        </div>
                    </div>
                </div>
                
                <div class="row mt-2">
                    <div class="col-6">
                        <div class="detail-label">Nº de Repique</div>
                        <div class="detail-value"><span class="badge bg-warning bg-opacity-25 text-warning" style="font-size: 13px;">R@(Model.NumeroRepique)</span></div>
                    </div>
                    <div class="col-6">
                        <div class="detail-label">Responsable</div>
                        <div class="detail-value">@(Model.Usuario?.Nombres ?? "N/A")</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="figma-card h-100">
                <h4 class="figma-title">Cuantificación y Técnica</h4>
                
                <div class="row">
                    <div class="col-6">
                        <div class="detail-label">Fecha de Resiembra</div>
                        <div class="detail-value">@Model.FechaSiembra.ToString("dd/MM/yyyy")</div>
                    </div>
                    <div class="col-6">
                        <div class="detail-label">Nuevas Unidades Generadas</div>
                        <div class="detail-value">@Model.TotalUnidades frascos</div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-6">
                        <div class="detail-label">Explantes por Frasco</div>
                        <div class="detail-value">@Model.ExplantesPorUnidad</div>
                    </div>
                    <div class="col-6">
                        <div class="detail-label">Protocolo Utilizado</div>
                        <div class="detail-value">@(Model.DocumentoProtocolo?.Titulo ?? "Ninguno")</div>
                    </div>
                </div>
                
                <div class="row">
                    <div class="col-6">
                        <div class="detail-label">Medio de Cultivo</div>
                        <div class="detail-value">@(Model.MedioCultivo?.Siglas ?? "N/A")</div>
                    </div>
                    <div class="col-6">
                        <div class="detail-label">Anaquel</div>
                        <div class="detail-value">@(Model.UbicacionFisica?.CodigoAnaquel ?? "N/A")</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
