@model IEnumerable<BioUTN.MVC.Models.UsuarioViewModel>
@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="mb-0 text-dark">Directorio de Usuarios</h5>
        <button class="btn btn-primary-utn" data-bs-toggle="modal" data-bs-target="#newUserModal">
            <i class="fas fa-plus"></i> Nuevo
        </button>
    </div>

    <div class="table-responsive bg-white rounded shadow-sm">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nombres</th>
                    <th>Correo</th>
                    <th>Rol</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr style="cursor: pointer;" onclick="abrirModalEdicion('@user.Nombres @user.Apellidos', '@user.Correo', '@user.Rol', '@user.Estado')">
                        <td class="p-3">
                            <div class="fw-bold" style="font-size: var(--fs-body); color: var(--text-main);">@user.Nombres @user.Apellidos</div>
                            <small class="text-muted" style="font-size: var(--fs-small);">C.I: @user.Id</small>
                        </td>
                        <td class="p-3 align-middle" style="font-size: var(--fs-body);">@user.Correo</td>
                        <td class="p-3 align-middle">
                            <span class="badge @(user.Rol == "Docente" ? "badge-docencia" : user.Rol == "Tesista" ? "badge-tesis" : "bg-secondary")">@user.Rol</span>
                        </td>
                        <td class="p-3 align-middle">
                            @if(user.Estado == "Activo")
                            {
                                <span class="badge bg-success bg-opacity-10 text-success border border-success"><i class="fas fa-check-circle"></i> Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-danger bg-opacity-10 text-danger border border-danger"><i class="fas fa-times-circle"></i> Inactivo</span>
                            }
                        </td>
                        <td class="p-3 align-middle text-end">
                            <button class="btn btn-sm btn-outline-danger" onclick="event.stopPropagation(); confirmarInactivacion('@user.Nombres');">
                                <i class="fas fa-user-slash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Nuevo Usuario -->
<div class="modal fade" id="newUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0 bg-light">
                <h5 class="modal-title fw-bold"><i class="fas fa-user-plus text-success"></i> Alta de Usuario</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form id="newUserForm" onsubmit="return validateEmail(event, 'emailInput', 'emailError', 'newUserModal')">
                    <div class="mb-3">
                        <label class="form-label text-muted text-uppercase small fw-bold">Nombres</label>
                        <input type="text" class="form-control form-control-lg bg-light border-0" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted text-uppercase small fw-bold">Apellidos</label>
                        <input type="text" class="form-control form-control-lg bg-light border-0" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted text-uppercase small fw-bold">Correo Institucional</label>
                        <input type="email" id="emailInput" class="form-control form-control-lg bg-light border-0" placeholder="@@utn.edu.ec" required>
                        <div id="emailError" class="text-danger small mt-1 d-none"><i class="fas fa-exclamation-circle"></i> No se permiten correos personales (gmail/hotmail).</div>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label text-muted text-uppercase small fw-bold">Rol</label>
                            <select class="form-select form-select-lg bg-light border-0">
                                <option>Técnico</option>
                                <option>Tesista</option>
                                <option>Docente</option>
                                <option>Estudiante</option>
                            </select>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label text-muted text-uppercase small fw-bold">Semestre</label>
                            <select class="form-select form-select-lg bg-light border-0">
                                <option>1er Nivel</option>
                                <option>Egresado</option>
                            </select>
                        </div>
                    </div>
                    <div class="mt-4 pt-3 border-top text-end">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary-utn px-4"><i class="fas fa-save"></i> Guardar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- Modal Editar Usuario -->
<div class="modal fade" id="editUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header border-bottom-0 bg-light">
                <h5 class="modal-title fw-bold"><i class="fas fa-user-edit text-primary"></i> Editar Usuario</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form id="editUserForm" onsubmit="return validateEmail(event, 'editEmailInput', 'editEmailError', 'editUserModal')">
                    <div class="mb-3">
                        <label class="form-label text-muted text-uppercase small fw-bold">Nombre Completo</label>
                        <input type="text" id="editNombre" class="form-control form-control-lg bg-light border-0" disabled>
                    </div>
                    <div class="mb-3">
                        <label class="form-label text-muted text-uppercase small fw-bold">Correo Institucional</label>
                        <input type="email" id="editEmailInput" class="form-control form-control-lg bg-light border-0" required>
                        <div id="editEmailError" class="text-danger small mt-1 d-none"><i class="fas fa-exclamation-circle"></i> No se permiten correos personales.</div>
                    </div>
                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label text-muted text-uppercase small fw-bold">Rol</label>
                            <select id="editRol" class="form-select form-select-lg bg-light border-0">
                                <option value="Técnico">Técnico</option>
                                <option value="Tesista">Tesista</option>
                                <option value="Docente">Docente</option>
                                <option value="Estudiante">Estudiante</option>
                            </select>
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label text-muted text-uppercase small fw-bold">Estado</label>
                            <select id="editEstado" class="form-select form-select-lg bg-light border-0">
                                <option value="Activo">Activo</option>
                                <option value="Inactivo">Inactivo</option>
                            </select>
                        </div>
                    </div>
                    <div class="mt-4 pt-3 border-top text-end">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancelar</button>
                        <button type="submit" class="btn btn-primary px-4"><i class="fas fa-sync"></i> Actualizar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<!-- LEY DE FITTS / VELOCIDAD-PRECISIÓN: Toast de Undo (Soft-Delete) -->
<div id="undoToastAdmin" class="fixed-bottom w-100 d-flex justify-content-center p-3" style="z-index: 2000; bottom: 20px !important; display: none !important; pointer-events: none;">
    <div class="bg-light text-dark px-4 py-3 rounded shadow-lg d-flex justify-content-between align-items-center w-100" style="max-width: 450px; pointer-events: auto;">
        <span id="undoMessageAdmin">Usuario inactivado exitosamente.</span>
        <button class="btn btn-link text-warning fw-bold text-uppercase text-decoration-none p-0 ms-3" onclick="deshacerInactivacion()">
            Deshacer
        </button>
    </div>
</div>

@section Scripts {
    <script>
        // Ley de Proximidad y Fitts en formularios
        function abrirModalEdicion(nombre, correo, rol, estado) {
            document.getElementById('editNombre').value = nombre;
            document.getElementById('editEmailInput').value = correo;
            document.getElementById('editRol').value = rol;
            document.getElementById('editEstado').value = estado;
            
            var myModal = new bootstrap.Modal(document.getElementById('editUserModal'));
            myModal.show();
        }

        function validateEmail(e, inputId, errorId, modalId) {
            e.preventDefault();
            const email = document.getElementById(inputId).value.toLowerCase();
            const errorDiv = document.getElementById(errorId);
            
            if(email.includes('@@gmail.com') || email.includes('@@hotmail.com')) {
                errorDiv.classList.remove('d-none');
                return false;
            }
            errorDiv.classList.add('d-none');
            alert("Acción guardada correctamente con validación de seguridad.");
            
            // Cerrar modal
            var modal = bootstrap.Modal.getInstance(document.getElementById(modalId));
            modal.hide();
            return true;
        }

        // Soft Delete con Undo (Tolerancia al error)
        let undoTimeout;
        function confirmarInactivacion(nombre) {
            const toast = document.getElementById('undoToastAdmin');
            document.getElementById('undoMessageAdmin').innerText = `El usuario ${nombre} ha sido marcado como Inactivo.`;
            toast.style.setProperty('display', 'flex', 'important');
            
            clearTimeout(undoTimeout);
            undoTimeout = setTimeout(() => {
                toast.style.setProperty('display', 'none', 'important');
            }, 5000);
        }

        function deshacerInactivacion() {
            document.getElementById('undoToastAdmin').style.setProperty('display', 'none', 'important');
            alert("Operación de inactivación cancelada (Undo).");
        }
    </script>
}
