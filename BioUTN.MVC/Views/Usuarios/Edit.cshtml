@model BioUTN.Modelos.Usuario

@{
    ViewData["Title"] = "Editar Usuario";
}

@section Styles {
<style>
    body { background-color: #f9fafb; font-family: 'Inter', -apple-system, sans-serif; }
    .figma-container { padding: 40px 20px; max-width: 800px; margin: 0 auto; }
    .figma-header { margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: flex-end; }
    .figma-title { font-size: 24px; font-weight: 700; color: #111827; margin-bottom: 0.25rem; }
    .figma-subtitle { font-size: 14px; color: #6b7280; }
    
    .figma-btn-secondary { background-color: white; color: #374151; border: 1px solid #e5e7eb; padding: 0.5rem 1rem; border-radius: 8px; font-size: 14px; font-weight: 500; transition: all 0.2s; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; }
    .figma-btn-secondary:hover { background-color: #f9fafb; color: #111827; }
    .figma-btn-primary { background-color: #3b82f6; color: white; border: none; padding: 0.5rem 1.5rem; border-radius: 8px; font-size: 14px; font-weight: 500; transition: all 0.2s; }
    .figma-btn-primary:hover { background-color: #2563eb; }
    
    .figma-card { background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 2rem; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); }
    .figma-label { font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 0.5rem; display: block; }
    .figma-input { width: 100%; padding: 0.625rem 0.75rem; border-radius: 0.5rem; border: 1px solid #e5e7eb; font-size: 14px; color: #111827; outline: none; transition: all 0.2s; }
    .figma-input:focus { border-color: rgba(59, 130, 246, 0.6); box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2); }
    .figma-checkbox { margin-right: 0.5rem; transform: translateY(1px); }
</style>
}

<div class="figma-container">
    <div class="figma-header">
        <div>
            <h1 class="figma-title">Editar Usuario</h1>
            <p class="figma-subtitle">Actualizar información y permisos del usuario</p>
        </div>
        <div>
            <a asp-action="Index" class="figma-btn-secondary">
                <i class="bi bi-arrow-left"></i> Cancelar
            </a>
        </div>
    </div>

    <div class="figma-card">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 13px;"></div>
            <input type="hidden" asp-for="Id" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Nombres" class="figma-label">Nombres *</label>
                    <input asp-for="Nombres" class="figma-input" required />
                    <span asp-validation-for="Nombres" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Apellidos" class="figma-label">Apellidos *</label>
                    <input asp-for="Apellidos" class="figma-input" required />
                    <span asp-validation-for="Apellidos" class="text-danger small mt-1 d-block"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="IdTipoIdentificacion" class="figma-label">Tipo de Identificación *</label>
                    <select asp-for="IdTipoIdentificacion" class="figma-input form-select" asp-items="ViewBag.TiposIdentificacion" required></select>
                    <span asp-validation-for="IdTipoIdentificacion" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="NumeroIdentificacion" class="figma-label">Número de Identificación *</label>
                    <input asp-for="NumeroIdentificacion" class="figma-input" required />
                    <span asp-validation-for="NumeroIdentificacion" class="text-danger small mt-1 d-block"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Email" class="figma-label">Correo Electrónico *</label>
                    <input asp-for="Email" type="email" class="figma-input" required />
                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="Telefono" class="figma-label">Teléfono</label>
                    <input asp-for="Telefono" class="figma-input" />
                    <span asp-validation-for="Telefono" class="text-danger small mt-1 d-block"></span>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="IdRol" class="figma-label">Rol del Sistema *</label>
                    <select asp-for="IdRol" class="figma-input form-select" asp-items="ViewBag.Roles" required></select>
                    <span asp-validation-for="IdRol" class="text-danger small mt-1 d-block"></span>
                </div>
                <div class="col-md-6 mb-3">
                    <label asp-for="IdGenero" class="figma-label">Género *</label>
                    <select asp-for="IdGenero" class="figma-input form-select" asp-items="ViewBag.Generos" required></select>
                    <span asp-validation-for="IdGenero" class="text-danger small mt-1 d-block"></span>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="ContrasenaHash" class="figma-label">Contraseña de Acceso</label>
                <input asp-for="ContrasenaHash" type="password" class="figma-input" />
                <p style="font-size: 11px; color: #9ca3af; margin-top: 4px;">Modifica este campo solo si deseas restablecer la contraseña.</p>
                <span asp-validation-for="ContrasenaHash" class="text-danger small mt-1 d-block"></span>
            </div>
            
            <div class="row p-3 mb-4 rounded" style="background-color: #f9fafb; border: 1px solid #e5e7eb;">
                <div class="col-12 mb-2">
                    <p style="font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 8px;">Estado y Seguridad de la Cuenta</p>
                </div>
                <div class="col-md-4 mb-2">
                    <label class="d-flex align-items-center" style="font-size: 14px; cursor: pointer;">
                        <input asp-for="Activo" type="checkbox" class="figma-checkbox" />
                        Cuenta Activa
                    </label>
                </div>
                <div class="col-md-4 mb-2">
                    <label class="d-flex align-items-center" style="font-size: 14px; cursor: pointer;">
                        <input asp-for="CuentaBloqueada" type="checkbox" class="figma-checkbox" />
                        Cuenta Bloqueada
                    </label>
                </div>
                <div class="col-md-4">
                    <label asp-for="IntentosFallidos" style="font-size: 12px; color: #6b7280;" class="mb-1 d-block">Intentos Fallidos (Reset = 0)</label>
                    <input asp-for="IntentosFallidos" type="number" class="figma-input py-1" style="max-width: 100px;" />
                </div>
            </div>

            <div class="d-flex justify-content-end gap-2 mt-2">
                <button type="button" id="btnGuardar" class="figma-btn-primary">Guardar Cambios</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.getElementById('btnGuardar').addEventListener('click', function (e) {
            e.preventDefault();
            
            var form = this.closest('form');
            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }

            Swal.fire({
                title: '¿Guardar Cambios?',
                text: "Se actualizará la información del usuario en el sistema.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#3b82f6',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Sí, Guardar',
                cancelButtonText: 'Revisar'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            })
        });
    </script>
}
