@model BioUTN.Modelos.Usuario

@{
    ViewData["Title"] = "Perfil de Usuario";
}

@section Styles {
<style>
    body { background-color: #f9fafb; font-family: 'Inter', -apple-system, sans-serif; }
    .figma-container { padding: 40px 20px; max-width: 800px; margin: 0 auto; }
    
    .profile-header {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        border-radius: 16px 16px 0 0;
        height: 120px;
        position: relative;
    }
    
    .profile-card {
        background-color: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 16px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
        margin-top: -60px;
        padding: 0 2rem 2rem 2rem;
        position: relative;
    }
    
    .profile-avatar {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background-color: #f3f4f6;
        border: 4px solid #ffffff;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        color: #9ca3af;
        margin-top: -50px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }
    
    .profile-name { font-size: 24px; font-weight: 700; color: #111827; margin-top: 1rem; margin-bottom: 0.25rem; }
    .profile-role { font-size: 14px; color: #6b7280; font-weight: 500; }
    
    .info-group { margin-bottom: 1.5rem; }
    .info-label { font-size: 12px; font-weight: 600; color: #6b7280; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 0.25rem; display: block; }
    .info-value { font-size: 14px; color: #111827; font-weight: 500; }
    
    .badge-status { padding: 4px 12px; border-radius: 9999px; font-size: 12px; font-weight: 600; display: inline-flex; align-items: center; gap: 4px; }
    .status-active { background-color: #d1fae5; color: #065f46; }
    .status-inactive { background-color: #fee2e2; color: #991b1b; }
    
    .figma-btn-secondary { background-color: white; color: #374151; border: 1px solid #e5e7eb; padding: 0.5rem 1rem; border-radius: 8px; font-size: 14px; font-weight: 500; transition: all 0.2s; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; }
    .figma-btn-secondary:hover { background-color: #f9fafb; color: #111827; }
    .figma-btn-primary { background-color: #3b82f6; color: white; border: none; padding: 0.5rem 1.5rem; border-radius: 8px; font-size: 14px; font-weight: 500; transition: all 0.2s; text-decoration: none; display: inline-flex; align-items: center; gap: 0.5rem; }
    .figma-btn-primary:hover { background-color: #2563eb; color: white; }
    
    .divider { height: 1px; background-color: #e5e7eb; margin: 1.5rem 0; }
</style>
}

<div class="figma-container">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <a asp-action="Index" class="figma-btn-secondary">
            <i class="bi bi-arrow-left"></i> Volver al Directorio
        </a>
        <a asp-action="Edit" asp-route-id="@Model?.Id" class="figma-btn-primary">
            <i class="bi bi-pencil-square"></i> Editar Usuario
        </a>
    </div>

    <div>
        <div class="profile-header"></div>
        <div class="profile-card">
            <div class="d-flex justify-content-between align-items-start">
                <div class="profile-avatar">
                    <i class="bi bi-person-fill"></i>
                </div>
                <div class="mt-4 pt-2">
                    @if(Model.Activo && !Model.CuentaBloqueada)
                    {
                        <span class="badge-status status-active"><i class="bi bi-check-circle-fill"></i> Cuenta Activa</span>
                    }
                    else if(Model.CuentaBloqueada)
                    {
                        <span class="badge-status status-inactive"><i class="bi bi-lock-fill"></i> Cuenta Bloqueada</span>
                    }
                    else
                    {
                        <span class="badge-status status-inactive"><i class="bi bi-x-circle-fill"></i> Inactivo</span>
                    }
                </div>
            </div>

            <h1 class="profile-name">@Model.Nombres @Model.Apellidos</h1>
            <p class="profile-role">
                <i class="bi bi-shield-badge text-indigo-600 me-1"></i> @(Model.Rol?.NombreRol ?? "Sin Rol Asignado")
            </p>

            <div class="divider"></div>

            <div class="row">
                <div class="col-md-6">
                    <h5 class="mb-3" style="font-size: 14px; font-weight: 700; color: #374151;">Información Personal</h5>
                    
                    <div class="info-group">
                        <span class="info-label">Tipo de Identificación</span>
                        <span class="info-value">@(Model.TipoIdentificacion?.NombreTipo ?? "N/A")</span>
                    </div>
                    
                    <div class="info-group">
                        <span class="info-label">Número de Identificación</span>
                        <span class="info-value">@Model.NumeroIdentificacion</span>
                    </div>

                    <div class="info-group">
                        <span class="info-label">Género</span>
                        <span class="info-value">@(Model.Genero?.NombreGenero ?? "N/A")</span>
                    </div>
                </div>
                
                <div class="col-md-6">
                    <h5 class="mb-3" style="font-size: 14px; font-weight: 700; color: #374151;">Contacto y Acceso</h5>
                    
                    <div class="info-group">
                        <span class="info-label">Correo Electrónico</span>
                        <span class="info-value">
                            <a href="mailto:@Model.Email" class="text-decoration-none" style="color: #3b82f6;">@Model.Email</a>
                        </span>
                    </div>
                    
                    <div class="info-group">
                        <span class="info-label">Teléfono</span>
                        <span class="info-value">@(string.IsNullOrEmpty(Model.Telefono) ? "No registrado" : Model.Telefono)</span>
                    </div>

                    <div class="info-group">
                        <span class="info-label">Intentos Fallidos de Login</span>
                        <span class="info-value @(Model.IntentosFallidos > 0 ? "text-danger" : "")">
                            @Model.IntentosFallidos
                        </span>
                    </div>

                    <div class="info-group">
                        <span class="info-label">Contraseña</span>
                        <span class="info-value text-muted">
                            ******** (Encriptada)
                        </span>
                    </div>
                    
                    <div class="info-group">
                        <span class="info-label">ID del Sistema</span>
                        <span class="info-value text-muted">#@Model.Id</span>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
