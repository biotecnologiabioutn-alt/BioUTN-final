@model BioUTN.Modelos.Taxonomia

@{
    ViewData["Title"] = "Crear Taxonomía";
}

@section Styles {
<style>
    .figma-container { font-family: 'Inter', -apple-system, sans-serif; background-color: #f9fafb; padding: 20px; border-radius: 12px; }
    .figma-card { background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 0.75rem; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); padding: 1.5rem; }
    .figma-label { font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 0.5rem; display: block; }
    .figma-input { width: 100%; padding: 0.625rem 0.75rem; border-radius: 0.5rem; border: 1px solid #e5e7eb; font-size: 14px; color: #111827; outline: none; transition: all 0.2s; background-color: #ffffff; }
    .figma-input:focus { border-color: rgba(16, 185, 129, 0.6); box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.2); }
    .figma-btn-primary { background-color: #10b981; color: white; border: none; padding: 0.625rem 1.25rem; border-radius: 0.5rem; font-size: 14px; font-weight: 500; transition: all 0.2s; }
    .figma-btn-primary:hover { background-color: #059669; color: white; }
    .figma-btn-secondary { background-color: white; color: #374151; border: 1px solid #e5e7eb; padding: 0.625rem 1.25rem; border-radius: 0.5rem; font-size: 14px; font-weight: 500; transition: all 0.2s; text-decoration: none; display: inline-flex; align-items: center; }
    .figma-btn-secondary:hover { background-color: #f9fafb; color: #111827; }
    .section-label { font-size: 11px; text-transform: uppercase; letter-spacing: 0.05em; color: #6b7280; font-weight: 600; margin-bottom: 1rem; margin-top: 1.5rem; padding-bottom: 0.5rem; border-bottom: 1px solid #f3f4f6; }
</style>
}

<div class="figma-container">
    <div class="mb-4">
        <h3 style="font-weight: 700; color: #111827; font-size: 18px;">Nueva Taxonomía</h3>
        <p class="text-muted" style="font-size: 13px;">Registrar una nueva clasificación taxonómica en el sistema</p>
    </div>

    <div class="row">
        <div class="col-md-10 col-lg-8">
            <div class="figma-card">
                <form asp-action="Create" class="space-y-4">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" style="font-size: 13px;"></div>

                    <div class="section-label mt-0">Reino y División</div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Dominio" class="figma-label">Dominio *</label>
                            <input asp-for="Dominio" class="figma-input" value="Eukaryota" required />
                            <span asp-validation-for="Dominio" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Reino" class="figma-label">Reino *</label>
                            <input asp-for="Reino" class="figma-input" value="Plantae" required />
                            <span asp-validation-for="Reino" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="SubReino" class="figma-label">SubReino</label>
                            <input asp-for="SubReino" class="figma-input" />
                            <span asp-validation-for="SubReino" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="FiloDivision" class="figma-label">Filo / División *</label>
                        <input asp-for="FiloDivision" class="figma-input" required />
                        <span asp-validation-for="FiloDivision" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="section-label">Clasificación Media</div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Clase" class="figma-label">Clase *</label>
                            <input asp-for="Clase" class="figma-input" required />
                            <span asp-validation-for="Clase" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Orden" class="figma-label">Orden *</label>
                            <input asp-for="Orden" class="figma-input" required />
                            <span asp-validation-for="Orden" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="section-label">Familia y Tribu</div>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="Familia" class="figma-label">Familia *</label>
                            <input asp-for="Familia" class="figma-input" required />
                            <span asp-validation-for="Familia" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="SubFamilia" class="figma-label">SubFamilia</label>
                            <input asp-for="SubFamilia" class="figma-input" />
                            <span asp-validation-for="SubFamilia" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Tribu" class="figma-label">Tribu</label>
                            <input asp-for="Tribu" class="figma-input" />
                            <span asp-validation-for="Tribu" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="section-label">Género y Especie</div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Genero" class="figma-label">Género *</label>
                            <input asp-for="Genero" class="figma-input" required />
                            <span asp-validation-for="Genero" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Especie" class="figma-label">Especie *</label>
                            <input asp-for="Especie" class="figma-input" required />
                            <span asp-validation-for="Especie" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4 pt-3" style="border-top: 1px solid #e5e7eb;">
                        <a asp-action="Index" class="figma-btn-secondary">Volver</a>
                        <button type="button" id="btnGuardar" class="figma-btn-primary">Guardar Taxonomía</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.getElementById('btnGuardar').addEventListener('click', function (e) {
            e.preventDefault();
            
            // Validar formulario
            var form = this.closest('form');
            if (!form.checkValidity()) {
                form.reportValidity();
                return;
            }

            Swal.fire({
                title: '¿Confirmar Taxonomía?',
                text: "Estás a punto de registrar esta nueva taxonomía en el sistema.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#10b981',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Sí, Guardar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            })
        });
    </script>
}
