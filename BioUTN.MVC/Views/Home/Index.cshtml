@model IEnumerable<BioUTN.MVC.Models.ProyectoViewModel>
@{
    ViewData["Title"] = "Dashboard";
}

<style>
    /* Estilos del Calendario Premium BioUTN */
    .calendar-card {
        background: var(--surface);
        border-radius: 14px;
        box-shadow: var(--shadow-sm);
        padding: 1.5rem;
        border: 1px solid var(--border-color);
    }
    .calendar-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }
    .calendar-title {
        text-align: center;
        line-height: 1.2;
    }
    .calendar-title h6 { font-weight: bold; margin: 0; font-size: 1.1rem; color: var(--brand-primary); }
    .calendar-title small { color: #64748B; font-size: 0.8rem; }
    .btn-cal-nav {
        background: #F8FAFC;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        width: 35px;
        height: 35px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-main);
        cursor: pointer;
        transition: all 0.2s;
    }
    .btn-cal-nav:hover { background: #E2E8F0; }
    
    .calendar-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 5px;
        text-align: center;
    }
    .cal-day-header {
        font-size: 0.8rem;
        color: #64748B;
        margin-bottom: 10px;
    }
    .cal-day {
        width: 35px;
        height: 35px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: auto;
        font-size: 0.95rem;
        color: var(--text-main);
        border-radius: 50%;
        position: relative;
        cursor: pointer;
        transition: all 0.2s;
    }
    .cal-day:hover { background: rgba(46, 125, 50, 0.1); }
    .cal-day.active { background: var(--brand-primary); color: #fff; font-weight: bold; box-shadow: var(--shadow-sm); }
    
    .cal-dots {
        position: absolute;
        bottom: 2px;
        display: flex;
        gap: 2px;
    }
    .dot { width: 4px; height: 4px; border-radius: 50%; }
    .dot-green { background: #2ecc71; }
    .dot-orange { background: #f39c12; }
    .dot-red { background: #e74c3c; }

    .cal-divider {
        border-top: 1px solid var(--border-color);
        margin: 1.5rem 0;
    }

    /* KPI Cards Styles */
    .figma-card {
        background-color: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 0.75rem;
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        padding: 1.25rem;
        transition: all 0.2s;
    }
    .figma-section-title {
        font-size: 11px;
        font-weight: 600;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 1.2px;
        margin-bottom: 1.25rem;
    }
    .kpi-card {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.5rem;
        padding: 0.75rem;
        border-radius: 0.75rem;
        border: 1px solid #e5e7eb;
        background-color: #f9fafb;
        transition: all 0.2s;
        text-decoration: none;
    }
    .kpi-card:hover {
        border-color: rgba(16, 185, 129, 0.3);
        box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
    }
    .kpi-icon-box {
        width: 32px;
        height: 32px;
        border-radius: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .kpi-value {
        font-size: 1.5rem;
        font-weight: 700;
        color: #111827;
        line-height: 1;
        margin: 0;
    }
    .kpi-label {
        font-size: 11px;
        color: #6b7280;
        margin: 0;
    }
    .health-bar-container {
        display: flex;
        height: 12px;
        border-radius: 9999px;
        overflow: hidden;
        gap: 2px;
    }
    .bg-emerald-50 { background-color: #ecfdf5; }
    .text-emerald-600 { color: #059669; }
    .bg-purple-50 { background-color: #faf5ff; }
    .text-purple-600 { color: #9333ea; }
    .bg-teal-50 { background-color: #f0fdfa; }
    .text-teal-600 { color: #0d9488; }
    .bg-blue-50 { background-color: #eff6ff; }
    .text-blue-600 { color: #2563eb; }
    .bg-violet-50 { background-color: #f5f3ff; }
    .text-violet-600 { color: #7c3aed; }
    .bg-orange-50 { background-color: #fff7ed; }
    .text-orange-600 { color: #ea580c; }
    .bg-pink-50 { background-color: #fdf2f8; }
    .text-pink-600 { color: #db2777; }

    /* Tareas Pendientes */
    .pending-header {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-bottom: 1.2rem;
        font-weight: bold;
        color: var(--text-main);
    }
    .badge-count {
        background: var(--alert-danger);
        color: #fff;
        width: 25px;
        height: 25px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.85rem;
    }
    
    .task-card {
        background: #F8FAFC;
        border-radius: 10px;
        padding: 1rem;
        margin-bottom: 1rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border: 1px solid var(--border-color);
        transition: transform 0.2s;
    }
    .task-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-sm); background: #F1F5F9; }
    .task-info h6 { font-weight: bold; font-size: 0.95rem; color: var(--text-main); margin-bottom: 3px; }
    .task-info p { margin: 0; font-size: 0.8rem; color: #64748B; line-height: 1.3; }
    .task-status { text-align: center; }
    .status-icon {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 5px;
        font-size: 0.8rem;
    }
    .status-icon.danger { background: rgba(211, 47, 47, 0.1); color: var(--alert-danger); border: 1px solid rgba(211, 47, 47, 0.2); }
    .status-icon.warning { background: rgba(245, 124, 0, 0.1); color: var(--alert-warning); border: 1px solid rgba(245, 124, 0, 0.2); }
    .status-icon.success { background: rgba(46, 125, 50, 0.1); color: var(--brand-primary); border: 1px solid rgba(46, 125, 50, 0.2); }
    
    .status-text { font-size: 0.75rem; font-weight: bold; }
    .text-danger-custom { color: #ff6b6b; }
    .text-warning-custom { color: #f39c12; }
    .text-success { color: #2ecc71; }
</style>

<div class="container-fluid py-4">
    <div class="row g-4">
        <!-- Left Column: Calendar & Charts -->
        <div class="col-12 col-xl-7">
            <!-- Calendario de Notificaciones -->
            <div class="calendar-card mb-4">
                <div class="calendar-header">
                    <button class="btn-cal-nav" onclick="prevMonth()"><i class="fas fa-chevron-left"></i></button>
                    <div class="calendar-title">
                        <h6 id="calMonthName">Julio</h6>
                        <small id="calYearText">2026</small>
                    </div>
                    <button class="btn-cal-nav" onclick="nextMonth()"><i class="fas fa-chevron-right"></i></button>
                </div>
                <div class="calendar-grid" id="calendarGrid"></div>
                <div class="cal-divider"></div>
                <div class="pending-header">
                    <div class="badge-count" id="pendingCount">0</div>
                    <span id="pendingDateText">Pendientes</span>
                </div>
                <div id="tasksContainer" style="max-height: 300px; overflow-y: auto;"></div>
            </div>

            <!-- Gráficos -->
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="figma-card h-100">
                        <p class="figma-section-title">Lotes por Fase</p>
                        <div style="position: relative; height: 220px; width: 100%;">
                            <canvas id="faseChart"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="figma-card h-100">
                        <p class="figma-section-title">Estado de Frascos</p>
                        <div style="position: relative; height: 220px; width: 100%;">
                            <canvas id="frascosChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: KPI Cards -->
        <div class="col-12 col-xl-5">
            <!-- Stats Panel: Cultivos -->
            <div class="figma-card mb-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <p class="figma-section-title mb-0">Resumen de Cultivos</p>
                </div>
                <div class="row g-3 mb-4">
                    <div class="col-6">
                        <a asp-controller="LoteCultivos" asp-action="Index" class="kpi-card">
                            <div class="kpi-icon-box bg-emerald-50 text-emerald-600"><i class="bi bi-flower1"></i></div>
                            <div>
                                <p class="kpi-value">@ViewBag.TotalFrascos</p>
                                <p class="kpi-label">Plantas In Vitro</p>
                            </div>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="Especies" asp-action="Index" class="kpi-card">
                            <div class="kpi-icon-box bg-purple-50 text-purple-600"><i class="bi bi-box"></i></div>
                            <div>
                                <p class="kpi-value">@ViewBag.TotalEspecies</p>
                                <p class="kpi-label">Especies</p>
                            </div>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="PlantaMadres" asp-action="Index" class="kpi-card">
                            <div class="kpi-icon-box bg-teal-50 text-teal-600"><i class="bi bi-tree"></i></div>
                            <div>
                                <p class="kpi-value">@ViewBag.TotalPlantasMadre</p>
                                <p class="kpi-label">Plantas Madre</p>
                            </div>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="LoteCultivos" asp-action="Index" class="kpi-card">
                            <div class="kpi-icon-box bg-blue-50 text-blue-600"><i class="bi bi-droplet"></i></div>
                            <div>
                                <p class="kpi-value">@ViewBag.TotalLotes</p>
                                <p class="kpi-label">Lotes Activos</p>
                            </div>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Stats Panel: Zona de Trabajo -->
            <div class="figma-card mb-4">
                <div class="d-flex align-items-center justify-content-between mb-3">
                    <p class="figma-section-title mb-0">Resumen de Zona</p>
                </div>
                <div class="row g-3">
                    <div class="col-6">
                        <a asp-controller="Equipos" asp-action="Index" class="kpi-card">
                            <div class="kpi-icon-box bg-teal-50 text-teal-600"><i class="bi bi-display"></i></div>
                            <div>
                                <p class="kpi-value">@ViewBag.TotalEquipos</p>
                                <p class="kpi-label">Equipos Totales</p>
                            </div>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="ReservaEquipos" asp-action="Index" class="kpi-card">
                            <div class="kpi-icon-box bg-orange-50 text-orange-600"><i class="bi bi-clock"></i></div>
                            <div>
                                <p class="kpi-value">@ViewBag.ReservasActivas</p>
                                <p class="kpi-label">Reservas Activas</p>
                            </div>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="UbicacionFisicas" asp-action="Index" class="kpi-card">
                            <div class="kpi-icon-box bg-pink-50 text-pink-600"><i class="bi bi-geo-alt"></i></div>
                            <div>
                                <p class="kpi-value">@ViewBag.TotalAnaqueles</p>
                                <p class="kpi-label">Anaqueles</p>
                            </div>
                        </a>
                    </div>
                    <div class="col-6">
                        <a asp-controller="Biblioteca" asp-action="Index" class="kpi-card">
                            <div class="kpi-icon-box bg-violet-50 text-violet-600"><i class="bi bi-book"></i></div>
                            <div>
                                <p class="kpi-value">@ViewBag.TotalDocumentos</p>
                                <p class="kpi-label">Documentos</p>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="fab-container">
    <button class="fab-btn shadow-lg" onclick="simulateQRScan()">
        <i class="fas fa-qrcode"></i>
    </button>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Cargar datos dinámicos desde el backend
        const mockTasks = @Html.Raw(ViewBag.MockTasksJson ?? "{}");

        let currentDate = new Date(); // Fecha actual
        const monthNames = ["Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio", "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"];

        function renderCalendar() {
            const year = currentDate.getFullYear();
            const month = currentDate.getMonth();

            document.getElementById("calMonthName").innerText = monthNames[month];
            document.getElementById("calYearText").innerText = year;

            const grid = document.getElementById("calendarGrid");
            grid.innerHTML = `
                <div class="cal-day-header">Lun</div>
                <div class="cal-day-header">Mar</div>
                <div class="cal-day-header">Mié</div>
                <div class="cal-day-header">Jue</div>
                <div class="cal-day-header">Vie</div>
                <div class="cal-day-header">Sáb</div>
                <div class="cal-day-header">Dom</div>
            `;

            const firstDayIndex = new Date(year, month, 1).getDay();
            const startDay = firstDayIndex === 0 ? 6 : firstDayIndex - 1; // Lunes = 0

            const daysInMonth = new Date(year, month + 1, 0).getDate();

            for (let i = 0; i < startDay; i++) {
                grid.innerHTML += `<div></div>`;
            }

            let htmlString = "";
            let today = new Date();

            for (let i = 1; i <= daysInMonth; i++) {
                const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(i).padStart(2, '0')}`;
                let dotsHtml = '';
                const tasks = mockTasks[dateStr] || [];
                
                if (tasks.length > 0) {
                    let dots = '';
                    let hasDanger = false, hasWarning = false, hasSuccess = false;
                    tasks.forEach(t => {
                        if (t.type === 'danger') hasDanger = true;
                        if (t.type === 'warning') hasWarning = true;
                        if (t.type === 'success') hasSuccess = true;
                    });
                    if (hasDanger) dots += '<div class="dot dot-red"></div>';
                    if (hasWarning) dots += '<div class="dot dot-orange"></div>';
                    if (hasSuccess) dots += '<div class="dot dot-green"></div>';
                    dotsHtml = `<div class="cal-dots">${dots}</div>`;
                }

                // Día seleccionado por defecto (hoy)
                let activeClass = '';
                if (year === today.getFullYear() && month === today.getMonth() && i === today.getDate()) {
                    activeClass = 'active'; 
                }

                htmlString += `
                    <div class="cal-day ${activeClass}" onclick="selectDay(this, ${i}, ${month+1}, ${year})">
                        ${i}
                        ${dotsHtml}
                    </div>
                `;
            }
            grid.innerHTML += htmlString;
        }

        function prevMonth() {
            currentDate.setMonth(currentDate.getMonth() - 1);
            renderCalendar();
            renderTasksForMonth();
        }

        function nextMonth() {
            currentDate.setMonth(currentDate.getMonth() + 1);
            renderCalendar();
            renderTasksForMonth();
        }

        function renderTasksForMonth() {
            const container = document.getElementById('tasksContainer');
            container.innerHTML = `<div class="text-center text-muted mt-4"><i class="fas fa-calendar-alt fs-3 mb-2 text-info"></i><p>Selecciona un día para ver sus tareas.</p></div>`;
            document.getElementById('pendingCount').innerText = '0';
            document.getElementById('pendingDateText').innerText = `Pendientes (${monthNames[currentDate.getMonth()]})`;
        }

        function selectDay(dayElement, dayNumber, monthNumber, yearNumber) {
            document.querySelectorAll('.cal-day').forEach(el => el.classList.remove('active'));
            dayElement.classList.add('active');
            renderTasks(dayNumber, monthNumber, yearNumber);
        }

        function renderTasks(dayNumber, monthNumber, yearNumber) {
            const m = monthNumber || (currentDate.getMonth() + 1);
            const y = yearNumber || currentDate.getFullYear();
            const dateStr = `${y}-${String(m).padStart(2, '0')}-${String(dayNumber).padStart(2, '0')}`;
            const tasks = mockTasks[dateStr] || [];
            
            document.getElementById('pendingCount').innerText = tasks.length;
            document.getElementById('pendingDateText').innerText = `Pendientes (${dayNumber} de ${monthNames[m-1]})`;

            const container = document.getElementById('tasksContainer');
            container.innerHTML = '';

            if (tasks.length === 0) {
                container.innerHTML = `<div class="text-center text-muted mt-4"><i class="fas fa-check-circle fs-3 mb-2 text-success"></i><p>No hay tareas críticas para este día.</p></div>`;
                return;
            }

            tasks.forEach(t => {
                let colorClass = 'text-muted';
                if(t.type === 'danger') colorClass = 'text-danger-custom';
                if(t.type === 'warning') colorClass = 'text-warning-custom';
                if(t.type === 'success') colorClass = 'text-success';

                const cardHtml = `
                <div class="task-card">
                    <div class="task-info">
                        <h6>${t.title}</h6>
                        <p>${t.subtitle1}</p>
                        <p>${t.subtitle2}</p>
                        <p style="font-size: 0.8rem; margin-top: 5px; color: #64748B;"><i class="bi bi-calendar"></i> Fecha: ${t.deadline}</p>
                    </div>
                    <div class="task-status" style="text-align: center; min-width: 80px;">
                        <div class="status-icon ${t.type}" style="font-size: 1.5rem; margin-bottom: 5px;"><i class="fas ${t.icon}"></i></div>
                        <div class="status-text ${colorClass}" style="font-size: 0.75rem;">${t.status}</div>
                    </div>
                </div>`;
                container.innerHTML += cardHtml;
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            renderCalendar();
            const today = new Date();
            renderTasks(today.getDate(), today.getMonth() + 1, today.getFullYear()); 

            // Initialize Charts
            const faseLabels = @Html.Raw(ViewBag.LotesPorFaseLabels ?? "[]");
            const faseData = @Html.Raw(ViewBag.LotesPorFaseData ?? "[]");
            
            if(faseLabels.length > 0) {
                new Chart(document.getElementById('faseChart'), {
                    type: 'bar',
                    data: {
                        labels: faseLabels,
                        datasets: [{
                            label: 'Lotes',
                            data: faseData,
                            backgroundColor: 'rgba(54, 162, 235, 0.6)',
                            borderColor: 'rgba(54, 162, 235, 1)',
                            borderWidth: 1
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } }
                    }
                });
            }

            const saludables = @ViewBag.Saludables;
            const contaminados = @ViewBag.Contaminados;
            
            new Chart(document.getElementById('frascosChart'), {
                type: 'doughnut',
                data: {
                    labels: ['Saludables', 'Contaminados'],
                    datasets: [{
                        data: [saludables, contaminados],
                        backgroundColor: ['#2ecc71', '#ef4444']
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { position: 'bottom' } }
                }
            });
        });
    </script>
}
