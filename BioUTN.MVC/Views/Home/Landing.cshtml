@{
    ViewData["Title"] = "Bienvenido a Bio UTN";
    Layout = null; // Pantalla limpia de marketing
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #333;
        }
        .landing-header {
            text-align: center;
            padding: 4rem 1rem 2rem;
        }
        .brand-icon {
            font-size: 4rem;
            color: #2ecc71;
            margin-bottom: 1rem;
        }
        .main-title {
            font-weight: 900;
            letter-spacing: -1px;
            font-size: 2.5rem;
            color: #2c3e50;
            text-transform: uppercase;
        }
        .subtitle {
            font-size: 1.2rem;
            color: #555;
            margin-bottom: 3rem;
            font-weight: 500;
        }
        .features-grid {
            margin-bottom: 4rem;
        }
        .feature-card {
            background: white;
            border-radius: 15px;
            padding: 2rem;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            height: 100%;
            transition: transform 0.3s ease;
        }
        .feature-card:hover {
            transform: translateY(-5px);
        }
        .feature-icon-wrapper {
            font-size: 3rem;
            color: #34495e;
            margin-bottom: 1.5rem;
            display: flex;
            justify-content: center;
            gap: 15px;
        }
        .feature-title {
            font-weight: bold;
            font-size: 1.1rem;
            text-transform: uppercase;
            margin-bottom: 1rem;
            color: #2c3e50;
        }
        .feature-text {
            color: #666;
            font-size: 0.95rem;
            line-height: 1.5;
        }
        .cta-section {
            text-align: center;
            margin-bottom: 4rem;
        }
        .btn-cta {
            background-color: #2c3e50;
            
            font-size: 1.3rem;
            font-weight: bold;
            padding: 1rem 3rem;
            border-radius: 50px;
            border: 3px solid #2c3e50;
            text-decoration: none;
            transition: all 0.3s ease;
            box-shadow: 0 5px 15px rgba(44, 62, 80, 0.3);
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .btn-cta:hover {
            background-
            color: #2c3e50;
        }
        .decoration-section {
            position: fixed;
            bottom: 20px;
            right: 20px;
            text-align: right;
            opacity: 0.7;
        }
        .decoration-text {
            font-size: 0.8rem;
            font-style: italic;
            border-bottom: 1px solid #ccc;
            padding-bottom: 5px;
            margin-bottom: 5px;
        }
        .footer {
            text-align: center;
            padding: 2rem;
            color: #888;
            font-size: 0.9rem;
            background: #fff;
            border-top: 1px solid #eee;
        }
    </style>
</head>
<body>

    <div class="container">
        <!-- Header -->
        <div class="landing-header">
            <div class="brand-icon">
                <i class="fas fa-flask"></i><i class="fas fa-dna" style="margin-left:-25px; font-size: 2rem; color: #34495e; background: white; border-radius: 50%; padding: 5px;"></i>
            </div>
            <h1 class="main-title">Plataforma<br>Biovegetal</h1>
            <p class="subtitle">Descubre el Futuro de la Biotecnología en tus Cultivos In Vitro</p>
        </div>

        <!-- Features -->
        <div class="row g-4 features-grid">
            <!-- 1 -->
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-title">1. Control Total y Trazabilidad</div>
                    <div class="feature-icon-wrapper">
                        <i class="fas fa-qrcode"></i>
                        <i class="fas fa-mobile-alt"></i>
                    </div>
                    <p class="feature-text">Desde la Planta Madre hasta el laboratorio final. Monitoreo por frasco, lote y especie.</p>
                </div>
            </div>
            <!-- 2 -->
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-title">2. Gestión Eficiente del Laboratorio</div>
                    <div class="feature-icon-wrapper">
                        <i class="fas fa-vial"></i>
                        <i class="fas fa-calendar-alt"></i>
                    </div>
                    <p class="feature-text">Optimiza la producción de plantas medicinales y agrícolas con datos precisos.</p>
                </div>
            </div>
            <!-- 3 -->
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-title">3. Alertas y Análisis de Datos</div>
                    <div class="feature-icon-wrapper">
                        <i class="fas fa-bell"></i>
                        <i class="fas fa-chart-bar"></i>
                    </div>
                    <p class="feature-text">Notificaciones críticas en tiempo real (contaminación, resiembra) y reportes automatizados.</p>
                </div>
            </div>
        </div>

        <!-- Call to Action -->
        <div class="cta-section">
            <a href="/Account/Login" class="btn-cta">
                [ Iniciar Sesión ]
            </a>
        </div>
    </div>

    <!-- Decorative Element -->
    <div class="decoration-section d-none d-md-block">
        <div class="decoration-text">
            Cultivo In Vitro de Tejidos<br>
            Plantas Madre <em>C. Nubigenum</em>
        </div>
        <div class="d-flex justify-content-end gap-2 fs-3 text-secondary mt-2">
            <i class="fas fa-vial"></i>
            <i class="fas fa-vial"></i>
            <i class="fas fa-seedling"></i>
        </div>
    </div>

    <footer class="footer">
        &copy; 2026 Bio UTN
    </footer>

</body>
</html>
