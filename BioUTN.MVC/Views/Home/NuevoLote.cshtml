@{
    ViewData["Title"] = "Flujo de Registro (Nuevo Lote)";
    Layout = "_DashboardLayout";
}

<div class="card panel-flujo">
    <h3 class="card-title"><i class="fa-solid fa-plus-circle"></i> Flujo de Registro (Nuevo Lote)</h3>
    <div style="display: flex; gap: 3rem;">
        <div style="flex: 1;">
            <div class="form-group">
                <label>1. Especie</label>
                <select class="form-control"><option>Seleccionar Especie...</option></select>
            </div>
            <div class="form-group">
                <label>2. Detalles Lote</label>
                <input type="text" class="form-control" placeholder="Lote">
                <input type="text" class="form-control" placeholder="Ubicación" style="margin-top: 0.8rem;">
            </div>
        </div>
        <div style="flex: 1;">
            <div class="form-group">
                <label>Detalles Lote (Cont.)</label>
                <input type="text" class="form-control" placeholder="Detalles Adicionales">
                <select class="form-control" style="margin-top: 0.8rem;"><option>Urgente</option></select>
            </div>
        </div>
        <div style="flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; background: var(--bg-color); padding: 1rem; border-radius: 8px;">
            <div style="font-size: 1rem; font-weight: 500; margin-bottom: 1rem; color: var(--text-dark);">3. Ubicación y QR</div>
            <i class="fa-solid fa-qrcode" style="font-size: 5rem; color: var(--text-dark);"></i>
            <button style="margin-top: 1.5rem; padding: 0.75rem 1.5rem; border-radius: 6px; border: 1px solid var(--border-color); background: white; cursor: pointer; font-weight: 600;"><i class="fa-solid fa-print"></i> Imprimir Etiquetas</button>
        </div>
    </div>
    <div style="margin-top: 2rem; border-top: 1px solid var(--border-color); padding-top: 1.5rem;">
        <strong style="color: var(--text-dark);">5. Registro de Operación (Tesista):</strong>
        <label style="margin-left: 1.5rem; cursor: pointer;"><input type="checkbox" checked style="margin-right: 0.5rem;"> Control de Salud: Sano/Contaminado</label>
    </div>
</div>
