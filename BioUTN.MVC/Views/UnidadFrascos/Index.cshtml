@model IEnumerable<BioUTN.Modelos.UnidadFrasco>

@{
    ViewData["Title"] = "Inventario de Frascos (Unidades)";
}

<style>
    .figma-container { font-family: 'Inter', -apple-system, sans-serif; background-color: #f9fafb; padding: 20px; border-radius: 12px; }
    .figma-card { background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 0.75rem; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); padding: 1.25rem; transition: all 0.2s; height: 100%; display: flex; flex-direction: column; justify-content: space-between; }
    .figma-card:hover { box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); border-color: rgba(16, 185, 129, 0.2); }
    
    .badge-status { font-size: 0.75rem; font-weight: 600; padding: 0.25rem 0.5rem; border-radius: 9999px; display: inline-block; }
    .badge-status-sano { background-color: #ecfdf5; color: #047857; }
    .badge-status-enfermo { background-color: #fef2f2; color: #b91c1c; }
    .badge-status-regular { background-color: #fffbeb; color: #b45309; }
    
    .card-actions { display: flex; gap: 0.5rem; margin-top: 1rem; border-top: 1px solid #f3f4f6; padding-top: 0.75rem; }
    .action-link { font-size: 0.75rem; color: #4b5563; text-decoration: none; display: inline-flex; align-items: center; gap: 0.25rem; padding: 0.25rem 0.5rem; border-radius: 0.375rem; transition: all 0.2s; }
    .action-link:hover { background-color: #f3f4f6; color: #111827; }

    .meta-grid { display: grid; grid-template-columns: 1fr; gap: 0.5rem; font-size: 11px; margin-top: 1rem; color: #6b7280; }
    .meta-item p { margin: 0; }
    .meta-title { text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600; color: #9ca3af; }
    .meta-val { font-weight: 500; color: #374151; margin-top: 2px !important; }
</style>

<div class="container-fluid py-4 figma-container">
    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
        <div>
            <h1 class="h3 mb-1" style="font-weight: 700; color: #111827;">Frascos In Vitro</h1>
            <p class="text-muted mb-0" style="font-size: 14px;">Gestión de unidades individuales y seguimientos</p>
        </div>
    </div>

    <!-- Grid Layout -->
    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                    <div class="figma-card">
                        <div>
                            <div class="d-flex justify-content-between align-items-start gap-3">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="bg-teal-50 text-teal-600 rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px; background: #ccfbf1;">
                                        <i class="bi bi-droplet-half" style="font-size: 1rem; color: #0d9488;"></i>
                                    </div>
                                    <div>
                                        <div class="font-mono text-sm font-bold text-primary" style="font-size: 12px; font-family: monospace;">@item.CodigoUnidad</div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="mt-2 mb-1">
                                @{
                                    var fitoClass = "badge-status-sano";
                                    var fito = item.Estado?.ToLower() ?? "";
                                    if (fito.Contains("muerto") || fito.Contains("contaminado") || fito.Contains("hongo") || fito.Contains("bacteria"))
                                        fitoClass = "badge-status-enfermo";
                                    else if (fito.Contains("oxidado") || fito.Contains("regular"))
                                        fitoClass = "badge-status-regular";
                                }
                                <span class="badge-status @fitoClass">@item.Estado</span>
                            </div>

                            <div class="meta-grid">
                                <div class="meta-item">
                                    <p class="meta-title">Lote de Origen</p>
                                    <p class="meta-val">@(item.LoteCultivo?.CodigoTrazabilidad ?? "N/A")</p>
                                </div>
                                <div class="meta-item">
                                    <p class="meta-title">Resiembra Actual</p>
                                    <p class="meta-val">R @item.NumeroResiembra</p>
                                </div>
                            </div>
                        </div>

                        <div class="card-actions">
                            <a asp-action="Details" asp-route-id="@item.Id" class="action-link">
                                <i class="bi bi-eye"></i> Historial Clínico
                            </a>
                            @if (User.IsInRole("Tecnico") || User.IsInRole("Coordinador"))
                            {
                                <a asp-controller="MonitoreoFitosanitarios" asp-action="Create" asp-route-frascoId="@item.Id" class="action-link" style="color: #10b981;">
                                    <i class="bi bi-heart-pulse"></i> Evaluar
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted mb-3 d-block"></i>
                <p class="text-muted">No se encontraron frascos registrados.</p>
            </div>
        }
    </div>
</div>
