@model IEnumerable<BioUTN.Modelos.BloqueDisponibilidad>

@{
    ViewData["Title"] = "Gestión de Horarios y Bloqueos";
    var equipos = ViewBag.Equipos as List<BioUTN.Modelos.Equipo> ?? new List<BioUTN.Modelos.Equipo>();
}

@section Styles {
<style>
    body { background-color: #f9fafb; font-family: 'Inter', -apple-system, sans-serif; }
    .figma-container { padding: 40px 20px; max-width: 1000px; margin: 0 auto; }
    .figma-header { margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: flex-end; }
    .figma-title { font-size: 24px; font-weight: 700; color: #111827; margin-bottom: 0.25rem; }
    .figma-subtitle { font-size: 14px; color: #6b7280; }
    
    .figma-card { background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 2rem; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); margin-bottom: 2rem; }
    
    .figma-label { font-size: 14px; font-weight: 600; color: #374151; margin-bottom: 0.5rem; display: block; }
    .figma-input { width: 100%; border: 1px solid #d1d5db; border-radius: 8px; padding: 0.6rem 1rem; font-size: 14px; transition: border-color 0.2s, box-shadow 0.2s; }
    .figma-input:focus { outline: none; border-color: #3b82f6; box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1); }
    
    .figma-btn-primary { background-color: #10b981; color: white; border: none; padding: 0.75rem 1.5rem; border-radius: 8px; font-size: 14px; font-weight: 600; transition: all 0.2s; display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem; }
    .figma-btn-primary:hover { background-color: #059669; color: white; transform: translateY(-1px); }
    
    .figma-table-card { background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); }
    .figma-table { width: 100%; margin: 0; border-collapse: separate; border-spacing: 0; }
    .figma-table th { background-color: #f9fafb; padding: 12px 16px; font-size: 12px; font-weight: 600; color: #6b7280; text-transform: uppercase; border-bottom: 1px solid #e5e7eb; text-align: left; }
    .figma-table td { padding: 16px; font-size: 14px; color: #111827; border-bottom: 1px solid #e5e7eb; vertical-align: middle; }
    .figma-table tbody tr:hover { background-color: #f9fafb; }
    
    .badge-gray { background-color: #f3f4f6; color: #374151; padding: 4px 8px; border-radius: 6px; font-size: 12px; font-weight: 600; border: 1px solid #e5e7eb; }
</style>
}

<div class="figma-container">
    <div class="figma-header">
        <div>
            <h1 class="figma-title">Gestión de Horarios</h1>
            <p class="figma-subtitle">Bloquea horas para mantenimiento, eventos o indisponibilidad (de 08:00 a 17:00).</p>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Volver a Reservas
            </a>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="figma-card">
        <h5 class="fw-bold mb-4"><i class="bi bi-plus-circle-dotted text-primary me-2"></i> Nuevo Bloqueo de Horario</h5>
        <form asp-action="CreateBloque" method="post">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="figma-label">Equipo a bloquear</label>
                    <select name="IdEquipo" class="figma-input form-select" required>
                        <option value="">-- Seleccione el Equipo --</option>
                        @foreach (var eq in equipos)
                        {
                            <option value="@eq.Id">@eq.Nombre - @eq.Marca</option>
                        }
                    </select>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="figma-label">Día de la semana</label>
                    <select name="DiaSemana" class="figma-input form-select" required>
                        <option value="">-- Seleccione --</option>
                        <option value="lunes">Lunes</option>
                        <option value="martes">Martes</option>
                        <option value="miercoles">Miércoles</option>
                        <option value="jueves">Jueves</option>
                        <option value="viernes">Viernes</option>
                    </select>
                    <small class="text-muted">Se bloqueará todos los días seleccionados.</small>
                </div>
                <div class="col-md-4 mb-3">
                    <label class="figma-label">Hora Inicio</label>
                    <input type="time" name="HoraInicio" class="figma-input" min="08:00" max="17:00" required />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="figma-label">Hora Fin</label>
                    <input type="time" name="HoraFin" class="figma-input" min="08:00" max="17:00" required />
                </div>
                <div class="col-md-4 mb-3">
                    <label class="figma-label">Motivo (Ej. Evento, Mantenimiento)</label>
                    <input type="text" name="TipoReserva" class="figma-input" required />
                </div>
            </div>
            <div class="d-flex justify-content-end mt-3">
                <button type="submit" class="figma-btn-primary">
                    <i class="bi bi-lock-fill"></i> Bloquear Horario
                </button>
            </div>
        </form>
    </div>

    <h5 class="fw-bold mb-3">Horarios Bloqueados Actuales</h5>
    <div class="figma-table-card">
        <table class="figma-table">
            <thead>
                <tr>
                    <th>Equipo</th>
                    <th>Día</th>
                    <th>Horario</th>
                    <th>Motivo</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold" style="color: #4f46e5;">
                            @(item.Equipo?.Nombre ?? "Equipo ID: " + item.IdEquipo)
                        </td>
                        <td><span class="badge-gray" style="text-transform: capitalize;">@item.DiaSemana</span></td>
                        <td><i class="bi bi-clock text-muted me-1"></i> @item.HoraInicio.ToString(@"hh\:mm") - @item.HoraFin.ToString(@"hh\:mm")</td>
                        <td>@item.TipoReserva</td>
                        <td class="text-end">
                            <form asp-action="DeleteBloque" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('¿Seguro que deseas eliminar este bloqueo y liberar el horario?')">
                                    <i class="bi bi-trash"></i> Desbloquear
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">
                            <i class="bi bi-unlock fs-2 d-block mb-2"></i>
                            No hay ningún horario bloqueado actualmente.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
