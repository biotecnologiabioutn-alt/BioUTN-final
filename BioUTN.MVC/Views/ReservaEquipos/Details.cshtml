@model BioUTN.Modelos.ReservaEquipo

@{
    ViewData["Title"] = "Detalles de Reserva";
}

@section Styles {
<style>
    body { background-color: #f9fafb; font-family: 'Inter', -apple-system, sans-serif; }
    .figma-container { padding: 40px 20px; max-width: 800px; margin: 0 auto; }
    .figma-header { margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: flex-end; }
    .figma-title { font-size: 24px; font-weight: 700; color: #111827; margin-bottom: 0.25rem; }
    .figma-subtitle { font-size: 14px; color: #6b7280; }
    
    .figma-card { background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 12px; padding: 2rem; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); }
    
    .figma-btn-primary { background-color: #10b981; color: white; border: none; padding: 0.5rem 1rem; border-radius: 8px; font-size: 14px; font-weight: 500; transition: all 0.2s; display: inline-flex; align-items: center; gap: 0.5rem; text-decoration: none; }
    .figma-btn-primary:hover { background-color: #059669; color: white; transform: translateY(-1px); }

    .figma-btn-secondary { background-color: white; color: #374151; border: 1px solid #e5e7eb; padding: 0.5rem 1rem; border-radius: 8px; font-size: 14px; font-weight: 500; transition: all 0.2s; display: inline-flex; align-items: center; gap: 0.5rem; text-decoration: none; }
    .figma-btn-secondary:hover { background-color: #f9fafb; color: #111827; }

    .detail-row { display: flex; padding: 1rem 0; border-bottom: 1px solid #f3f4f6; }
    .detail-row:last-child { border-bottom: none; padding-bottom: 0; }
    .detail-label { width: 35%; font-size: 13px; font-weight: 600; color: #6b7280; text-transform: uppercase; letter-spacing: 0.5px; }
    .detail-value { width: 65%; font-size: 15px; color: #111827; font-weight: 500; }
    
    .status-badge { display: inline-flex; align-items: center; padding: 4px 10px; border-radius: 9999px; font-size: 13px; font-weight: 600; }
    .badge-aprobada { background-color: #d1fae5; color: #065f46; }
    .badge-pendiente { background-color: #fef3c7; color: #92400e; }
    .badge-rechazada { background-color: #fee2e2; color: #991b1b; }
    .badge-completada { background-color: #dbeafe; color: #1e40af; }
    .badge-cancelada { background-color: #f3f4f6; color: #4b5563; }
</style>
}

<div class="figma-container">
    <div class="figma-header">
        <div>
            <h1 class="figma-title">Detalles de Reserva</h1>
            <p class="figma-subtitle">Información completa sobre el turno y el equipo</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="figma-btn-secondary">
                <i class="bi bi-arrow-left"></i> Volver al Listado
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="figma-btn-primary">
                <i class="bi bi-pencil-square"></i> Modificar / Gestionar
            </a>
        </div>
    </div>

    <div class="figma-card">
        <div class="d-flex align-items-center gap-3 mb-4 pb-3" style="border-bottom: 1px solid #e5e7eb;">
            <div style="width: 48px; height: 48px; background-color: #f3f4f6; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; color: #10b981;">
                <i class="bi bi-calendar-check"></i>
            </div>
            <div>
                <h3 style="font-size: 18px; font-weight: 700; color: #111827; margin: 0;">Reserva de Equipo</h3>
                <p style="font-size: 14px; color: #6b7280; margin: 0;">Ref. @Model.Id</p>
            </div>
        </div>

        <div class="detail-row">
            <div class="detail-label">Equipo Asignado</div>
            <div class="detail-value">
                <div style="font-weight: 600; color: #4f46e5;">@(Model.Equipo != null ? Model.Equipo.Nombre : "Equipo ID: " + Model.IdEquipo)</div>
                <div style="font-size: 13px; color: #6b7280;">@(Model.Equipo != null ? Model.Equipo.CodigoInventario : "")</div>
            </div>
        </div>
        <div class="detail-row">
            <div class="detail-label">Solicitante</div>
            <div class="detail-value">@(Model.Usuario != null ? $"{Model.Usuario.Nombres} {Model.Usuario.Apellidos}" : "Usuario ID: " + Model.IdUsuario)</div>
        </div>
        <div class="detail-row">
            <div class="detail-label">Fecha del Turno</div>
            <div class="detail-value">
                <i class="bi bi-calendar-event text-muted me-2"></i>@Model.FechaReserva.ToString("dd MMMM yyyy")
            </div>
        </div>
        <div class="detail-row">
            <div class="detail-label">Horario Reservado</div>
            <div class="detail-value">
                <i class="bi bi-clock text-muted me-2"></i>@Model.HoraInicio.ToString(@"hh\:mm") - @Model.HoraFin.ToString(@"hh\:mm")
            </div>
        </div>
        <div class="detail-row">
            <div class="detail-label">Estado de la Reserva</div>
            <div class="detail-value">
                @if(Model.Estado == "Aprobada")
                {
                    <span class="status-badge badge-aprobada"><i class="bi bi-check2-circle me-1"></i> Aprobada</span>
                }
                else if(Model.Estado == "Pendiente")
                {
                    <span class="status-badge badge-pendiente"><i class="bi bi-hourglass-split me-1"></i> Pendiente</span>
                }
                else if (Model.Estado == "Rechazada")
                {
                    <span class="status-badge badge-rechazada"><i class="bi bi-x-circle me-1"></i> Rechazada</span>
                }
                else if (Model.Estado == "Completada")
                {
                    <span class="status-badge badge-completada"><i class="bi bi-check-all me-1"></i> Completada</span>
                }
                else
                {
                    <span class="status-badge badge-cancelada"><i class="bi bi-slash-circle me-1"></i> Cancelada</span>
                }
            </div>
        </div>
        <div class="detail-row">
            <div class="detail-label">Observaciones / Motivo</div>
            <div class="detail-value">@(string.IsNullOrEmpty(Model.ObservacionesCheckOut) ? "Sin observaciones" : Model.ObservacionesCheckOut)</div>
        </div>
    </div>
</div>
