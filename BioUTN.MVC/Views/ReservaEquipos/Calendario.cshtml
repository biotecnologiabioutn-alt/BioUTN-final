@{
    ViewData["Title"] = "Calendario de Reservas";
    var equipos = ViewBag.Equipos as List<BioUTN.Modelos.Equipo> ?? new List<BioUTN.Modelos.Equipo>();
    var reservas = ViewBag.Reservas as List<BioUTN.Modelos.ReservaEquipo> ?? new List<BioUTN.Modelos.ReservaEquipo>();
    var bloques = ViewBag.Bloques as List<BioUTN.Modelos.BloqueDisponibilidad> ?? new List<BioUTN.Modelos.BloqueDisponibilidad>();
    
    DateTime lunes = ViewBag.Lunes;
    DateTime viernes = ViewBag.Viernes;
    DateTime fechaBase = ViewBag.FechaBase;
    int? equipoId = ViewBag.EquipoSeleccionado;
    BioUTN.Modelos.Equipo equipoObj = ViewBag.EquipoObj;
    bool isEquipoDisponible = equipoObj == null || equipoObj.Estado.Equals("Disponible", StringComparison.OrdinalIgnoreCase);
}

@section Styles {
    <style>
        body { background-color: #f9fafb; font-family: 'Inter', -apple-system, sans-serif; }
        .calendar-container { padding: 30px; max-width: 1300px; margin: 0 auto; background: white; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1); }
        .calendar-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        .calendar-nav { display: flex; gap: 10px; align-items: center; }
        .btn-nav { background: #e5e7eb; border: 1px solid #d1d5db; padding: 6px 12px; border-radius: 6px; color: #374151; font-weight: bold; text-decoration: none; }
        .btn-nav:hover { background: #d1d5db; }
        .calendar-title { font-size: 28px; font-weight: 700; color: #1f2937; }
        
        .calendar-table { width: 100%; border-collapse: collapse; table-layout: fixed; }
        .calendar-table th, .calendar-table td { border: 1px solid #e5e7eb; text-align: center; }
        .calendar-table th { background: #f3f4f6; color: #4b5563; font-weight: 600; padding: 12px; font-size: 14px; }
        .time-col { width: 80px; background: #f9fafb; font-weight: 600; color: #6b7280; font-size: 13px; }
        .calendar-cell { height: 60px; padding: 4px; vertical-align: top; font-size: 12px; position: relative; transition: background 0.2s; }
        
        .cell-available { background-color: #f0fdf4; }
        
        .cell-reserved { background-color: #ef4444; color: white; border-radius: 4px; padding: 4px; font-weight: 500; height: 100%; display: flex; flex-direction: column; justify-content: center; align-items: flex-start; text-align: left; overflow: hidden; box-shadow: inset 0 0 0 1px rgba(0,0,0,0.1); }
        .cell-blocked { background-color: #9ca3af; color: white; border-radius: 4px; padding: 4px; font-weight: 500; height: 100%; display: flex; flex-direction: column; justify-content: center; align-items: center; }
        
        .legend-box { display: flex; gap: 15px; margin-top: 20px; font-size: 14px; align-items: center; }
        .legend-item { display: flex; align-items: center; gap: 5px; }
        .legend-color { width: 16px; height: 16px; border-radius: 4px; border: 1px solid rgba(0,0,0,0.1); }
    </style>
}

<div class="calendar-container mt-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <h2 class="fw-bold mb-0">Calendario de Reservas</h2>
            <p class="text-muted">Selecciona un equipo para ver su disponibilidad semanal.</p>
        </div>
        <div class="col-md-6">
            <form method="get" class="d-flex gap-2">
                <input type="hidden" name="fechaBase" value="@fechaBase.ToString("yyyy-MM-dd")" />
                <select name="equipoId" class="form-select border-2" onchange="this.form.submit()">
                    <option value="">-- Seleccione un Equipo --</option>
                    @foreach (var eq in equipos)
                    {
                        <option value="@eq.Id" selected="@(equipoId == eq.Id ? "selected" : null)">@eq.Nombre - @eq.Marca</option>
                    }
                </select>
            </form>
        </div>
    </div>

    @if (equipoId.HasValue)
    {
        <div class="calendar-header">
            <a asp-action="Calendario" asp-route-equipoId="@equipoId" asp-route-fechaBase="@DateTime.Today.ToString("yyyy-MM-dd")" class="btn btn-outline-secondary btn-sm fw-bold">Fecha actual</a>
            
            <div class="calendar-title">
                @lunes.ToString("MMM dd") – @viernes.ToString("MMM dd, yyyy")
            </div>
            
            <div class="calendar-nav">
                <a asp-action="Calendario" asp-route-equipoId="@equipoId" asp-route-fechaBase="@lunes.AddDays(-7).ToString("yyyy-MM-dd")" class="btn-nav"><i class="bi bi-caret-left-fill"></i></a>
                <a asp-action="Calendario" asp-route-equipoId="@equipoId" asp-route-fechaBase="@lunes.AddDays(7).ToString("yyyy-MM-dd")" class="btn-nav"><i class="bi bi-caret-right-fill"></i></a>
            </div>
        </div>

        @if (!isEquipoDisponible)
        {
            <div class="alert alert-warning d-flex align-items-center mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill fs-4 me-3"></i>
                <div>
                    <strong>Equipo No Disponible:</strong> Este equipo se encuentra actualmente en estado <strong>@equipoObj.Estado</strong> y no puede ser reservado hasta nuevo aviso.
                </div>
            </div>
        }

        <div class="table-responsive">
            <table class="calendar-table">
                <thead>
                    <tr>
                        <th class="time-col">Hora</th>
                        @for (int i = 0; i < 5; i++)
                        {
                            var currentDay = lunes.AddDays(i);
                            string[] dias = { "Lun", "Mar", "Mié", "Jue", "Vie" };
                            <th>@dias[i] @currentDay.ToString("M/dd")</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @for (int h = 8; h <= 17; h++)
                    {
                        var timeSpanStart = new TimeSpan(h, 0, 0);
                        var timeSpanEnd = new TimeSpan(h + 1, 0, 0);
                        
                        <tr>
                            <td class="time-col">@h.ToString("00"):00</td>
                            @for (int i = 0; i < 5; i++)
                            {
                                var currentDay = lunes.AddDays(i);
                                
                                // Buscar si hay reserva
                                var res = reservas.FirstOrDefault(r => r.FechaReserva.Date == currentDay &&
                                    ((timeSpanStart >= r.HoraInicio && timeSpanStart < r.HoraFin) || 
                                     (timeSpanEnd > r.HoraInicio && timeSpanEnd <= r.HoraFin) ||
                                     (timeSpanStart <= r.HoraInicio && timeSpanEnd >= r.HoraFin)));
                                
                                // Buscar si hay bloqueo (asumiendo DiaSemana en string español como "Lunes")
                                string diaString = currentDay.ToString("dddd", new System.Globalization.CultureInfo("es-ES")).ToLower();
                                // Quitamos tildes para comparar seguro
                                diaString = diaString.Replace("á","a").Replace("é","e").Replace("í","i").Replace("ó","o").Replace("ú","u");
                                
                                var block = bloques.FirstOrDefault(b => b.DiaSemana.ToLower().Contains(diaString) && 
                                    ((timeSpanStart >= b.HoraInicio && timeSpanStart < b.HoraFin) || 
                                     (timeSpanEnd > b.HoraInicio && timeSpanEnd <= b.HoraFin) ||
                                     (timeSpanStart <= b.HoraInicio && timeSpanEnd >= b.HoraFin)));

                                if (!isEquipoDisponible)
                                {
                                    <td class="calendar-cell">
                                        <div class="cell-blocked">
                                            <div>No Disponible</div>
                                            <div style="font-size:10px;">@equipoObj.Estado</div>
                                        </div>
                                    </td>
                                }
                                else if (res != null)
                                {
                                    <td class="calendar-cell">
                                        <div class="cell-reserved">
                                            <div class="fw-bold px-1">@h.ToString("00"):00 - Reservado</div>
                                            <div class="px-1" style="font-size:10px; opacity: 0.9;">@res.Usuario?.Nombres @res.Usuario?.Apellidos</div>
                                        </div>
                                    </td>
                                }
                                else if (block != null)
                                {
                                    <td class="calendar-cell">
                                        <div class="cell-blocked">
                                            <div>No Disponible</div>
                                            <div style="font-size:10px;">@block.TipoReserva</div>
                                        </div>
                                    </td>
                                }
                                else
                                {
                                    <td class="calendar-cell cell-available">
                                        <!-- Vacío = Disponible -->
                                    </td>
                                }
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="legend-box">
            <div class="legend-item"><div class="legend-color" style="background: white; border: 1px solid #d1d5db;"></div> Fecha actual.</div>
            <div class="legend-item"><div class="legend-color" style="background: #f0fdf4;"></div> Disponible.</div>
            <div class="legend-item"><div class="legend-color" style="background: #ef4444;"></div> Reservado.</div>
            <div class="legend-item"><div class="legend-color" style="background: #9ca3af;"></div> No disponible.</div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-calendar-x text-muted" style="font-size: 4rem;"></i>
            <h4 class="mt-3 text-muted">Seleccione un equipo para ver el calendario</h4>
        </div>
    }
</div>
