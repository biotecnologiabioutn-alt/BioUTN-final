@model IEnumerable<BioUTN.Modelos.ReservaEquipo>

@{
    ViewData["Title"] = "Gestión de Reservas";
}

@section Styles {
<style>
    body { background-color: #f9fafb; font-family: 'Inter', -apple-system, sans-serif; }
    .figma-container { padding: 40px 20px; max-width: 1100px; margin: 0 auto; }
    .figma-header { margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: flex-end; }
    .figma-title { font-size: 24px; font-weight: 700; color: #111827; margin-bottom: 0.25rem; }
    .figma-subtitle { font-size: 14px; color: #6b7280; }
    
    .figma-btn-primary { background-color: #10b981; color: white; border: none; padding: 0.5rem 1rem; border-radius: 8px; font-size: 14px; font-weight: 500; transition: all 0.2s; display: inline-flex; align-items: center; gap: 0.5rem; text-decoration: none; }
    .figma-btn-primary:hover { background-color: #059669; color: white; transform: translateY(-1px); }

    .figma-btn-secondary { background-color: white; color: #374151; border: 1px solid #e5e7eb; padding: 0.5rem 1rem; border-radius: 8px; font-size: 14px; font-weight: 500; transition: all 0.2s; display: inline-flex; align-items: center; gap: 0.5rem; text-decoration: none; }
    .figma-btn-secondary:hover { background-color: #f9fafb; color: #111827; }
    
    .figma-table-card { background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 12px; overflow: hidden; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); }
    .figma-table { width: 100%; margin: 0; border-collapse: separate; border-spacing: 0; }
    .figma-table th { background-color: #f9fafb; padding: 12px 16px; font-size: 12px; font-weight: 600; color: #6b7280; text-transform: uppercase; letter-spacing: 0.05em; border-bottom: 1px solid #e5e7eb; text-align: left; }
    .figma-table td { padding: 16px; font-size: 14px; color: #111827; border-bottom: 1px solid #e5e7eb; vertical-align: middle; }
    .figma-table tr:last-child td { border-bottom: none; }
    .figma-table tbody tr:hover { background-color: #f9fafb; }
    
    .figma-badge { display: inline-flex; align-items: center; padding: 2px 8px; border-radius: 9999px; font-size: 12px; font-weight: 500; }
    .badge-aprobada { background-color: #d1fae5; color: #065f46; }
    .badge-pendiente { background-color: #fef3c7; color: #92400e; }
    .badge-rechazada { background-color: #fee2e2; color: #991b1b; }
    .badge-completada { background-color: #dbeafe; color: #1e40af; }
    .badge-cancelada { background-color: #f3f4f6; color: #4b5563; }
    
    .figma-action-btn { background: none; border: none; padding: 6px; border-radius: 6px; color: #6b7280; transition: all 0.2s; display: inline-flex; }
    .figma-action-btn:hover { background-color: #f3f4f6; color: #111827; }
    .figma-action-btn.delete:hover { background-color: #fee2e2; color: #dc2626; }
</style>
}

<div class="figma-container">
    <div class="figma-header">
        <div>
            <h1 class="figma-title">Gestión de Reservas</h1>
            <p class="figma-subtitle">Historial y turnos de equipos (cabinas, autoclaves, etc.)</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Calendario" class="figma-btn-secondary">
                <i class="bi bi-calendar3"></i> Ver Calendario
            </a>
            <a asp-action="Bloques" class="figma-btn-secondary">
                <i class="bi bi-clock-history"></i> Configurar Horarios
            </a>
            <a asp-action="Create" class="figma-btn-primary">
                <i class="bi bi-plus-lg"></i> Nueva Reserva
            </a>
        </div>
    </div>

    <div class="figma-table-card">
        <table class="figma-table">
            <thead>
                <tr>
                    <th>Equipo</th>
                    <th>Solicitante</th>
                    <th>Fecha y Horario</th>
                    <th>Estado</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.OrderByDescending(x => x.FechaReserva).ThenByDescending(x => x.HoraInicio))
                {
                    <tr>
                        <td>
                            <div style="font-weight: 600; color: #4f46e5;">
                                @(item.Equipo != null ? item.Equipo.Nombre : "Equipo ID: " + item.IdEquipo)
                            </div>
                            <div style="font-size: 12px; color: #6b7280;">
                                @(item.Equipo != null ? item.Equipo.CodigoInventario : "")
                            </div>
                        </td>
                        <td>
                            <div style="font-weight: 500;">
                                @(item.Usuario != null ? $"{item.Usuario.Nombres} {item.Usuario.Apellidos}" : "Usuario ID: " + item.IdUsuario)
                            </div>
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <i class="bi bi-calendar-event text-muted"></i>
                                <span>@item.FechaReserva.ToString("dd MMM yyyy")</span>
                            </div>
                            <div class="d-flex align-items-center gap-2 mt-1" style="font-size: 13px; color: #6b7280;">
                                <i class="bi bi-clock text-muted"></i>
                                <span>@item.HoraInicio.ToString(@"hh\:mm") - @item.HoraFin.ToString(@"hh\:mm")</span>
                            </div>
                        </td>
                        <td>
                            @if(item.Estado == "Aprobada")
                            {
                                <span class="figma-badge badge-aprobada"><i class="bi bi-check2-circle me-1"></i> Aprobada</span>
                            }
                            else if(item.Estado == "Pendiente")
                            {
                                <span class="figma-badge badge-pendiente"><i class="bi bi-hourglass-split me-1"></i> Pendiente</span>
                            }
                            else if (item.Estado == "Rechazada")
                            {
                                <span class="figma-badge badge-rechazada"><i class="bi bi-x-circle me-1"></i> Rechazada</span>
                            }
                            else if (item.Estado == "Completada")
                            {
                                <span class="figma-badge badge-completada"><i class="bi bi-check-all me-1"></i> Completada</span>
                            }
                            else
                            {
                                <span class="figma-badge badge-cancelada"><i class="bi bi-slash-circle me-1"></i> Cancelada</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.Id" class="figma-action-btn" title="Editar / Ver Detalle">
                                <i class="bi bi-pencil-square"></i>
                            </a>
                            <button type="button" class="figma-action-btn delete" onclick="confirmDelete(@item.Id)" title="Eliminar">
                                <i class="bi bi-trash3"></i>
                            </button>
                            <form id="delete-form-@item.Id" asp-action="Delete" asp-route-id="@item.Id" method="post" style="display: none;"></form>
                        </td>
                    </tr>
                }
                
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5">
                            <i class="bi bi-calendar-x text-muted fs-2 mb-2 d-block"></i>
                            <p class="text-muted mb-0">No hay reservas registradas en el sistema.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function confirmDelete(id) {
            Swal.fire({
                title: '¿Eliminar Reserva?',
                text: "Esta acción liberará el espacio en el calendario y no se puede deshacer.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc2626',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('delete-form-' + id).submit();
                }
            });
        }
    </script>
}
