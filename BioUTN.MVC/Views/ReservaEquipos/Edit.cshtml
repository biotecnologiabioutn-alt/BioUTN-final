@model BioUTN.Modelos.ReservaEquipo

@{
    ViewData["Title"] = "Editar Reserva de Equipo";
    var equipos = ViewBag.Equipos as List<BioUTN.Modelos.Equipo> ?? new List<BioUTN.Modelos.Equipo>();
    var usuarios = ViewBag.Usuarios as List<BioUTN.Modelos.Usuario> ?? new List<BioUTN.Modelos.Usuario>();
}

@section Styles {
<style>
    .figma-container { font-family: 'Inter', -apple-system, sans-serif; background-color: #f9fafb; padding: 20px; border-radius: 12px; }
    .figma-card { background-color: #ffffff; border: 1px solid #e5e7eb; border-radius: 0.75rem; box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05); padding: 1.5rem; }
    .figma-label { font-size: 13px; font-weight: 600; color: #374151; margin-bottom: 0.5rem; display: block; }
    .figma-input { width: 100%; padding: 0.625rem 0.75rem; border-radius: 0.5rem; border: 1px solid #e5e7eb; font-size: 14px; color: #111827; outline: none; transition: all 0.2s; background-color: #ffffff; }
    .figma-input:focus { border-color: rgba(59, 130, 246, 0.6); box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2); }
    .figma-btn-primary { background-color: #3b82f6; color: white; border: none; padding: 0.625rem 1.25rem; border-radius: 0.5rem; font-size: 14px; font-weight: 500; transition: all 0.2s; }
    .figma-btn-primary:hover { background-color: #2563eb; color: white; }
    .figma-btn-secondary { background-color: white; color: #374151; border: 1px solid #e5e7eb; padding: 0.625rem 1.25rem; border-radius: 0.5rem; font-size: 14px; font-weight: 500; transition: all 0.2s; text-decoration: none; display: inline-flex; align-items: center; }
    .figma-btn-secondary:hover { background-color: #f9fafb; color: #111827; }
</style>
}

<div class="figma-container">
    <div class="mb-4">
        <h3 style="font-weight: 700; color: #111827; font-size: 18px;">Modificar Reserva</h3>
        <p class="text-muted" style="font-size: 13px;">Actualiza el horario o el estado de la reserva del equipo.</p>
    </div>

    <div class="row">
        <div class="col-md-10 col-lg-8">
            <div class="figma-card">
                <form asp-action="Edit" class="space-y-4">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 p-3 rounded bg-danger bg-opacity-10" style="font-size: 13px;"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="IdEquipo" class="figma-label">Equipo a Reservar *</label>
                            <select asp-for="IdEquipo" class="figma-input form-select" required>
                                <option value="">-- Seleccione el equipo --</option>
                                @foreach(var eq in equipos)
                                {
                                    <option value="@eq.Id">@eq.Nombre (@eq.CodigoInventario)</option>
                                }
                            </select>
                            <span asp-validation-for="IdEquipo" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="IdUsuario" class="figma-label">Usuario Solicitante *</label>
                            <select asp-for="IdUsuario" class="figma-input form-select" required>
                                <option value="">-- Seleccione su usuario --</option>
                                @foreach(var user in usuarios)
                                {
                                    <option value="@user.Id">@user.Nombres @user.Apellidos</option>
                                }
                            </select>
                            <span asp-validation-for="IdUsuario" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label asp-for="FechaReserva" class="figma-label">Fecha del Turno *</label>
                            <input asp-for="FechaReserva" type="date" class="figma-input" required />
                            <span asp-validation-for="FechaReserva" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="HoraInicio" class="figma-label">Hora Inicio *</label>
                            <input asp-for="HoraInicio" type="time" class="figma-input" required />
                            <span asp-validation-for="HoraInicio" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="HoraFin" class="figma-label">Hora Fin *</label>
                            <input asp-for="HoraFin" type="time" class="figma-input" required />
                            <span asp-validation-for="HoraFin" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Estado" class="figma-label">Estado de la Reserva *</label>
                            <select asp-for="Estado" class="figma-input form-select" required>
                                <option value="Pendiente">Pendiente</option>
                                <option value="Aprobada">Aprobada</option>
                                <option value="Rechazada">Rechazada</option>
                                <option value="Completada">Completada</option>
                                <option value="Cancelada">Cancelada</option>
                            </select>
                            <span asp-validation-for="Estado" class="text-danger small mt-1 d-block"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="ObservacionesCheckOut" class="figma-label">Observaciones (Opcional)</label>
                            <input asp-for="ObservacionesCheckOut" class="figma-input" placeholder="Ej: Equipo dejado limpio" />
                            <span asp-validation-for="ObservacionesCheckOut" class="text-danger small mt-1 d-block"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4 pt-3" style="border-top: 1px solid #e5e7eb;">
                        <a asp-action="Index" class="figma-btn-secondary">Volver</a>
                        <button type="submit" class="figma-btn-primary">Guardar Cambios</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
