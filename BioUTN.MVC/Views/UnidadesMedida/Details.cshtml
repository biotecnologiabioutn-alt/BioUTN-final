@model BioUTN.Modelos.UnidadMedida

@{
    ViewData["Title"] = "Detalles de Unidad de Medida";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="bioutn-title mb-0">Detalles de Unidad</h2>
    </div>
    <a asp-action="Index" class="btn bioutn-btn bioutn-btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Volver al Catálogo
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="bioutn-card">
            <div class="bioutn-card-header">
                <h5><i class="bi bi-info-circle me-2"></i> Información de la Unidad</h5>
            </div>
            <div class="bioutn-card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Nombre</dt>
                    <dd class="col-sm-8 fw-bold">@Model.Nombre</dd>

                    <dt class="col-sm-4 text-muted">Abreviatura</dt>
                    <dd class="col-sm-8"><span class="badge bg-secondary">@Model.Abreviatura</span></dd>

                    <dt class="col-sm-4 text-muted">Unidad Base</dt>
                    <dd class="col-sm-8">@Model.UnidadBase</dd>

                    <dt class="col-sm-4 text-muted">Factor de Conversión</dt>
                    <dd class="col-sm-8 text-primary fw-bold">x @Model.FactorConversion.ToString("0.##")</dd>
                </dl>

                <div class="text-end mt-4 pt-3 border-top">
                    <a asp-action="Edit" asp-route-id="@Model?.Id" class="btn btn-outline-primary px-4 shadow-sm">
                        <i class="bi bi-pencil me-1"></i> Editar
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
